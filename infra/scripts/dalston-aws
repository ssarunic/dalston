#!/usr/bin/env python3
"""dalston-aws — provision and manage Dalston on AWS without Terraform.

Usage:
    dalston-aws setup -t TEMPLATE [--region R]     # provision infra (S3, IAM, SG)
    dalston-aws launch [control-plane|gpu]          # launch instances
    dalston-aws terminate [control-plane|gpu]       # terminate instances
    dalston-aws up / down                           # start/stop without terminating
    dalston-aws status / ssh [main|gpu] / teardown

Templates:
    YAML files in infra/templates/ define instance types, spot preferences,
    and compose profiles. Presets: cpu, split, gpu.

Prerequisites:
    - AWS credentials configured (boto3 must be able to call sts:GetCallerIdentity)
    - pip install boto3 pyyaml
"""

from __future__ import annotations

import argparse
import base64
import json
import os
import shlex
import subprocess
import sys
import time
from dataclasses import asdict, dataclass
from datetime import UTC, datetime
from pathlib import Path
from typing import Any, NoReturn

import boto3
import yaml
from botocore.exceptions import ClientError, WaiterError

