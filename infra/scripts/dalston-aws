# ---------------------------------------------------------------------------
# Colored output helpers
# ---------------------------------------------------------------------------

_RED = "\033[0;31m"
_GREEN = "\033[0;32m"
_YELLOW = "\033[1;33m"
_BLUE = "\033[0;34m"
_NC = "\033[0m"


def log(msg: str) -> None:
    print(f"{_GREEN}[dalston-aws]{_NC} {msg}")


def audit(action: str, **details: Any) -> None:
    """Append a line to the audit log."""
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    ts = datetime.now(UTC).strftime("%Y-%m-%dT%H:%M:%SZ")
    entry = {"ts": ts, "action": action, **details}
    with AUDIT_LOG.open("a") as f:
        f.write(json.dumps(entry) + "\n")


def warn(msg: str) -> None:
    print(f"{_YELLOW}[dalston-aws]{_NC} {msg}")


def err(msg: str) -> None:
    print(f"{_RED}[dalston-aws]{_NC} {msg}", file=sys.stderr)


def die(msg: str) -> NoReturn:
    err(msg)
    sys.exit(1)


# ---------------------------------------------------------------------------
# Deployment template
# ---------------------------------------------------------------------------


@dataclass
class ControlPlaneConfig:
    instance_type: str = CPU_INSTANCE_TYPE
    spot: bool = False
    compose_profiles: list[str] | None = None
    data_volume_gb: int = DATA_VOLUME_SIZE


@dataclass
class GpuWorkerConfig:
    instance_type: str = GPU_INSTANCE_TYPE
    spot: bool = True


@dataclass
class DeploymentTemplate:
    scenario: str = "split"
    region: str = DEFAULT_REGION
    registry: str = DEFAULT_GHCR_REGISTRY
    control_plane: ControlPlaneConfig | None = None
    gpu_worker: GpuWorkerConfig | None = None


def load_template(path: str | Path) -> DeploymentTemplate:
    """Load a deployment template from a YAML file."""
    p = Path(path)
    if not p.exists():
        # Try as a preset name: "split" -> infra/templates/split.yaml
        preset = TEMPLATES_DIR / f"{path}.yaml"
        if preset.exists():
            p = preset
        else:
            die(f"Template not found: {path}")
    data = yaml.safe_load(p.read_text())
    cp = data.pop("control_plane", None) or {}
    gw = data.pop("gpu_worker", None)
    tmpl = DeploymentTemplate(**data)
    tmpl.control_plane = ControlPlaneConfig(**cp)
    tmpl.gpu_worker = GpuWorkerConfig(**gw) if gw else None
    return tmpl


# ---------------------------------------------------------------------------
# State dataclass
# ---------------------------------------------------------------------------


@dataclass
class GpuWorker:
    """State for a single GPU worker instance."""

    name: str = ""  # e.g., "onnx", "pyannote"
    instance_id: str = ""
    instance_type: str = ""
    spot: bool = True
    engines: list[str] | None = None  # e.g., ["onnx"] or ["pyannote"]


@dataclass
class DeploymentState:
    region: str = DEFAULT_REGION
    scenario: str = "gpu"
    template: str = ""
    s3_bucket: str = ""
    iam_role: str = ""
    instance_profile: str = ""
    sg_id: str = ""
    instance_id: str = ""
    data_volume_id: str = ""
    gpu_sg_id: str = ""
    key_name: str = ""
    observability: bool = False
    gpu_workers: list[dict] | None = None  # list of GpuWorker dicts


def save_state(state: DeploymentState) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    STATE_FILE.write_text(
        yaml.dump(asdict(state), default_flow_style=False, sort_keys=False)
    )
    log(f"State saved to {STATE_FILE}")


def load_state() -> DeploymentState | None:
    if not STATE_FILE.exists():
        return None
    data = yaml.safe_load(STATE_FILE.read_text())
    known = set(DeploymentState.__dataclass_fields__)
    return DeploymentState(**{k: v for k, v in data.items() if k in known})


def require_state() -> DeploymentState:
    st = load_state()
    if st is None:
        die("No deployment found. Run 'dalston-aws setup' first.")
    return st


# ---------------------------------------------------------------------------
# boto3 client helpers
# ---------------------------------------------------------------------------


_clients: dict[str, Any] = {}


def ec2_client(region: str):
    key = f"ec2:{region}"
    if key not in _clients:
        _clients[key] = boto3.client("ec2", region_name=region)
    return _clients[key]


def iam_client():
    if "iam" not in _clients:
        _clients["iam"] = boto3.client("iam")
    return _clients["iam"]


def s3_client(region: str):
    key = f"s3:{region}"
    if key not in _clients:
        _clients[key] = boto3.client("s3", region_name=region)
    return _clients[key]


def sts_client(region: str):
    key = f"sts:{region}"
    if key not in _clients:
        _clients[key] = boto3.client("sts", region_name=region)
    return _clients[key]


# ---------------------------------------------------------------------------
# AWS helpers
# ---------------------------------------------------------------------------

_account_id_cache: str | None = None


def aws_account_id(region: str) -> str:
    global _account_id_cache
    if _account_id_cache is None:
        _account_id_cache = sts_client(region).get_caller_identity()["Account"]
    return _account_id_cache


def describe_instance(region: str, instance_id: str) -> dict | None:
    """Single describe_instances call — returns the instance dict or None."""
    try:
        resp = ec2_client(region).describe_instances(InstanceIds=[instance_id])
        return resp["Reservations"][0]["Instances"][0]
    except (ClientError, IndexError, KeyError):
        return None


def get_instance_state(region: str, instance_id: str) -> str:
    inst = describe_instance(region, instance_id)
    return inst["State"]["Name"] if inst else "terminated"


def get_instance_ip(region: str, instance_id: str) -> str:
    inst = describe_instance(region, instance_id)
    return (inst.get("PublicIpAddress", "") or "") if inst else ""


def get_instance_private_ip(region: str, instance_id: str) -> str:
    inst = describe_instance(region, instance_id)
    return (inst.get("PrivateIpAddress", "") or "") if inst else ""


def get_instance_vpc(region: str, instance_id: str) -> str:
    inst = describe_instance(region, instance_id)
    if not inst:
        die(f"Instance {instance_id} not found")
    return inst["VpcId"]


def get_instance_type(region: str, instance_id: str) -> str:
    inst = describe_instance(region, instance_id)
    return inst.get("InstanceType", "") if inst else ""


def wait_instance_running(region: str, instance_id: str) -> None:
    log(f"Waiting for {instance_id} to be running...")
    waiter = ec2_client(region).get_waiter("instance_running")
    waiter.wait(InstanceIds=[instance_id])


def wait_instance_terminated(region: str, instance_id: str) -> None:
    if get_instance_state(region, instance_id) == "terminated":
        return
    try:
        waiter = ec2_client(region).get_waiter("instance_terminated")
        waiter.wait(InstanceIds=[instance_id])
    except WaiterError:
        pass


def get_default_vpc(region: str) -> str:
    resp = ec2_client(region).describe_vpcs(
        Filters=[{"Name": "is-default", "Values": ["true"]}]
    )
    vpcs = resp.get("Vpcs", [])
    if not vpcs:
        die("No default VPC found in region " + region)
    return vpcs[0]["VpcId"]


def retry_aws(func, *args, max_retries: int = 4, **kwargs):
    delay = 2
    for attempt in range(1, max_retries + 1):
        try:
            return func(*args, **kwargs)
        except ClientError as e:
            if attempt >= max_retries:
                raise
            warn(f"Attempt {attempt} failed ({e}), retrying in {delay}s...")
            time.sleep(delay)
            delay *= 2


# ---------------------------------------------------------------------------
# S3 bucket
# ---------------------------------------------------------------------------


def create_s3_bucket(region: str) -> str:
    account_id = aws_account_id(region)
    bucket = f"{NAME_PREFIX}-artifacts-{account_id}"
    s3 = s3_client(region)

    try:
        s3.head_bucket(Bucket=bucket)
        log(f"S3 bucket {bucket} already exists")
        return bucket
    except ClientError:
        pass

    log(f"Creating S3 bucket: {bucket}")
    create_kwargs: dict = {"Bucket": bucket}
    if region != "us-east-1":
        create_kwargs["CreateBucketConfiguration"] = {"LocationConstraint": region}
    s3.create_bucket(**create_kwargs)

    # Block public access
    s3.put_public_access_block(
        Bucket=bucket,
        PublicAccessBlockConfiguration={
            "BlockPublicAcls": True,
            "IgnorePublicAcls": True,
            "BlockPublicPolicy": True,
            "RestrictPublicBuckets": True,
        },
    )

    # Enable encryption
    s3.put_bucket_encryption(
        Bucket=bucket,
        ServerSideEncryptionConfiguration={
            "Rules": [
                {"ApplyServerSideEncryptionByDefault": {"SSEAlgorithm": "AES256"}}
            ]
        },
    )

    # Lifecycle rules
    s3.put_bucket_lifecycle_configuration(
        Bucket=bucket,
        LifecycleConfiguration={
            "Rules": [
                {
                    "ID": "cleanup-temp",
                    "Status": "Enabled",
                    "Filter": {"Prefix": "temp/"},
                    "Expiration": {"Days": 7},
                },
                {
                    "ID": "cleanup-jobs",
                    "Status": "Enabled",
                    "Filter": {"Prefix": "jobs/"},
                    "Expiration": {"Days": 30},
                },
            ]
        },
    )

    log("S3 bucket created with encryption + lifecycle rules")
    return bucket


# ---------------------------------------------------------------------------
# IAM role + instance profile
# ---------------------------------------------------------------------------


def create_iam_role(region: str, s3_bucket: str) -> tuple[str, str]:
    iam = iam_client()
    role_name = f"{NAME_PREFIX}-ec2-role"
    profile_name = f"{NAME_PREFIX}-instance-profile"
    account_id = aws_account_id(region)

    # Create role if needed
    try:
        iam.get_role(RoleName=role_name)
        log(f"IAM role {role_name} already exists")
    except ClientError:
        log(f"Creating IAM role: {role_name}")
        iam.create_role(
            RoleName=role_name,
            AssumeRolePolicyDocument=json.dumps(
                {
                    "Version": "2012-10-17",
                    "Statement": [
                        {
                            "Effect": "Allow",
                            "Principal": {"Service": "ec2.amazonaws.com"},
                            "Action": "sts:AssumeRole",
                        }
                    ],
                }
            ),
            Tags=[{"Key": "Project", "Value": "dalston"}],
        )

    # S3 access policy (idempotent upsert)
    bucket_arn = f"arn:aws:s3:::{s3_bucket}"
    iam.put_role_policy(
        RoleName=role_name,
        PolicyName=f"{NAME_PREFIX}-s3-access",
        PolicyDocument=json.dumps(
            {
                "Version": "2012-10-17",
                "Statement": [
                    {
                        "Effect": "Allow",
                        "Action": ["s3:ListBucket"],
                        "Resource": bucket_arn,
                    },
                    {
                        "Effect": "Allow",
                        "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
                        "Resource": f"{bucket_arn}/*",
                    },
                ],
            }
        ),
    )

    # SSM read access (for Tailscale auth key)
    iam.put_role_policy(
        RoleName=role_name,
        PolicyName=f"{NAME_PREFIX}-ssm-access",
        PolicyDocument=json.dumps(
            {
                "Version": "2012-10-17",
                "Statement": [
                    {
                        "Effect": "Allow",
                        "Action": ["ssm:GetParameter"],
                        "Resource": f"arn:aws:ssm:{region}:{account_id}:parameter/dalston/*",
                    }
                ],
            }
        ),
    )

    # Instance profile
    try:
        iam.get_instance_profile(InstanceProfileName=profile_name)
        log(f"Instance profile {profile_name} already exists")
    except ClientError:
        log(f"Creating instance profile: {profile_name}")
        iam.create_instance_profile(
            InstanceProfileName=profile_name,
            Tags=[{"Key": "Project", "Value": "dalston"}],
        )
        iam.add_role_to_instance_profile(
            InstanceProfileName=profile_name,
            RoleName=role_name,
        )
        log("Waiting for IAM instance profile to propagate...")
        time.sleep(10)

    log("IAM role + instance profile ready")
    return role_name, profile_name


# ---------------------------------------------------------------------------
# Security groups
# ---------------------------------------------------------------------------


def _find_sg(region: str, name: str, vpc_id: str) -> str | None:
    resp = ec2_client(region).describe_security_groups(
        Filters=[
            {"Name": "group-name", "Values": [name]},
            {"Name": "vpc-id", "Values": [vpc_id]},
        ]
    )
    groups = resp.get("SecurityGroups", [])
    if groups:
        return groups[0]["GroupId"]
    return None


def _create_sg(region: str, vpc_id: str, name: str, description: str) -> str:
    existing = _find_sg(region, name, vpc_id)
    if existing:
        log(f"Security group {existing} already exists")
        return existing

    log(f"Creating security group: {name}")
    ec2 = ec2_client(region)
    resp = ec2.create_security_group(
        GroupName=name,
        Description=description,
        VpcId=vpc_id,
    )
    sg_id = resp["GroupId"]

    ec2.authorize_security_group_ingress(
        GroupId=sg_id,
        IpPermissions=[
            {
                "IpProtocol": "tcp",
                "FromPort": 22,
                "ToPort": 22,
                "IpRanges": [{"CidrIp": "100.64.0.0/10"}],
            },
            # Grafana dashboard (observability)
            {
                "IpProtocol": "tcp",
                "FromPort": 3001,
                "ToPort": 3001,
                "IpRanges": [{"CidrIp": "100.64.0.0/10"}],
            },
            # Jaeger UI (observability)
            {
                "IpProtocol": "tcp",
                "FromPort": 16686,
                "ToPort": 16686,
                "IpRanges": [{"CidrIp": "100.64.0.0/10"}],
            },
        ],
    )

    ec2.create_tags(
        Resources=[sg_id],
        Tags=[
            {"Key": "Name", "Value": name},
            {"Key": "Project", "Value": "dalston"},
        ],
    )

    log(f"Security group {sg_id} created")
    return sg_id


def create_security_group(region: str, vpc_id: str) -> str:
    return _create_sg(
        region, vpc_id, f"{NAME_PREFIX}-sg", "Dalston EC2 - SSH from Tailscale"
    )


def create_gpu_worker_security_group(region: str, vpc_id: str) -> str:
    return _create_sg(
        region,
        vpc_id,
        f"{NAME_PREFIX}-gpu-sg",
        "Dalston GPU worker - SSH from Tailscale",
    )


def _open_sg_ports(
    region: str,
    target_sg: str,
    source_sg: str,
    ports: list[tuple[int, int]],
) -> None:
    """Allow TCP traffic on *ports* from *source_sg* into *target_sg*.

    Each entry in *ports* is (from_port, to_port). Duplicate rules are ignored.
    """
    ec2 = ec2_client(region)
    perms = [
        {
            "IpProtocol": "tcp",
            "FromPort": lo,
            "ToPort": hi,
            "UserIdGroupPairs": [{"GroupId": source_sg}],
        }
        for lo, hi in ports
    ]
    try:
        ec2.authorize_security_group_ingress(GroupId=target_sg, IpPermissions=perms)
    except ClientError:
        # Batch call fails if *any* rule exists; fall back to per-rule
        for perm in perms:
            try:
                ec2.authorize_security_group_ingress(
                    GroupId=target_sg, IpPermissions=[perm]
                )
            except ClientError:
                pass  # rule already exists


def open_control_plane_ports(region: str, ctrl_sg_id: str, gpu_sg_id: str) -> None:
    _open_sg_ports(region, ctrl_sg_id, gpu_sg_id, [(6379, 6379), (5432, 5432)])
    log("Control plane ports 6379,5432 open to GPU worker")


def open_observability_ports(region: str, ctrl_sg_id: str, gpu_sg_id: str) -> None:
    """Open observability ports between control plane and GPU worker."""
    # GPU → control plane: Loki + Jaeger OTLP
    _open_sg_ports(region, ctrl_sg_id, gpu_sg_id, [(3100, 3100), (4317, 4317)])
    # Control plane → GPU: Prometheus scraping
    _open_sg_ports(region, gpu_sg_id, ctrl_sg_id, [(9100, 9101)])
    log(
        "Observability ports open: Loki(3100),Jaeger(4317) on ctrl; metrics(9100-9101) on GPU"
    )


# ---------------------------------------------------------------------------
# Key pair
# ---------------------------------------------------------------------------


def ensure_key_pair(region: str, key_name: str) -> str:
    ec2 = ec2_client(region)
    try:
        ec2.describe_key_pairs(KeyNames=[key_name])
        log(f"Key pair {key_name} already exists in AWS")
        return key_name
    except ClientError:
        pass

    log(f"Creating key pair: {key_name}")
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    resp = ec2.create_key_pair(KeyName=key_name)
    key_file = STATE_DIR / f"{key_name}.pem"
    key_file.write_text(resp["KeyMaterial"])
    key_file.chmod(0o600)
    log(f"Private key saved to {key_file}")
    return key_name


# ---------------------------------------------------------------------------
# Tailscale cloud-init block (shared by CPU and GPU)
# ---------------------------------------------------------------------------


def _loki_driver_cloud_init_block() -> str:
    """Return shell snippet that installs the Loki Docker log driver plugin."""
    return f"""\
# Install Loki Docker log driver if observability is enabled
if [ "$OBSERVABILITY" = "true" ]; then
  echo "Installing Loki Docker log driver..."
  docker plugin install grafana/loki-docker-driver:{LOKI_DRIVER_VERSION} --alias loki --grant-all-permissions || true
fi
"""


def _tailscale_cloud_init_block(hostname: str) -> str:
    """Return shell snippet that installs a Tailscale auto-join systemd service.

    The join script runs on every boot: skips if already connected, otherwise
    cleans up stale nodes and re-joins via auth key from SSM.
    """
    return f"""\
# Wait for unattended-upgrades / apt to release the dpkg lock
dpkg_wait=0
while fuser /var/lib/dpkg/lock-frontend >/dev/null 2>&1; do
  dpkg_wait=$((dpkg_wait + 1))
  if [ $dpkg_wait -gt 36 ]; then
    echo "WARNING: dpkg lock not released after 3 minutes, proceeding anyway"
    break
  fi
  echo "Waiting for dpkg lock ($dpkg_wait/36)..."
  sleep 5
done

# Install and auto-join Tailscale
curl -fsSL https://tailscale.com/install.sh | sh

# Create Tailscale join script that runs on every boot
cat > /usr/local/bin/dalston-tailscale-join.sh << 'TSEOF'
#!/bin/bash
set -euo pipefail

# Skip if Tailscale is already connected (normal reboot)
if tailscale status --json 2>/dev/null | python3 -c "import sys,json; sys.exit(0 if json.load(sys.stdin).get('BackendState')=='Running' else 1)" 2>/dev/null; then
  echo "Tailscale already connected, skipping re-join"
  exit 0
fi

# Region via IMDS v2 (works on both Amazon Linux and Ubuntu)
IMDS_TOKEN=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" -H "X-aws-ec2-metadata-token-ttl-seconds: 60")
REGION=$(curl -s -H "X-aws-ec2-metadata-token: $IMDS_TOKEN" http://169.254.169.254/latest/meta-data/placement/region)
TS_HOSTNAME="{hostname}"

# Remove stale Tailscale node with same hostname to avoid -1 suffix
TS_API_KEY=$(aws ssm get-parameter \\
  --name "/dalston/tailscale-api-key" \\
  --with-decryption \\
  --query "Parameter.Value" \\
  --output text --region "$REGION" 2>/dev/null) || true
if [ -n "$TS_API_KEY" ]; then
  curl -s -H "Authorization: Bearer $TS_API_KEY" \\
    "https://api.tailscale.com/api/v2/tailnet/-/devices" | \\
    python3 -c "
import sys, json
for d in json.load(sys.stdin).get('devices', []):
    if d.get('hostname') == '$TS_HOSTNAME' and not d.get('online', False):
        print(d['nodeId'])
" | while read -r node_id; do
    curl -s -X DELETE -H "Authorization: Bearer $TS_API_KEY" \\
      "https://api.tailscale.com/api/v2/device/$node_id"
    echo "Removed stale Tailscale node: $node_id ($TS_HOSTNAME)"
  done
fi

TS_AUTH_KEY=$(aws ssm get-parameter \\
  --name "/dalston/tailscale-auth-key" \\
  --with-decryption \\
  --query "Parameter.Value" \\
  --output text --region "$REGION") || true
if [ -n "$TS_AUTH_KEY" ]; then
  tailscale up --authkey="$TS_AUTH_KEY" --hostname="$TS_HOSTNAME"
  echo "Tailscale joined as $TS_HOSTNAME"
else
  echo "WARNING: No Tailscale auth key in SSM. Run 'sudo tailscale up' manually."
fi
TSEOF
chmod +x /usr/local/bin/dalston-tailscale-join.sh

# Install systemd service to re-join Tailscale on every boot
cat > /etc/systemd/system/dalston-tailscale.service << 'SVCEOF'
[Unit]
Description=Dalston Tailscale auto-join
After=network-online.target tailscaled.service
Wants=network-online.target tailscaled.service

[Service]
Type=oneshot
ExecStart=/usr/local/bin/dalston-tailscale-join.sh
RemainAfterExit=true

[Install]
WantedBy=multi-user.target
SVCEOF
systemctl daemon-reload
systemctl enable dalston-tailscale.service

# Run it now for first boot
/usr/local/bin/dalston-tailscale-join.sh
"""


# ---------------------------------------------------------------------------
# User-data generation
# ---------------------------------------------------------------------------


def generate_user_data(
    s3_bucket: str,
    region: str,
    compose_profiles: str,
    use_ghcr: bool = False,
    registry: str | None = None,
    observability: bool = False,
) -> str:
    ghcr_registry = registry or os.environ.get("GHCR_REGISTRY", DEFAULT_GHCR_REGISTRY)
    hf_token = os.environ.get("HF_TOKEN", "")

    # Build compose files and services list (controlled here, used as bash vars)
    ctrl_services = "postgres redis gateway orchestrator stt-prepare"
    if use_ghcr:
        compose_files = "-f docker-compose.yml -f infra/docker/docker-compose.aws.yml -f infra/docker/docker-compose.ghcr.yml"
        compose_up_flags = "--no-build"
    else:
        compose_files = "-f docker-compose.yml -f infra/docker/docker-compose.aws.yml"
        compose_up_flags = ""

    if observability:
        compose_files += " -f infra/docker/docker-compose.observability.aws.yml"
        compose_profiles += " --profile observability"
        ctrl_services += " jaeger prometheus grafana loki metrics-exporter"

    otel_enabled = "true" if observability else "false"

    # Part 1: static header
    header = """\
#!/bin/bash
set -euo pipefail
exec > >(tee /var/log/user-data.log) 2>&1
echo "Starting Dalston bootstrap at $(date)"
"""

    # Part 2: variables (f-string interpolation)
    variables = f"""\
DATA_DEVICE="/dev/xvdf"
DATA_MOUNT="/data"
S3_BUCKET="{s3_bucket}"
AWS_REGION="{region}"
COMPOSE_PROFILE_FLAGS="{compose_profiles}"
USE_GHCR="{"true" if use_ghcr else "false"}"
GHCR_REGISTRY="{ghcr_registry}"
REPO_URL="{REPO_URL}"
HF_TOKEN="{hf_token}"
REPO_BRANCH="{REPO_BRANCH}"
OBSERVABILITY="{"true" if observability else "false"}"
OTEL_ENABLED="{otel_enabled}"
CTRL_SERVICES="{ctrl_services}"
COMPOSE_FILES="{compose_files}"
COMPOSE_UP_FLAGS="{compose_up_flags}"
"""

    tailscale_block = _tailscale_cloud_init_block("dalston-control-plane")
    loki_driver_block = _loki_driver_cloud_init_block()

    # Part 3: body (raw string — no f-string to avoid bash {brace} conflicts)
    body = (
        r"""
# Install Docker
echo "Installing Docker..."
dnf update -y
dnf install -y docker git pciutils

"""
        + tailscale_block
        + r"""
# Start Docker
systemctl start docker
systemctl enable docker
usermod -aG docker ec2-user

# Install Docker Compose plugin
echo "Installing Docker Compose..."
mkdir -p /usr/local/lib/docker/cli-plugins
DOCKER_COMPOSE_VERSION="v2.34.0"
curl -L "https://github.com/docker/compose/releases/download/${DOCKER_COMPOSE_VERSION}/docker-compose-linux-x86_64" \
  -o /usr/local/lib/docker/cli-plugins/docker-compose
chmod +x /usr/local/lib/docker/cli-plugins/docker-compose

# GPU detection and NVIDIA runtime setup
if lspci | grep -qi nvidia; then
  echo "NVIDIA GPU detected. Installing NVIDIA Container Toolkit..."
  curl -fsSL https://nvidia.github.io/libnvidia-container/stable/rpm/nvidia-container-toolkit.repo \
    -o /etc/yum.repos.d/nvidia-container-toolkit.repo
  dnf install -y nvidia-container-toolkit || true
  if command -v nvidia-ctk >/dev/null 2>&1; then
    nvidia-ctk runtime configure --runtime=docker
    systemctl restart docker
    echo "NVIDIA runtime configured."
  else
    echo "WARNING: NVIDIA toolkit installation incomplete."
  fi
fi

# Wait for data volume
echo "Waiting for data volume..."
while [ ! -e "$DATA_DEVICE" ]; do
  sleep 5
done

# Format if needed
if ! blkid "$DATA_DEVICE" | grep -q ext4; then
  echo "Formatting data volume..."
  mkfs.ext4 -L dalston-data "$DATA_DEVICE"
fi

# Mount
mkdir -p "$DATA_MOUNT"
mount "$DATA_DEVICE" "$DATA_MOUNT"
if ! grep -q "$DATA_MOUNT" /etc/fstab; then
  echo "LABEL=dalston-data $DATA_MOUNT ext4 defaults,nofail 0 2" >> /etc/fstab
fi

# Create data directories
mkdir -p "$DATA_MOUNT/postgres" "$DATA_MOUNT/redis" "$DATA_MOUNT/models" "$DATA_MOUNT/dalston"
chown -R 1000:1000 "$DATA_MOUNT"
if [ "$OBSERVABILITY" = "true" ]; then
  mkdir -p "$DATA_MOUNT/prometheus" "$DATA_MOUNT/loki" "$DATA_MOUNT/grafana"
  chown -R 65534:65534 "$DATA_MOUNT/prometheus"  # prometheus runs as nobody
  chown -R 10001:10001 "$DATA_MOUNT/loki"         # loki runs as uid 10001
  chown -R 472:472 "$DATA_MOUNT/grafana"           # grafana runs as uid 472
fi

# Clone repo (shallow — only need compose files, code runs from GHCR images)
if [ -n "$REPO_URL" ] && [ ! -f "$DATA_MOUNT/dalston/docker-compose.yml" ]; then
  echo "Cloning $REPO_URL ($REPO_BRANCH)..."
  git clone --depth 1 --branch "$REPO_BRANCH" "$REPO_URL" "$DATA_MOUNT/dalston"
fi

"""
        + loki_driver_block
        + r"""
# Create .env.aws (includes compose vars for systemd)
cat > "$DATA_MOUNT/dalston/.env.aws" << ENVEOF
DALSTON_S3_BUCKET=${S3_BUCKET}
DALSTON_S3_REGION=${AWS_REGION}
AWS_REGION=${AWS_REGION}
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql+asyncpg://dalston:password@postgres:5432/dalston
HF_HOME=/data/models
GHCR_REGISTRY=${GHCR_REGISTRY}
IMAGE_TAG=latest
USE_GHCR=${USE_GHCR}
COMPOSE_FILES=${COMPOSE_FILES}
COMPOSE_UP_FLAGS=${COMPOSE_UP_FLAGS}
CTRL_SERVICES=${CTRL_SERVICES}
OTEL_ENABLED=${OTEL_ENABLED}
ENVEOF

# Create .env with secrets (only if it doesn't already exist — preserves manual edits)
if [ ! -f "$DATA_MOUNT/dalston/.env" ]; then
  cat > "$DATA_MOUNT/dalston/.env" << DOTENVEOF
HF_TOKEN=${HF_TOKEN}
POSTGRES_PASSWORD=password
DOTENVEOF
fi

# Create deploy script for easy redeploys
cat > "$DATA_MOUNT/dalston/deploy.sh" << 'DEPLOYEOF'
#!/bin/bash
set -euo pipefail
cd /data/dalston

# Read .env.aws safely (values may contain spaces/flags)
while IFS='=' read -r key value; do
  [[ -z "$key" || "$key" =~ ^# ]] && continue
  export "$key=$value"
done < .env.aws

git pull --ff-only

if [ "$USE_GHCR" = "true" ]; then
  docker compose $COMPOSE_FILES --env-file .env.aws pull $CTRL_SERVICES
fi

docker compose $COMPOSE_FILES --env-file .env.aws up -d $COMPOSE_UP_FLAGS $CTRL_SERVICES
echo "Deploy complete at $(date)"
DEPLOYEOF
chmod +x "$DATA_MOUNT/dalston/deploy.sh"

# Create systemd service
cat > /etc/systemd/system/dalston.service << SVCEOF
[Unit]
Description=Dalston Transcription Server
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/data/dalston
EnvironmentFile=/data/dalston/.env.aws
ExecStart=/bin/bash -c 'cd /data/dalston && docker compose ${COMPOSE_FILES} --env-file .env.aws up -d ${COMPOSE_UP_FLAGS} ${CTRL_SERVICES}'
ExecStop=/bin/bash -c 'cd /data/dalston && docker compose ${COMPOSE_FILES} --env-file .env.aws down'
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
SVCEOF

systemctl daemon-reload
systemctl enable --now dalston.service

echo ""
echo "=========================================="
echo "Dalston bootstrap completed at $(date)"
echo "=========================================="
echo ""
echo "Next steps:"
echo "1. sudo tailscale up"
echo "2. tailscale ip -4"
echo "3. sudo systemctl start dalston"
echo ""
echo "To redeploy: sudo /data/dalston/deploy.sh"
"""
    )

    return header + variables + body


def _generate_docker_run_block(engine_name: str, port: int) -> str:
    """Generate a docker run command for a GPU engine preset."""
    preset = GPU_ENGINE_PRESETS[engine_name]
    container = preset["container"]
    engine_id = preset["engine_id"]
    image = preset["image"]
    needs_hf = preset.get("needs_hf_token", False)
    extra_env = preset.get("extra_env", {})

    extra_lines = ""
    if needs_hf:
        extra_lines += '  -e HF_TOKEN="$HF_TOKEN" \\\n'
    for k, v in extra_env.items():
        extra_lines += f'  -e {k}="{v}" \\\n'

    return f"""\
docker run -d --name {container} --gpus all --network host --restart unless-stopped \\
  --shm-size=8g \\
  -v /data/models:/data/models \\
  -e DALSTON_METRICS_PORT={port} \\
  -e DALSTON_DEVICE=cuda \\
  -e DALSTON_VRAM_SHARE=1.0 \\
  -e DALSTON_ENGINE_ID={engine_id} \\
  -e DALSTON_DEPLOY_ENV=aws \\
  -e DALSTON_HOST_HOSTNAME="$HOST_HOSTNAME" \\
  -e REDIS_URL="redis://${{CTRL_PLANE_HOST}}:6379" \\
  -e DALSTON_S3_BUCKET="$S3_BUCKET" \\
  -e DALSTON_S3_REGION="$AWS_REGION" \\
  -e AWS_REGION="$AWS_REGION" \\
  -e HF_HOME=/data/models \\
{extra_lines}  $OTEL_FLAGS $LOG_FLAGS \\
  "$GHCR_REGISTRY/{image}:latest"
"""


def generate_gpu_worker_user_data(
    s3_bucket: str,
    region: str,
    worker_name: str,
    engines: list[str],
    registry: str | None = None,
    observability: bool = False,
) -> str:
    ghcr_registry = registry or os.environ.get("GHCR_REGISTRY", DEFAULT_GHCR_REGISTRY)
    hf_token = os.environ.get("HF_TOKEN", "")
    ts_hostname = f"dalston-gpu-{worker_name}"

    # Validate engines
    for eng in engines:
        if eng not in GPU_ENGINE_PRESETS:
            raise ValueError(
                f"Unknown engine '{eng}'. Available: {list(GPU_ENGINE_PRESETS)}"
            )
        if GPU_ENGINE_PRESETS[eng].get("needs_hf_token") and not hf_token:
            die(
                f"Engine '{eng}' requires HF_TOKEN for gated model access. "
                f"Set it with: export HF_TOKEN=hf_..."
            )

    # Build pull commands and docker run blocks
    presets = [GPU_ENGINE_PRESETS[e] for e in engines]
    pull_lines = "\n".join(
        f'docker pull "$GHCR_REGISTRY/{p["image"]}:latest"' for p in presets
    )
    containers = [p["container"] for p in presets]
    rm_line = "docker rm -f " + " ".join(containers) + " 2>/dev/null || true"

    run_blocks = []
    for i, eng in enumerate(engines):
        run_blocks.append(_generate_docker_run_block(eng, 9100 + i))
    run_section = "\n".join(run_blocks)

    # Part 1: static header
    header = """\
#!/bin/bash
set -euo pipefail
exec > >(tee /var/log/user-data.log) 2>&1
echo "Starting Dalston GPU worker bootstrap at $(date)"
"""

    # Part 2: variables (f-string interpolation)
    variables = f"""\
S3_BUCKET="{s3_bucket}"
AWS_REGION="{region}"
CTRL_PLANE_HOST="dalston-control-plane"
GHCR_REGISTRY="{ghcr_registry}"
HF_TOKEN="{hf_token}"
OBSERVABILITY="{"true" if observability else "false"}"
"""

    # Part 3: body
    body = (
        r"""
# Wait for any unattended-upgrades to finish
while fuser /var/lib/dpkg/lock-frontend >/dev/null 2>&1; do
  echo "Waiting for dpkg lock (unattended-upgrades)..."
  sleep 5
done

# Ensure Docker is running (pre-installed on DL AMI)
systemctl start docker
systemctl enable docker
usermod -aG docker ubuntu

"""
        + _tailscale_cloud_init_block(ts_hostname)
        + r"""
# Configure NVIDIA Container Toolkit for Docker
for attempt in 1 2 3; do
  apt-get update && break
  echo "apt-get update failed (attempt $attempt/3), retrying in 10s..."
  sleep 10
done
apt-get install -y nvidia-container-toolkit || true
if command -v nvidia-ctk >/dev/null 2>&1; then
  nvidia-ctk runtime configure --runtime=docker
  systemctl restart docker
fi

# Mount instance store NVMe for model cache (free 125 GB on g4dn)
# Device names aren't stable — find instance store by model string.
NVME_DEV=""
for dev in /dev/nvme*n1; do
  [ -b "$dev" ] || continue
  MODEL=$(lsblk -n -o MODEL "$dev" 2>/dev/null | head -1)
  if echo "$MODEL" | grep -qi "Instance Storage"; then
    NVME_DEV="$dev"
    break
  fi
done

if [ -n "$NVME_DEV" ]; then
  # Check if already mounted (DL AMI uses LVM on instance store)
  EXISTING_MOUNT=$(lsblk -n -o MOUNTPOINT "$NVME_DEV" 2>/dev/null | grep -v '^$' | head -1 || true)
  if [ -n "$EXISTING_MOUNT" ]; then
    echo "Instance store $NVME_DEV already mounted at $EXISTING_MOUNT, symlinking to /data/models"
    mkdir -p /data/models
    rm -rf /data/models
    ln -s "$EXISTING_MOUNT" /data/models
  else
    echo "Mounting instance store $NVME_DEV at /data/models..."
    mkfs.xfs "$NVME_DEV"
    mkdir -p /data/models
    mount "$NVME_DEV" /data/models
  fi
else
  echo "No instance store NVMe found, using root volume for models"
  mkdir -p /data/models
fi
chown -R 1000:1000 /data/models

"""
        + _loki_driver_cloud_init_block()
        + f"""
# Pull images (no login needed — public repo)
{pull_lines}

mkdir -p /opt/dalston

# Save env for the start script (must exist before gpu-start.sh runs)
cat > /opt/dalston/gpu-env.sh << ENVEOF
S3_BUCKET="${{S3_BUCKET}}"
AWS_REGION="${{AWS_REGION}}"
CTRL_PLANE_HOST="${{CTRL_PLANE_HOST}}"
GHCR_REGISTRY="${{GHCR_REGISTRY}}"
HF_TOKEN="${{HF_TOKEN}}"
OBSERVABILITY="${{OBSERVABILITY}}"
ENVEOF

# GPU worker start script
cat > /opt/dalston/gpu-start.sh << 'STARTEOF'
#!/bin/bash
set -euo pipefail
source /opt/dalston/gpu-env.sh

# Pull images
{pull_lines}

# Stop existing containers if running
{rm_line}

HOST_HOSTNAME=$(hostname)

# Build observability flags for docker run
OTEL_FLAGS=""
LOG_FLAGS=""
if [ "$OBSERVABILITY" = "true" ]; then
  OTEL_FLAGS="-e OTEL_ENABLED=true -e OTEL_EXPORTER_OTLP_ENDPOINT=http://${{CTRL_PLANE_HOST}}:4317 -e DALSTON_METRICS_ENABLED=true -e DALSTON_METRICS_PORT=9100"
  LOG_FLAGS="--log-driver=loki --log-opt loki-url=http://${{CTRL_PLANE_HOST}}:3100/loki/api/v1/push --log-opt loki-retries=3 --log-opt max-size=20m --log-opt max-file=2"
fi

{run_section}
echo "GPU engines started at $(date)"
STARTEOF
chmod +x /opt/dalston/gpu-start.sh

# GPU worker systemd service
cat > /etc/systemd/system/dalston-gpu.service << SVCEOF
[Unit]
Description=Dalston GPU Worker ({worker_name})
Requires=docker.service dalston-tailscale.service
After=docker.service dalston-tailscale.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/opt/dalston/gpu-start.sh
ExecStop=/usr/bin/docker rm -f {" ".join(containers)}
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
SVCEOF

systemctl daemon-reload
systemctl enable --now dalston-gpu.service

echo ""
echo "=========================================="
echo "GPU worker bootstrap completed at $(date)"
echo "=========================================="
echo ""
echo "Next steps:"
echo "1. sudo tailscale up"
echo "2. sudo systemctl start dalston-gpu"
"""
    )

    return header + variables + body


# ---------------------------------------------------------------------------
# AMI lookup
# ---------------------------------------------------------------------------


def get_latest_ami(region: str) -> str:
    resp = ec2_client(region).describe_images(
        Owners=["amazon"],
        Filters=[
            {"Name": "name", "Values": ["al2023-ami-*-x86_64"]},
            {"Name": "virtualization-type", "Values": ["hvm"]},
        ],
    )
    images = sorted(resp["Images"], key=lambda i: i["CreationDate"])
    if not images:
        die("No AL2023 AMI found")
    return images[-1]["ImageId"]


def get_gpu_ami(region: str) -> str:
    """Get the Deep Learning Base AMI with NVIDIA drivers pre-installed."""
    ssm = boto3.client("ssm", region_name=region)
    resp = ssm.get_parameter(
        Name="/aws/service/deeplearning/ami/x86_64/base-oss-nvidia-driver-gpu-ubuntu-22.04/latest/ami-id"
    )
    return resp["Parameter"]["Value"]


# ---------------------------------------------------------------------------
# Instance launch
# ---------------------------------------------------------------------------


def launch_instance(
    region: str,
    instance_type: str,
    sg_id: str,
    user_data: str,
    name_tag: str,
    use_spot: bool,
    key_name: str,
    instance_profile: str,
    ami_id: str | None = None,
) -> str:
    """Launch an EC2 instance, trying each AZ in the default VPC.

    Returns the instance ID on success or raises on failure.
    """
    ec2 = ec2_client(region)
    if ami_id is None:
        ami_id = get_latest_ami(region)
    vpc_id = get_default_vpc(region)

    resp = ec2.describe_subnets(Filters=[{"Name": "vpc-id", "Values": [vpc_id]}])
    subnet_list = [
        (s["SubnetId"], s["AvailabilityZone"]) for s in resp.get("Subnets", [])
    ]
    if not subnet_list:
        die(f"No subnets found in VPC {vpc_id}")

    # Sort AZs by current spot price (cheapest first)
    if use_spot:
        try:
            prices_resp = ec2.describe_spot_price_history(
                InstanceTypes=[instance_type],
                ProductDescriptions=["Linux/UNIX"],
                MaxResults=len(subnet_list),
            )
            az_prices = {
                p["AvailabilityZone"]: float(p["SpotPrice"])
                for p in prices_resp.get("SpotPriceHistory", [])
            }
            subnet_list.sort(key=lambda s: az_prices.get(s[1], 999))
            cheapest_az = subnet_list[0][1]
            cheapest_price = az_prices.get(cheapest_az, 0)
            log(f"Cheapest AZ: {cheapest_az} (${cheapest_price:.4f}/hr)")
        except Exception:
            pass  # Fall back to arbitrary order

    encoded_user_data = base64.b64encode(user_data.encode()).decode()

    for subnet_id, az in subnet_list:
        run_kwargs: dict = {
            "ImageId": ami_id,
            "InstanceType": instance_type,
            "KeyName": key_name,
            "SecurityGroupIds": [sg_id],
            "SubnetId": subnet_id,
            "IamInstanceProfile": {"Name": instance_profile},
            "UserData": encoded_user_data,
            "MinCount": 1,
            "MaxCount": 1,
            "BlockDeviceMappings": [
                {
                    "DeviceName": "/dev/xvda",
                    "Ebs": {
                        "VolumeSize": ROOT_VOLUME_SIZE,
                        "VolumeType": "gp3",
                        "Encrypted": True,
                        "DeleteOnTermination": True,
                    },
                }
            ],
            "TagSpecifications": [
                {
                    "ResourceType": "instance",
                    "Tags": [
                        {"Key": "Name", "Value": name_tag},
                        {"Key": "Project", "Value": "dalston"},
                    ],
                }
            ],
        }

        if use_spot:
            run_kwargs["InstanceMarketOptions"] = {
                "MarketType": "spot",
                "SpotOptions": {
                    "SpotInstanceType": "one-time",
                    "InstanceInterruptionBehavior": "terminate",
                },
            }

        log(f"Trying AZ {az} (subnet {subnet_id})...")
        try:
            result = ec2.run_instances(**run_kwargs)
            iid = result["Instances"][0]["InstanceId"]
            log(f"Launched in {az}: {iid}")
            return iid
        except ClientError as e:
            code = e.response["Error"]["Code"]
            if code in (
                "InsufficientInstanceCapacity",
                "SpotMaxPriceTooLow",
                "Unsupported",
            ):
                warn(f"No capacity in {az}, trying next AZ...")
                continue
            if code == "MaxSpotInstanceCountExceeded":
                die(
                    f"AWS spot instance vCPU limit reached for {instance_type}. "
                    f"Request a quota increase at: "
                    f"https://console.aws.amazon.com/servicequotas/home/services/ec2/quotas "
                    f"(search 'All G and VT Spot Instance Requests'). "
                    f"Or retry with --no-spot for on-demand pricing."
                )
            raise

    raise RuntimeError(f"Failed to launch {instance_type} in any AZ.")


# ---------------------------------------------------------------------------
# GPU compute capability mapping
# ---------------------------------------------------------------------------

# Maps GPU model name (as returned by describe_instance_types) to CUDA compute capability.
GPU_COMPUTE_CAPABILITY: dict[str, float] = {
    "T4": 7.5,
    "A10G": 8.6,
    "L4": 8.9,
    "L40S": 8.9,
    "A100": 8.0,
    "H100": 9.0,
    "H200": 9.0,
}


GPU_FAMILY_TO_NAME: dict[str, str] = {
    "g4dn": "T4",
    "g5": "A10G",
    "g6": "L4",
    "g6e": "L40S",
    "p4d": "A100",
    "p5": "H100",
}


def _gpu_compute_for_instance_type(instance_type: str) -> float:
    """Return the GPU compute capability for a known instance family, or 0.0."""
    family = instance_type.split(".")[0]
    gpu_name = GPU_FAMILY_TO_NAME.get(family, "")
    return GPU_COMPUTE_CAPABILITY.get(gpu_name, 0.0)


def _check_gpu_compat(engines: list[str], gpu_type: str) -> None:
    """Warn and abort if any engine requires a higher compute capability than the GPU provides."""
    gpu_cc = _gpu_compute_for_instance_type(gpu_type)
    if gpu_cc == 0.0:
        return  # unknown instance family, skip check
    for engine_name in engines:
        preset = GPU_ENGINE_PRESETS.get(engine_name, {})
        min_cc = preset.get("min_gpu_compute", 0.0)
        if min_cc and gpu_cc < min_cc:
            gpu_family = gpu_type.split(".")[0]
            gpu_name = GPU_FAMILY_TO_NAME.get(gpu_family, gpu_family)
            die(
                f"Engine '{engine_name}' requires GPU compute >= {min_cc} "
                f"but {gpu_type} has {gpu_name} (compute {gpu_cc}). "
                f"Use g5.xlarge (A10G) or g6.xlarge (L4) instead."
            )


# ---------------------------------------------------------------------------
# List GPU spot instances
# ---------------------------------------------------------------------------


def list_gpu_spot_instances(region: str, engines: list[str] | None = None) -> None:
    log(f"Available GPU spot instances in {region}:")
    print()
    header_fmt = "  {:<20s} {:<8s} {:<10s} {:<18s} {:s}"
    print(header_fmt.format("INSTANCE TYPE", "vCPUs", "RAM (GiB)", "GPUs", "SPOT $/hr"))
    print(header_fmt.format("-------------", "-----", "---------", "----", "---------"))
    # Compute minimum GPU requirement across all requested engines
    min_cc_required = 0.0
    for e in engines or []:
        preset = GPU_ENGINE_PRESETS.get(e, {})
        min_cc_required = max(min_cc_required, preset.get("min_gpu_compute", 0.0))

    ec2 = ec2_client(region)

    gpu_types: list[dict] = []
    # Use filter instead of InstanceTypes list — avoids failure on types
    # that don't exist in the region, and returns all matches in one call.
    try:
        paginator = ec2.get_paginator("describe_instance_types")
        for page in paginator.paginate(
            Filters=[
                {
                    "Name": "instance-type",
                    "Values": [f"{fam}.*" for fam in ("g4dn", "g5", "g6", "g6e")],
                },
                {"Name": "processor-info.supported-architecture", "Values": ["x86_64"]},
            ],
        ):
            gpu_types.extend(page.get("InstanceTypes", []))
    except ClientError:
        pass

    gpu_types.sort(key=lambda t: t["InstanceType"])

    for it in gpu_types:
        itype = it["InstanceType"]
        vcpus = it["VCpuInfo"]["DefaultVCpus"]
        mem_gib = it["MemoryInfo"]["SizeInMiB"] // 1024
        gpu_info = it["GpuInfo"]["Gpus"][0]
        gpu_count = gpu_info["Count"]
        gpu_name = gpu_info["Name"]

        try:
            sp_resp = ec2.describe_spot_price_history(
                InstanceTypes=[itype],
                ProductDescriptions=["Linux/UNIX"],
                MaxResults=1,
            )
            prices = sp_resp.get("SpotPriceHistory", [])
            if not prices:
                continue
            spot_price = prices[0]["SpotPrice"]
        except ClientError:
            continue

        gpu_cc = GPU_COMPUTE_CAPABILITY.get(gpu_name, 0.0)
        compat_warn = ""
        if min_cc_required and gpu_cc and gpu_cc < min_cc_required:
            compat_warn = f"  {_YELLOW}⚠ compute {gpu_cc} < {min_cc_required}{_NC}"
        print(
            header_fmt.format(
                itype,
                str(vcpus),
                str(mem_gib),
                f"{gpu_count}x {gpu_name}",
                f"${spot_price}",
            )
            + compat_warn
        )
    print()


# ---------------------------------------------------------------------------
# Interactive GPU launch with retry
# ---------------------------------------------------------------------------


def _ensure_cross_region_sg(region: str, key_name: str) -> str:
    """Create or reuse a minimal security group for GPU workers in another region.

    Only allows SSH (22) inbound — all engine communication goes via Tailscale.
    """
    ec2 = ec2_client(region)
    sg_name = f"{NAME_PREFIX}-gpu-cross-region"

    # Check if SG already exists
    try:
        result = ec2.describe_security_groups(
            Filters=[{"Name": "group-name", "Values": [sg_name]}]
        )
        if result["SecurityGroups"]:
            sg_id = result["SecurityGroups"][0]["GroupId"]
            log(f"Reusing cross-region SG {sg_id} in {region}")
            return sg_id
    except ClientError:
        pass

    # Get default VPC
    vpcs = ec2.describe_vpcs(Filters=[{"Name": "is-default", "Values": ["true"]}])
    if not vpcs["Vpcs"]:
        die(
            f"No default VPC in {region}. Create one or use the same region as control plane."
        )
    vpc_id = vpcs["Vpcs"][0]["VpcId"]

    sg = ec2.create_security_group(
        GroupName=sg_name,
        Description="Dalston GPU worker (cross-region, Tailscale networking)",
        VpcId=vpc_id,
    )
    sg_id = sg["GroupId"]
    ec2.authorize_security_group_ingress(
        GroupId=sg_id,
        IpPermissions=[
            {
                "IpProtocol": "tcp",
                "FromPort": 22,
                "ToPort": 22,
                "IpRanges": [{"CidrIp": "0.0.0.0/0", "Description": "SSH"}],
            },
        ],
    )
    log(f"Created cross-region SG {sg_id} in {region}")
    return sg_id


def launch_gpu_interactive(
    region: str,
    sg_id: str,
    user_data: str,
    name_tag: str,
    use_spot: bool,
    key_name: str,
    instance_profile: str,
    gpu_type: str,
    engines: list[str] | None = None,
) -> str:
    """Launch GPU worker with interactive retry on capacity failure."""
    gpu_ami = get_gpu_ami(region)
    log(f"Using Deep Learning AMI: {gpu_ami}")
    while True:
        try:
            return launch_instance(
                region,
                gpu_type,
                sg_id,
                user_data,
                name_tag,
                use_spot,
                key_name,
                instance_profile,
                ami_id=gpu_ami,
            )
        except RuntimeError:
            print()
            list_gpu_spot_instances(region, engines=engines)
            try:
                choice = input(
                    "Enter instance type to retry (or 'q' to quit): "
                ).strip()
            except (EOFError, KeyboardInterrupt):
                die("GPU worker launch aborted.")
            if not choice or choice == "q":
                die("GPU worker launch aborted.")
            _check_gpu_compat(engines or [], choice)
            gpu_type = choice


# ---------------------------------------------------------------------------
# EBS data volume
# ---------------------------------------------------------------------------


def create_and_attach_data_volume(
    region: str, instance_id: str, size_gb: int = DATA_VOLUME_SIZE
) -> str:
    ec2 = ec2_client(region)

    resp = ec2.describe_instances(InstanceIds=[instance_id])
    az = resp["Reservations"][0]["Instances"][0]["Placement"]["AvailabilityZone"]

    vol_resp = ec2.create_volume(
        AvailabilityZone=az,
        Size=size_gb,
        VolumeType="gp3",
        Encrypted=True,
        TagSpecifications=[
            {
                "ResourceType": "volume",
                "Tags": [
                    {"Key": "Name", "Value": f"{NAME_PREFIX}-data"},
                    {"Key": "Project", "Value": "dalston"},
                ],
            }
        ],
    )
    vol_id = vol_resp["VolumeId"]

    log(f"Waiting for volume {vol_id} to be available...")
    waiter = ec2.get_waiter("volume_available")
    waiter.wait(VolumeIds=[vol_id])

    ec2.attach_volume(
        VolumeId=vol_id,
        InstanceId=instance_id,
        Device="/dev/xvdf",
    )

    return vol_id


# ---------------------------------------------------------------------------
# Cancel spot requests before termination
# ---------------------------------------------------------------------------


def cancel_spot_requests_for_instances(region: str, instance_ids: list[str]) -> None:
    """Cancel any active spot instance requests for the given instances."""
    ec2 = ec2_client(region)
    try:
        resp = ec2.describe_spot_instance_requests(
            Filters=[{"Name": "instance-id", "Values": instance_ids}]
        )
        sir_ids = [
            r["SpotInstanceRequestId"]
            for r in resp.get("SpotInstanceRequests", [])
            if r.get("State") in ("open", "active")
        ]
        if sir_ids:
            log(f"Cancelling spot requests: {', '.join(sir_ids)}")
            ec2.cancel_spot_instance_requests(SpotInstanceRequestIds=sir_ids)
    except ClientError:
        pass


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------


def cmd_setup(args: argparse.Namespace) -> None:
    tmpl = load_template(args.template)

    # CLI overrides on top of template
    region = args.region or tmpl.region
    tmpl.region = region

    scenario = tmpl.scenario
    key_name = args.key or f"{NAME_PREFIX}-key"

    audit("setup", scenario=scenario, region=region, template=args.template)

    # Check AWS credentials
    try:
        aws_account_id(region)
    except Exception:
        die("AWS credentials not configured. Run 'aws configure' first.")

    # Idempotency check
    existing = load_state()
    if existing:
        log("Existing deployment found. Verifying infrastructure...")
        vpc_id = get_default_vpc(existing.region)
        existing.s3_bucket = create_s3_bucket(existing.region)
        existing.iam_role, existing.instance_profile = create_iam_role(
            existing.region, existing.s3_bucket
        )
        existing.key_name = ensure_key_pair(
            existing.region, existing.key_name or key_name
        )
        existing.sg_id = create_security_group(existing.region, vpc_id)
        if tmpl.gpu_worker and not existing.gpu_sg_id:
            existing.gpu_sg_id = create_gpu_worker_security_group(
                existing.region, vpc_id
            )
            open_control_plane_ports(
                existing.region, existing.sg_id, existing.gpu_sg_id
            )
        save_state(existing)
        cmd_status_impl(existing)
        return

    account_id = aws_account_id(region)
    vpc_id = get_default_vpc(region)

    print()
    log("Setting up Dalston on AWS")
    log(f"  Template: {args.template}")
    log(f"  Region:   {region}")
    log(f"  Scenario: {scenario}")
    log(f"  Account:  {account_id}")
    print()

    st = DeploymentState(
        region=region,
        scenario=scenario,
        template=args.template,
        key_name=key_name,
    )

    # 1. S3 bucket
    st.s3_bucket = create_s3_bucket(region)

    # 2. IAM role
    st.iam_role, st.instance_profile = create_iam_role(region, st.s3_bucket)

    # 3. Key pair
    st.key_name = ensure_key_pair(region, key_name)

    # 4. Security groups
    st.sg_id = create_security_group(region, vpc_id)
    if tmpl.gpu_worker:
        st.gpu_sg_id = create_gpu_worker_security_group(region, vpc_id)
        open_control_plane_ports(region, st.sg_id, st.gpu_sg_id)

    save_state(st)
    audit("setup.done", scenario=scenario)

    print()
    log("Infrastructure ready.")
    log("Next: dalston-aws launch control-plane")
    cmd_status_impl(st)


def cmd_status_impl(st: DeploymentState) -> None:
    print()
    log("Dalston AWS Deployment")
    log(f"  Scenario: {st.scenario}")
    if st.template:
        log(f"  Template: {st.template}")
    log(f"  Region:   {st.region}")
    log(f"  S3:       {st.s3_bucket}")
    print()

    inst = describe_instance(st.region, st.instance_id)
    state = inst["State"]["Name"] if inst else "terminated"
    ip = (inst.get("PublicIpAddress", "") or "") if inst else ""
    label = "Control plane" if st.scenario == "split" else "Instance"
    log(f"  {label}: {st.instance_id}  state={state}  ip={ip or 'none'}")

    if st.scenario == "split" and st.gpu_workers:
        for w in st.gpu_workers:
            gpu_inst = describe_instance(st.region, w["instance_id"])
            gpu_state = gpu_inst["State"]["Name"] if gpu_inst else "terminated"
            gpu_ip = (gpu_inst.get("PublicIpAddress", "") or "") if gpu_inst else ""
            engines = ",".join(w.get("engines") or [])
            pricing = "spot" if w.get("spot", True) else "on-demand"
            itype = w.get("instance_type", "")
            log(
                f"  GPU '{w['name']}':  {w['instance_id']}  state={gpu_state}  "
                f"ip={gpu_ip or 'none'}  {itype} ({pricing})  engines={engines}"
            )
    print()


def cmd_status(args: argparse.Namespace) -> None:
    st = require_state()
    cmd_status_impl(st)


def _launch_control_plane(
    st: DeploymentState, tmpl: DeploymentTemplate, *, observability: bool = False
) -> None:
    """Launch the control plane instance."""
    if st.instance_id:
        state = get_instance_state(st.region, st.instance_id)
        if state in ("running", "stopped"):
            die(f"Control plane already exists ({st.instance_id}, state={state}).")

    cp = tmpl.control_plane
    compose_profiles = " ".join(f"--profile {p}" for p in (cp.compose_profiles or []))
    tag = (
        f"{NAME_PREFIX}-control-plane"
        if tmpl.scenario == "split"
        else f"{NAME_PREFIX}-server"
    )

    obs_suffix = " with observability" if observability else ""
    log(f"Launching {tag} ({cp.instance_type}, spot={cp.spot}){obs_suffix}...")
    ud = generate_user_data(
        st.s3_bucket,
        st.region,
        compose_profiles,
        use_ghcr=True,
        registry=tmpl.registry,
        observability=observability,
    )
    st.observability = observability
    st.instance_id = launch_instance(
        st.region,
        cp.instance_type,
        st.sg_id,
        ud,
        tag,
        cp.spot,
        st.key_name,
        st.instance_profile,
    )
    wait_instance_running(st.region, st.instance_id)
    st.data_volume_id = create_and_attach_data_volume(
        st.region, st.instance_id, cp.data_volume_gb
    )
    save_state(st)

    ip = get_instance_ip(st.region, st.instance_id)
    audit("launch.control-plane", instance=st.instance_id, ip=ip)
    log(f"Control plane running: {st.instance_id} ({ip})")


def _write_gpu_prometheus_targets(
    workers: list[dict], key_name: str = "dalston-key"
) -> None:
    """Write Prometheus file_sd targets for all GPU workers on the control plane.

    Uses SSH via Tailscale to write a JSON targets file that Prometheus picks up
    via file_sd_configs. Prometheus rescans every 30s, so targets appear quickly.
    """
    # Build targets using Tailscale IPs (Docker's DNS can't resolve
    # Tailscale hostnames). IPs are stable for the instance lifetime.
    target_groups = []
    for w in workers:
        ts_host = _resolve_tailscale_host(f"dalston-gpu-{w['name']}")
        ts_ip = _resolve_tailscale_ip(ts_host)
        if not ts_ip:
            warn(f"Could not resolve Tailscale IP for {ts_host}, skipping")
            continue
        engines = w.get("engines", [])
        ports = [f"{ts_ip}:{9100 + i}" for i in range(len(engines))]
        target_groups.append(
            {
                "targets": ports,
                "labels": {
                    "instance_group": "gpu-worker",
                    "host": ts_host,
                    "worker": w["name"],
                },
            }
        )
    if not target_groups:
        return
    targets_json = json.dumps(target_groups)
    cmd = (
        f"sudo mkdir -p /data/prometheus && "
        f"echo {shlex.quote(targets_json)} | sudo tee /data/prometheus/gpu-targets.json > /dev/null && "
        f"sudo chown 65534:65534 /data/prometheus/gpu-targets.json"
    )
    ctrl_host = _resolve_tailscale_host("dalston-control-plane")
    log(f"Writing GPU Prometheus targets on {ctrl_host}...")
    try:
        key_file = Path.home() / ".dalston" / f"{key_name}.pem"
        subprocess.run(
            _ssh_base_args(ctrl_host, "ec2-user", key_file) + [cmd],
            check=True,
            capture_output=True,
            text=True,
            timeout=30,
        )
        log("GPU Prometheus targets registered")
    except (subprocess.TimeoutExpired, subprocess.CalledProcessError) as e:
        warn(f"Could not write GPU targets via SSH: {e}")
        warn(
            f"Manually run on control plane: echo '{targets_json}' > /data/prometheus/gpu-targets.json"
        )


def _launch_gpu(
    st: DeploymentState,
    tmpl: DeploymentTemplate,
    *,
    spot: bool | None = None,
    gpu_type: str | None = None,
    engines: list[str] | None = None,
    region: str | None = None,
) -> None:
    """Launch a GPU worker instance with specified engines."""
    gw = tmpl.gpu_worker
    if not gw:
        die("Template has no gpu_worker config.")

    use_spot = spot if spot is not None else gw.spot
    gpu_type = gpu_type or gw.instance_type
    engines = engines or list(GPU_ENGINE_PRESETS.keys())
    worker_name = "-".join(engines) if len(engines) < 3 else "combo"

    # Check for name collision with existing workers
    if st.gpu_workers:
        for w in st.gpu_workers:
            if w["name"] == worker_name:
                w_state = get_instance_state(st.region, w["instance_id"])
                if w_state in ("terminated", "shutting-down"):
                    log(
                        f"Previous worker '{worker_name}' ({w['instance_id']}) is {w_state}, replacing..."
                    )
                    st.gpu_workers.remove(w)
                    save_state(st)
                    break
                else:
                    die(
                        f"GPU worker '{worker_name}' already exists ({w['instance_id']}, state={w_state})."
                    )

    if not st.instance_id:
        die("Control plane not launched. Run 'dalston-aws launch control-plane' first.")
    ctrl_inst = describe_instance(st.region, st.instance_id)
    main_state = ctrl_inst["State"]["Name"] if ctrl_inst else "terminated"
    if main_state != "running":
        die(f"Control plane is {main_state}. Run 'dalston-aws up' first.")

    if not st.gpu_sg_id:
        die("GPU security group not provisioned. Re-run 'dalston-aws setup -t split'.")

    # Cross-region GPU worker: provision a minimal SG in the target region
    gpu_region = region or st.region
    if gpu_region != st.region:
        log(f"Cross-region GPU worker: {gpu_region} (control plane: {st.region})")
        gpu_sg_id = _ensure_cross_region_sg(gpu_region, st.key_name)
    else:
        gpu_sg_id = st.gpu_sg_id

    # Open observability ports if enabled (idempotent)
    if st.observability and gpu_region == st.region:
        open_observability_ports(st.region, st.sg_id, st.gpu_sg_id)

    _check_gpu_compat(engines, gpu_type)

    log(
        f"Launching GPU worker '{worker_name}' ({gpu_type}, spot={use_spot}, "
        f"engines={engines}, region={gpu_region})..."
    )

    gpu_ud = generate_gpu_worker_user_data(
        st.s3_bucket,
        gpu_region,
        worker_name=worker_name,
        engines=engines,
        registry=tmpl.registry,
        observability=st.observability,
    )
    instance_id = launch_gpu_interactive(
        gpu_region,
        gpu_sg_id,
        gpu_ud,
        f"{NAME_PREFIX}-gpu-{worker_name}",
        use_spot,
        st.key_name,
        st.instance_profile,
        gpu_type,
        engines=engines,
    )
    wait_instance_running(gpu_region, instance_id)

    gpu_inst = describe_instance(gpu_region, instance_id)
    gpu_ip = (gpu_inst.get("PublicIpAddress", "") or "") if gpu_inst else ""

    worker = asdict(
        GpuWorker(
            name=worker_name,
            instance_id=instance_id,
            instance_type=gpu_type,
            spot=use_spot,
            engines=engines,
        )
    )
    if gpu_region != st.region:
        worker["region"] = gpu_region
    if st.gpu_workers is None:
        st.gpu_workers = []
    st.gpu_workers.append(worker)
    save_state(st)

    audit(
        "launch.gpu",
        gpu_instance=instance_id,
        gpu_type=gpu_type,
        ip=gpu_ip,
        worker=worker_name,
    )
    log(f"GPU worker '{worker_name}' running: {instance_id} ({gpu_ip})")

    # Register all GPU worker metrics with Prometheus on the control plane
    if st.observability:
        _write_gpu_prometheus_targets(st.gpu_workers, key_name=st.key_name)


def cmd_launch(args: argparse.Namespace) -> None:
    st = require_state()
    if not st.template:
        die("No template recorded in state. Re-run 'dalston-aws setup -t TEMPLATE'.")
    tmpl = load_template(st.template)
    target = args.target

    # Resolve spot override: --spot → True, --on-demand → False, neither → None (use template)
    spot_override = True if args.spot else (False if args.on_demand else None)

    if target in ("control-plane", None):
        _launch_control_plane(st, tmpl, observability=args.observability)
    if target in ("gpu", None):
        if tmpl.gpu_worker:
            engines = args.engines.split(",") if args.engines else None
            _launch_gpu(
                st,
                tmpl,
                spot=spot_override,
                gpu_type=args.gpu_type,
                engines=engines,
                region=args.region,
            )
        elif target == "gpu":
            die("Template has no gpu_worker config.")

    cmd_status_impl(st)


def _terminate_gpu(st: DeploymentState, name: str | None = None) -> None:
    """Terminate GPU worker(s). If name is None, terminate all."""
    if not st.gpu_workers:
        log("No GPU workers to terminate.")
        return

    names: set[str] | None = None
    if name is not None:
        names = {n.strip() for n in name.split(",")}

    to_remove = []

    for w in st.gpu_workers:
        if names is not None and w["name"] not in names:
            continue
        iid = w["instance_id"]
        wname = w["name"]
        w_region = w.get("region", st.region)
        state = get_instance_state(w_region, iid)
        if state in ("terminated", "shutting-down"):
            to_remove.append(w)
            continue
        audit("terminate.gpu", gpu_instance=iid, worker=wname)
        cancel_spot_requests_for_instances(w_region, [iid])
        log(f"Terminating GPU worker '{wname}' ({iid})...")
        try:
            ec2_client(w_region).terminate_instances(InstanceIds=[iid])
            to_remove.append(w)
        except ClientError as e:
            warn(f"Failed to terminate '{wname}' ({iid}): {e}")

    for w in to_remove:
        st.gpu_workers.remove(w)
    if not st.gpu_workers:
        st.gpu_workers = None
    save_state(st)
    if names:
        log(f"GPU worker(s) {', '.join(sorted(names))} terminated.")
    else:
        log("All GPU workers terminated.")


def _terminate_control_plane(st: DeploymentState) -> None:
    """Terminate the control plane and clean up its resources."""
    if not st.instance_id:
        log("No control plane to terminate.")
        return

    ec2 = ec2_client(st.region)

    if get_instance_state(st.region, st.instance_id) != "terminated":
        audit("terminate.control-plane", instance=st.instance_id)
        cancel_spot_requests_for_instances(st.region, [st.instance_id])
        log(f"Terminating control plane {st.instance_id}...")
        try:
            ec2.terminate_instances(InstanceIds=[st.instance_id])
        except ClientError:
            pass
        wait_instance_terminated(st.region, st.instance_id)

    if st.data_volume_id:
        log(f"Deleting data volume {st.data_volume_id}...")
        try:
            ec2.delete_volume(VolumeId=st.data_volume_id)
        except ClientError:
            pass

    st.instance_id = ""
    st.data_volume_id = ""
    save_state(st)
    log("Control plane terminated.")


def cmd_terminate(args: argparse.Namespace) -> None:
    st = require_state()
    target = args.target

    if target is None:
        warn("This will terminate ALL instances.")
        confirm = input("Type 'yes' to confirm: ").strip()
        if confirm != "yes":
            die("Aborted.")

    # GPU first, then control plane
    if target in ("gpu", None):
        gpu_name = getattr(args, "name", None)
        _terminate_gpu(st, name=gpu_name)
    if target in ("control-plane", None):
        _terminate_control_plane(st)

    cmd_status_impl(st)


def _ssh_base_args(
    host: str, user: str, key_file: Path, connect_timeout: int = 10
) -> list[str]:
    """Build common SSH command prefix."""
    args = [
        "ssh",
        "-o",
        "StrictHostKeyChecking=no",
        "-o",
        f"ConnectTimeout={connect_timeout}",
    ]
    if key_file.exists():
        args += ["-i", str(key_file)]
    args.append(f"{user}@{host}")
    return args


def _wait_for_ssh(host: str, user: str, key_file: Path, timeout: int = 120) -> bool:
    """Wait until SSH is reachable, returning True on success."""
    ssh_cmd = _ssh_base_args(host, user, key_file, connect_timeout=5) + [
        "-o",
        "BatchMode=yes",
        "true",
    ]
    deadline = time.time() + timeout
    while time.time() < deadline:
        if subprocess.run(ssh_cmd, capture_output=True).returncode == 0:
            return True
        time.sleep(5)
    return False


def _ssh_run(host: str, user: str, key_file: Path, command: str) -> int:
    """Run a command over SSH and stream output. Returns exit code."""
    return subprocess.call(_ssh_base_args(host, user, key_file) + [command])


def cmd_up(args: argparse.Namespace) -> None:
    st = require_state()
    if not st.instance_id:
        die("No instances to start. Run 'dalston-aws launch control-plane' first.")
    audit("up", instance=st.instance_id)
    log("Starting instance(s)...")
    ec2 = ec2_client(st.region)

    cp_state = get_instance_state(st.region, st.instance_id)
    if cp_state == "terminated":
        warn(f"Control plane {st.instance_id} was terminated.")
        _terminate_control_plane(st)
        die("Run 'dalston-aws launch control-plane' to launch a new one.")
    retry_aws(ec2.start_instances, InstanceIds=[st.instance_id])

    for w in st.gpu_workers or []:
        gpu_state = get_instance_state(st.region, w["instance_id"])
        if gpu_state == "terminated":
            warn(f"GPU worker '{w['name']}' ({w['instance_id']}) was terminated.")
        else:
            retry_aws(ec2.start_instances, InstanceIds=[w["instance_id"]])
    log("Start command sent. Instances booting...")

    if args.pull:
        key_file = STATE_DIR / f"{st.key_name}.pem"
        host = _resolve_tailscale_host("dalston-control-plane")
        log(f"Waiting for SSH on {host}...")
        if not _wait_for_ssh(host, "ec2-user", key_file):
            warn(
                "SSH not reachable after timeout. Run deploy manually: sudo /data/dalston/deploy.sh"
            )
            return
        log("Pulling latest images and redeploying...")
        rc = _ssh_run(host, "ec2-user", key_file, "sudo /data/dalston/deploy.sh")
        if rc != 0:
            warn(f"Deploy script exited with code {rc}")
        else:
            log("Deploy complete.")


def _stop_instance(ec2, region: str, instance_id: str) -> None:
    """Stop an instance, handling spot and already-terminated cases."""
    state = get_instance_state(region, instance_id)
    if state in ("terminated", "shutting-down"):
        log(f"  {instance_id}: already {state}, skipping")
        return
    try:
        ec2.stop_instances(InstanceIds=[instance_id])
        log(f"  {instance_id}: stop requested")
    except ClientError as e:
        err_str = str(e)
        if "UnsupportedOperation" in err_str and "Spot" in err_str:
            warn(f"  {instance_id}: one-time spot instance — terminating instead")
            ec2.terminate_instances(InstanceIds=[instance_id])
        elif "IncorrectInstanceState" in err_str:
            log(f"  {instance_id}: cannot stop (state may have changed), skipping")
        else:
            raise


def cmd_down(args: argparse.Namespace) -> None:
    st = require_state()
    if not st.instance_id:
        die("No instances to stop. Run 'dalston-aws launch control-plane' first.")
    audit("down", instance=st.instance_id)
    log("Stopping instance(s)...")
    ec2 = ec2_client(st.region)
    _stop_instance(ec2, st.region, st.instance_id)
    for w in st.gpu_workers or []:
        _stop_instance(ec2, st.region, w["instance_id"])
    log("Done. Use 'dalston-aws up' to restart.")


def _resolve_tailscale_host(base_hostname: str) -> str:
    """Find the actual Tailscale hostname, handling -1/-2 suffixes."""
    import subprocess

    try:
        result = subprocess.run(
            ["tailscale", "status", "--json"],
            capture_output=True,
            text=True,
            timeout=5,
        )
        if result.returncode == 0:
            import re

            status = json.loads(result.stdout)
            pattern = re.compile(rf"^{re.escape(base_hostname)}(-\d+)?$")
            for peer in (status.get("Peer") or {}).values():
                name = peer.get("HostName", "")
                if pattern.match(name) and peer.get("Online"):
                    if name != base_hostname:
                        warn(f"Tailscale node is '{name}' (not '{base_hostname}')")
                    return name
    except (subprocess.TimeoutExpired, FileNotFoundError, json.JSONDecodeError):
        pass
    return base_hostname


def _resolve_tailscale_ip(hostname: str) -> str | None:
    """Resolve a Tailscale hostname to its 100.x.y.z IP."""
    import subprocess

    try:
        result = subprocess.run(
            ["tailscale", "status", "--json"],
            capture_output=True,
            text=True,
            timeout=5,
        )
        if result.returncode == 0:
            status = json.loads(result.stdout)
            for peer in (status.get("Peer") or {}).values():
                if peer.get("HostName") == hostname and peer.get("Online"):
                    ips = peer.get("TailscaleIPs", [])
                    if ips:
                        return ips[0]
    except (subprocess.TimeoutExpired, FileNotFoundError, json.JSONDecodeError):
        pass
    return None


def cmd_ssh(args: argparse.Namespace) -> None:
    st = require_state()

    if args.target == "gpu":
        if not st.gpu_workers:
            die("No GPU workers found. Use 'dalston-aws ssh' for the main instance.")
        # If multiple workers, pick by --name or default to first
        gpu_name = getattr(args, "name", None)
        if gpu_name:
            worker = next((w for w in st.gpu_workers if w["name"] == gpu_name), None)
            if not worker:
                names = [w["name"] for w in st.gpu_workers]
                die(f"GPU worker '{gpu_name}' not found. Available: {names}")
        else:
            worker = st.gpu_workers[0]
            if len(st.gpu_workers) > 1:
                names = [w["name"] for w in st.gpu_workers]
                warn(
                    f"Multiple GPU workers: {names}. Connecting to '{worker['name']}'. Use --name to choose."
                )
        base_hostname = f"dalston-gpu-{worker['name']}"
        user = "ubuntu"  # DL AMI is Ubuntu-based
    else:
        base_hostname = "dalston-control-plane"
        user = "ec2-user"  # AL2023

    hostname = _resolve_tailscale_host(base_hostname)

    key_file = STATE_DIR / f"{st.key_name}.pem"
    ssh_args = ["ssh"]
    if key_file.exists():
        ssh_args += ["-i", str(key_file)]
    ssh_args.append(f"{user}@{hostname}")

    log(f"Connecting to {hostname}...")
    os.execvp("ssh", ssh_args)


def cmd_teardown(args: argparse.Namespace) -> None:
    st = require_state()
    gpu_ids = [w["instance_id"] for w in (st.gpu_workers or [])]
    audit(
        "teardown",
        instance=st.instance_id,
        gpu_instances=gpu_ids or None,
        s3_bucket=st.s3_bucket,
    )

    print()
    warn("This will PERMANENTLY DELETE all Dalston AWS resources:")
    instance_list = st.instance_id
    for gid in gpu_ids:
        instance_list += f" {gid}"
    warn(f"  - EC2 instance(s): {instance_list}")
    volume_list = st.data_volume_id
    warn(f"  - EBS volumes: {volume_list}")
    warn(f"  - S3 bucket: {st.s3_bucket} (contents preserved -- delete manually)")
    warn(f"  - IAM role: {st.iam_role}")
    sg_list = st.sg_id
    if st.gpu_sg_id:
        sg_list += f" {st.gpu_sg_id}"
    warn(f"  - Security group(s): {sg_list}")
    print()
    confirm = input("Type 'yes' to confirm: ").strip()
    if confirm != "yes":
        die("Aborted.")

    # Terminate instances and clean up volumes
    _terminate_gpu(st)
    _terminate_control_plane(st)

    # Delete security groups (GPU SG first since control plane SG may reference it)
    ec2 = ec2_client(st.region)
    time.sleep(3)
    for sg_attr in ("gpu_sg_id", "sg_id"):
        sg_id = getattr(st, sg_attr)
        if sg_id:
            log(f"Deleting security group {sg_id}...")
            try:
                ec2.delete_security_group(GroupId=sg_id)
            except ClientError:
                pass
    st.sg_id = ""
    st.gpu_sg_id = ""
    save_state(st)

    # Delete IAM resources
    iam = iam_client()
    log("Deleting IAM role...")
    profile_name = st.instance_profile or f"{NAME_PREFIX}-instance-profile"
    role_name = st.iam_role or f"{NAME_PREFIX}-ec2-role"
    try:
        iam.remove_role_from_instance_profile(
            InstanceProfileName=profile_name,
            RoleName=role_name,
        )
    except ClientError:
        pass
    try:
        iam.delete_instance_profile(InstanceProfileName=profile_name)
    except ClientError:
        pass
    for policy_name in (
        f"{NAME_PREFIX}-s3-access",
        f"{NAME_PREFIX}-ssm-access",
    ):
        try:
            iam.delete_role_policy(RoleName=role_name, PolicyName=policy_name)
        except ClientError:
            pass
    try:
        iam.delete_role(RoleName=role_name)
    except ClientError:
        pass

    warn(f"S3 bucket {st.s3_bucket} was NOT deleted (may contain transcription data).")
    warn(f"To delete: aws s3 rb s3://{st.s3_bucket} --force")

    # Clean up state
    STATE_FILE.unlink(missing_ok=True)
    log("Teardown complete.")


# ---------------------------------------------------------------------------
# Argument parser
# ---------------------------------------------------------------------------


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="dalston-aws",
        description="Provision and manage Dalston on AWS without Terraform.",
    )
    sub = parser.add_subparsers(dest="command")

    # setup
    p_setup = sub.add_parser(
        "setup", help="Provision AWS infrastructure (S3, IAM, SG, keypair)"
    )
    p_setup.add_argument(
        "--template",
        "-t",
        required=True,
        help="Template name (cpu, split, gpu) or path to YAML file",
    )
    p_setup.add_argument(
        "--region", default=os.environ.get("AWS_REGION", DEFAULT_REGION)
    )
    p_setup.add_argument("--key", default=None, help="Existing SSH key pair name")
    p_setup.set_defaults(func=cmd_setup)

    # teardown
    p_teardown = sub.add_parser("teardown", help="Remove all AWS resources")
    p_teardown.set_defaults(func=cmd_teardown)

    # status
    p_status = sub.add_parser("status", help="Show instance state")
    p_status.set_defaults(func=cmd_status)

    # up
    p_up = sub.add_parser("up", help="Start instance(s)")
    p_up.add_argument(
        "--pull",
        action="store_true",
        help="Pull latest GHCR images and redeploy after boot",
    )
    p_up.set_defaults(func=cmd_up)

    # down
    p_down = sub.add_parser("down", help="Stop instance(s)")
    p_down.set_defaults(func=cmd_down)

    # ssh
    p_ssh = sub.add_parser("ssh", help="SSH to instance via Tailscale")
    p_ssh.add_argument(
        "target",
        nargs="?",
        default="main",
        choices=["main", "gpu"],
        help="Which instance to connect to (default: main)",
    )
    p_ssh.add_argument(
        "--name",
        default=None,
        help="GPU worker name (e.g., 'onnx', 'pyannote') when target=gpu",
    )
    p_ssh.set_defaults(func=cmd_ssh)

    # launch
    p_launch = sub.add_parser(
        "launch", help="Launch instance(s) (control-plane, gpu, or all)"
    )
    p_launch.add_argument(
        "target",
        nargs="?",
        default=None,
        choices=["control-plane", "gpu"],
        help="Component to launch (default: all from template)",
    )
    spot_group = p_launch.add_mutually_exclusive_group()
    spot_group.add_argument("--spot", action="store_true", help="Force spot pricing")
    spot_group.add_argument(
        "--on-demand", action="store_true", help="Force on-demand pricing"
    )
    p_launch.add_argument(
        "--gpu-type", default=None, help="GPU instance type (overrides template)"
    )
    p_launch.add_argument(
        "--engines",
        default=None,
        help="Comma-separated engines to run (e.g., 'onnx', 'pyannote', 'onnx,pyannote')",
    )
    p_launch.add_argument(
        "--observability",
        action="store_true",
        default=False,
        help="Deploy observability stack (Jaeger, Prometheus, Grafana, Loki) on control plane",
    )
    p_launch.add_argument(
        "--region",
        default=None,
        help="AWS region for GPU worker (default: same as control plane)",
    )
    p_launch.set_defaults(func=cmd_launch)

    # terminate
    p_term = sub.add_parser(
        "terminate", help="Terminate instance(s) (control-plane, gpu, or all)"
    )
    p_term.add_argument(
        "target",
        nargs="?",
        default=None,
        choices=["control-plane", "gpu"],
        help="Component to terminate (default: all, requires confirmation)",
    )
    p_term.add_argument(
        "--name",
        default=None,
        help="Terminate specific GPU worker(s) by name, comma-separated (e.g., 'onnx,pyannote')",
    )
    p_term.set_defaults(func=cmd_terminate)

    return parser


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(0)

    args.func(args)


if __name__ == "__main__":
    main()
