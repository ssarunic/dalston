#!/usr/bin/env python3
"""dalston-aws — provision and manage Dalston on AWS without Terraform.

Usage:
    dalston-aws setup [--cpu|--gpu|--split] [--spot] [--region R] [--gpu-type T]
    dalston-aws teardown
    dalston-aws status
    dalston-aws up
    dalston-aws down
    dalston-aws ssh [gpu]
    dalston-aws add-gpu [--spot] [--gpu-type T]
    dalston-aws remove-gpu

Prerequisites:
    - AWS credentials configured (boto3 must be able to call sts:GetCallerIdentity)
    - pip install boto3
"""

from __future__ import annotations

import argparse
import base64
import json
import os
import sys
import time
from dataclasses import asdict, dataclass
from pathlib import Path
from typing import NoReturn

import boto3
from botocore.exceptions import ClientError, WaiterError

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

STATE_DIR = Path.home() / ".dalston"
STATE_FILE = STATE_DIR / "aws-state.json"
NAME_PREFIX = "dalston"
DATA_VOLUME_SIZE = 50
ROOT_VOLUME_SIZE = 30
REPO_URL = "https://github.com/ssarunic/dalston.git"
REPO_BRANCH = "main"
DEFAULT_REGION = "eu-west-2"
GPU_INSTANCE_TYPE = "g4dn.xlarge"
CPU_INSTANCE_TYPE = "t3.xlarge"
CTRL_INSTANCE_TYPE = "t3.medium"

# ---------------------------------------------------------------------------
# Colored output helpers
# ---------------------------------------------------------------------------

_RED = "\033[0;31m"
_GREEN = "\033[0;32m"
_YELLOW = "\033[1;33m"
_BLUE = "\033[0;34m"
_NC = "\033[0m"


def log(msg: str) -> None:
    print(f"{_GREEN}[dalston-aws]{_NC} {msg}")


def warn(msg: str) -> None:
    print(f"{_YELLOW}[dalston-aws]{_NC} {msg}")


def err(msg: str) -> None:
    print(f"{_RED}[dalston-aws]{_NC} {msg}", file=sys.stderr)


def die(msg: str) -> NoReturn:
    err(msg)
    sys.exit(1)


# ---------------------------------------------------------------------------
# State dataclass
# ---------------------------------------------------------------------------


@dataclass
class DeploymentState:
    region: str = DEFAULT_REGION
    scenario: str = "gpu"
    s3_bucket: str = ""
    iam_role: str = ""
    instance_profile: str = ""
    sg_id: str = ""
    instance_id: str = ""
    data_volume_id: str = ""
    gpu_instance_id: str = ""
    gpu_data_volume_id: str = ""
    gpu_sg_id: str = ""
    key_name: str = ""


def save_state(state: DeploymentState) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    STATE_FILE.write_text(json.dumps(asdict(state), indent=2) + "\n")
    log(f"State saved to {STATE_FILE}")


def load_state() -> DeploymentState | None:
    if not STATE_FILE.exists():
        return None
    data = json.loads(STATE_FILE.read_text())
    return DeploymentState(**data)


def require_state() -> DeploymentState:
    st = load_state()
    if st is None:
        die("No deployment found. Run 'dalston-aws setup' first.")
    return st


# ---------------------------------------------------------------------------
# boto3 client helpers
# ---------------------------------------------------------------------------


def ec2_client(region: str):
    return boto3.client("ec2", region_name=region)


def iam_client():
    return boto3.client("iam")


def s3_client(region: str):
    return boto3.client("s3", region_name=region)


def sts_client(region: str):
    return boto3.client("sts", region_name=region)


# ---------------------------------------------------------------------------
# AWS helpers
# ---------------------------------------------------------------------------


def aws_account_id(region: str) -> str:
    return sts_client(region).get_caller_identity()["Account"]


def get_instance_state(region: str, instance_id: str) -> str:
    try:
        resp = ec2_client(region).describe_instances(InstanceIds=[instance_id])
        return resp["Reservations"][0]["Instances"][0]["State"]["Name"]
    except (ClientError, IndexError, KeyError):
        return "terminated"


def get_instance_ip(region: str, instance_id: str) -> str:
    try:
        resp = ec2_client(region).describe_instances(InstanceIds=[instance_id])
        return resp["Reservations"][0]["Instances"][0].get("PublicIpAddress", "") or ""
    except (ClientError, IndexError, KeyError):
        return ""


def get_instance_private_ip(region: str, instance_id: str) -> str:
    try:
        resp = ec2_client(region).describe_instances(InstanceIds=[instance_id])
        return resp["Reservations"][0]["Instances"][0].get("PrivateIpAddress", "") or ""
    except (ClientError, IndexError, KeyError):
        return ""


def get_instance_vpc(region: str, instance_id: str) -> str:
    resp = ec2_client(region).describe_instances(InstanceIds=[instance_id])
    return resp["Reservations"][0]["Instances"][0]["VpcId"]


def get_instance_type(region: str, instance_id: str) -> str:
    try:
        resp = ec2_client(region).describe_instances(InstanceIds=[instance_id])
        return resp["Reservations"][0]["Instances"][0]["InstanceType"]
    except (ClientError, IndexError, KeyError):
        return ""


def wait_instance_running(region: str, instance_id: str) -> None:
    log(f"Waiting for {instance_id} to be running...")
    waiter = ec2_client(region).get_waiter("instance_running")
    waiter.wait(InstanceIds=[instance_id])


def wait_instance_terminated(region: str, instance_id: str) -> None:
    try:
        waiter = ec2_client(region).get_waiter("instance_terminated")
        waiter.wait(InstanceIds=[instance_id])
    except WaiterError:
        pass


def get_default_vpc(region: str) -> str:
    resp = ec2_client(region).describe_vpcs(
        Filters=[{"Name": "is-default", "Values": ["true"]}]
    )
    vpcs = resp.get("Vpcs", [])
    if not vpcs:
        die("No default VPC found in region " + region)
    return vpcs[0]["VpcId"]


def retry_aws(func, *args, max_retries: int = 4, **kwargs):
    delay = 2
    for attempt in range(1, max_retries + 1):
        try:
            return func(*args, **kwargs)
        except ClientError as e:
            if attempt >= max_retries:
                raise
            warn(f"Attempt {attempt} failed ({e}), retrying in {delay}s...")
            time.sleep(delay)
            delay *= 2


# ---------------------------------------------------------------------------
# S3 bucket
# ---------------------------------------------------------------------------


def create_s3_bucket(region: str) -> str:
    account_id = aws_account_id(region)
    bucket = f"{NAME_PREFIX}-artifacts-{account_id}"
    s3 = s3_client(region)

    try:
        s3.head_bucket(Bucket=bucket)
        log(f"S3 bucket {bucket} already exists")
        return bucket
    except ClientError:
        pass

    log(f"Creating S3 bucket: {bucket}")
    create_kwargs: dict = {"Bucket": bucket}
    if region != "us-east-1":
        create_kwargs["CreateBucketConfiguration"] = {"LocationConstraint": region}
    s3.create_bucket(**create_kwargs)

    # Block public access
    s3.put_public_access_block(
        Bucket=bucket,
        PublicAccessBlockConfiguration={
            "BlockPublicAcls": True,
            "IgnorePublicAcls": True,
            "BlockPublicPolicy": True,
            "RestrictPublicBuckets": True,
        },
    )

    # Enable encryption
    s3.put_bucket_encryption(
        Bucket=bucket,
        ServerSideEncryptionConfiguration={
            "Rules": [
                {"ApplyServerSideEncryptionByDefault": {"SSEAlgorithm": "AES256"}}
            ]
        },
    )

    # Lifecycle rules
    s3.put_bucket_lifecycle_configuration(
        Bucket=bucket,
        LifecycleConfiguration={
            "Rules": [
                {
                    "ID": "cleanup-temp",
                    "Status": "Enabled",
                    "Filter": {"Prefix": "temp/"},
                    "Expiration": {"Days": 7},
                },
                {
                    "ID": "cleanup-jobs",
                    "Status": "Enabled",
                    "Filter": {"Prefix": "jobs/"},
                    "Expiration": {"Days": 30},
                },
            ]
        },
    )

    log("S3 bucket created with encryption + lifecycle rules")
    return bucket


# ---------------------------------------------------------------------------
# IAM role + instance profile
# ---------------------------------------------------------------------------


def create_iam_role(region: str, s3_bucket: str) -> tuple[str, str]:
    iam = iam_client()
    role_name = f"{NAME_PREFIX}-ec2-role"
    profile_name = f"{NAME_PREFIX}-instance-profile"
    account_id = aws_account_id(region)

    # Create role if needed
    try:
        iam.get_role(RoleName=role_name)
        log(f"IAM role {role_name} already exists")
    except ClientError:
        log(f"Creating IAM role: {role_name}")
        iam.create_role(
            RoleName=role_name,
            AssumeRolePolicyDocument=json.dumps(
                {
                    "Version": "2012-10-17",
                    "Statement": [
                        {
                            "Effect": "Allow",
                            "Principal": {"Service": "ec2.amazonaws.com"},
                            "Action": "sts:AssumeRole",
                        }
                    ],
                }
            ),
            Tags=[{"Key": "Project", "Value": "dalston"}],
        )

    # S3 access policy (idempotent upsert)
    bucket_arn = f"arn:aws:s3:::{s3_bucket}"
    iam.put_role_policy(
        RoleName=role_name,
        PolicyName=f"{NAME_PREFIX}-s3-access",
        PolicyDocument=json.dumps(
            {
                "Version": "2012-10-17",
                "Statement": [
                    {
                        "Effect": "Allow",
                        "Action": ["s3:ListBucket"],
                        "Resource": bucket_arn,
                    },
                    {
                        "Effect": "Allow",
                        "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
                        "Resource": f"{bucket_arn}/*",
                    },
                ],
            }
        ),
    )

    # ECR pull access policy
    iam.put_role_policy(
        RoleName=role_name,
        PolicyName=f"{NAME_PREFIX}-ecr-access",
        PolicyDocument=json.dumps(
            {
                "Version": "2012-10-17",
                "Statement": [
                    {
                        "Effect": "Allow",
                        "Action": ["ecr:GetAuthorizationToken"],
                        "Resource": "*",
                    },
                    {
                        "Effect": "Allow",
                        "Action": [
                            "ecr:BatchGetImage",
                            "ecr:GetDownloadUrlForLayer",
                            "ecr:BatchCheckLayerAvailability",
                        ],
                        "Resource": f"arn:aws:ecr:{region}:{account_id}:repository/dalston/*",
                    },
                ],
            }
        ),
    )

    # SSM read access (for Tailscale auth key)
    iam.put_role_policy(
        RoleName=role_name,
        PolicyName=f"{NAME_PREFIX}-ssm-access",
        PolicyDocument=json.dumps(
            {
                "Version": "2012-10-17",
                "Statement": [
                    {
                        "Effect": "Allow",
                        "Action": ["ssm:GetParameter"],
                        "Resource": f"arn:aws:ssm:{region}:{account_id}:parameter/dalston/*",
                    }
                ],
            }
        ),
    )

    # Instance profile
    try:
        iam.get_instance_profile(InstanceProfileName=profile_name)
        log(f"Instance profile {profile_name} already exists")
    except ClientError:
        log(f"Creating instance profile: {profile_name}")
        iam.create_instance_profile(
            InstanceProfileName=profile_name,
            Tags=[{"Key": "Project", "Value": "dalston"}],
        )
        iam.add_role_to_instance_profile(
            InstanceProfileName=profile_name,
            RoleName=role_name,
        )
        log("Waiting for IAM instance profile to propagate...")
        time.sleep(10)

    log("IAM role + instance profile ready")
    return role_name, profile_name


# ---------------------------------------------------------------------------
# Security groups
# ---------------------------------------------------------------------------


def _find_sg(region: str, name: str, vpc_id: str) -> str | None:
    resp = ec2_client(region).describe_security_groups(
        Filters=[
            {"Name": "group-name", "Values": [name]},
            {"Name": "vpc-id", "Values": [vpc_id]},
        ]
    )
    groups = resp.get("SecurityGroups", [])
    if groups:
        return groups[0]["GroupId"]
    return None


def create_security_group(region: str, vpc_id: str) -> str:
    name = f"{NAME_PREFIX}-sg"
    existing = _find_sg(region, name, vpc_id)
    if existing:
        log(f"Security group {existing} already exists")
        return existing

    log(f"Creating security group: {name}")
    ec2 = ec2_client(region)
    resp = ec2.create_security_group(
        GroupName=name,
        Description="Dalston EC2 - SSH from Tailscale",
        VpcId=vpc_id,
    )
    sg_id = resp["GroupId"]

    ec2.authorize_security_group_ingress(
        GroupId=sg_id,
        IpPermissions=[
            {
                "IpProtocol": "tcp",
                "FromPort": 22,
                "ToPort": 22,
                "IpRanges": [{"CidrIp": "100.64.0.0/10"}],
            }
        ],
    )

    ec2.create_tags(
        Resources=[sg_id],
        Tags=[
            {"Key": "Name", "Value": name},
            {"Key": "Project", "Value": "dalston"},
        ],
    )

    log(f"Security group {sg_id} created (SSH from Tailscale)")
    return sg_id


def create_gpu_worker_security_group(region: str, vpc_id: str) -> str:
    name = f"{NAME_PREFIX}-gpu-sg"
    existing = _find_sg(region, name, vpc_id)
    if existing:
        log(f"GPU security group {existing} already exists")
        return existing

    log(f"Creating GPU worker security group: {name}")
    ec2 = ec2_client(region)
    resp = ec2.create_security_group(
        GroupName=name,
        Description="Dalston GPU worker - SSH from Tailscale",
        VpcId=vpc_id,
    )
    gpu_sg_id = resp["GroupId"]

    ec2.authorize_security_group_ingress(
        GroupId=gpu_sg_id,
        IpPermissions=[
            {
                "IpProtocol": "tcp",
                "FromPort": 22,
                "ToPort": 22,
                "IpRanges": [{"CidrIp": "100.64.0.0/10"}],
            }
        ],
    )

    ec2.create_tags(
        Resources=[gpu_sg_id],
        Tags=[
            {"Key": "Name", "Value": name},
            {"Key": "Project", "Value": "dalston"},
        ],
    )

    log(f"GPU security group {gpu_sg_id} created")
    return gpu_sg_id


def open_control_plane_ports(region: str, ctrl_sg_id: str, gpu_sg_id: str) -> None:
    ec2 = ec2_client(region)
    for port in (6379, 5432):
        try:
            ec2.authorize_security_group_ingress(
                GroupId=ctrl_sg_id,
                IpPermissions=[
                    {
                        "IpProtocol": "tcp",
                        "FromPort": port,
                        "ToPort": port,
                        "UserIdGroupPairs": [{"GroupId": gpu_sg_id}],
                    }
                ],
            )
        except ClientError:
            pass  # rule already exists
    log("Control plane ports 6379,5432 open to GPU worker")


# ---------------------------------------------------------------------------
# Key pair
# ---------------------------------------------------------------------------


def ensure_key_pair(region: str, key_name: str) -> str:
    ec2 = ec2_client(region)
    try:
        ec2.describe_key_pairs(KeyNames=[key_name])
        log(f"Key pair {key_name} already exists in AWS")
        return key_name
    except ClientError:
        pass

    log(f"Creating key pair: {key_name}")
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    resp = ec2.create_key_pair(KeyName=key_name)
    key_file = STATE_DIR / f"{key_name}.pem"
    key_file.write_text(resp["KeyMaterial"])
    key_file.chmod(0o600)
    log(f"Private key saved to {key_file}")
    return key_name


# ---------------------------------------------------------------------------
# User-data generation
# ---------------------------------------------------------------------------


def generate_user_data(
    s3_bucket: str,
    region: str,
    compose_profiles: str,
    use_ecr: bool = False,
) -> str:
    account_id = aws_account_id(region)
    ecr_registry = f"{account_id}.dkr.ecr.{region}.amazonaws.com"
    hf_token = os.environ.get("HF_TOKEN", "")

    # Part 1: static header
    header = """\
#!/bin/bash
set -euo pipefail
exec > >(tee /var/log/user-data.log) 2>&1
echo "Starting Dalston bootstrap at $(date)"
"""

    # Part 2: variables (f-string interpolation)
    variables = f"""\
DATA_DEVICE="/dev/xvdf"
DATA_MOUNT="/data"
S3_BUCKET="{s3_bucket}"
AWS_REGION="{region}"
COMPOSE_PROFILE_FLAGS="{compose_profiles}"
USE_ECR="{"true" if use_ecr else "false"}"
ECR_REGISTRY="{ecr_registry}"
REPO_URL="{REPO_URL}"
HF_TOKEN="{hf_token}"
REPO_BRANCH="{REPO_BRANCH}"
"""

    # Part 3: body (raw string — no f-string to avoid bash {brace} conflicts)
    body = r"""
# Install Docker
echo "Installing Docker..."
dnf update -y
dnf install -y docker git pciutils

# Install and auto-join Tailscale
echo "Installing Tailscale..."
curl -fsSL https://tailscale.com/install.sh | sh
TS_AUTH_KEY=$(aws ssm get-parameter \
  --name "/dalston/tailscale-auth-key" \
  --with-decryption \
  --query "Parameter.Value" \
  --output text --region "$AWS_REGION") || true
if [ -n "$TS_AUTH_KEY" ]; then
  tailscale up --authkey="$TS_AUTH_KEY" --hostname="dalston-control-plane"
  echo "Tailscale joined as dalston-control-plane"
else
  echo "WARNING: No Tailscale auth key in SSM. Run 'sudo tailscale up' manually."
fi

# Start Docker
systemctl start docker
systemctl enable docker
usermod -aG docker ec2-user

# Install Docker Compose plugin
echo "Installing Docker Compose..."
mkdir -p /usr/local/lib/docker/cli-plugins
DOCKER_COMPOSE_VERSION="v2.34.0"
curl -L "https://github.com/docker/compose/releases/download/${DOCKER_COMPOSE_VERSION}/docker-compose-linux-x86_64" \
  -o /usr/local/lib/docker/cli-plugins/docker-compose
chmod +x /usr/local/lib/docker/cli-plugins/docker-compose

# GPU detection and NVIDIA runtime setup
if lspci | grep -qi nvidia; then
  echo "NVIDIA GPU detected. Installing NVIDIA Container Toolkit..."
  curl -fsSL https://nvidia.github.io/libnvidia-container/stable/rpm/nvidia-container-toolkit.repo \
    -o /etc/yum.repos.d/nvidia-container-toolkit.repo
  dnf install -y nvidia-container-toolkit || true
  if command -v nvidia-ctk >/dev/null 2>&1; then
    nvidia-ctk runtime configure --runtime=docker
    systemctl restart docker
    echo "NVIDIA runtime configured."
  else
    echo "WARNING: NVIDIA toolkit installation incomplete."
  fi
fi

# Wait for data volume
echo "Waiting for data volume..."
while [ ! -e "$DATA_DEVICE" ]; do
  sleep 5
done

# Format if needed
if ! blkid "$DATA_DEVICE" | grep -q ext4; then
  echo "Formatting data volume..."
  mkfs.ext4 -L dalston-data "$DATA_DEVICE"
fi

# Mount
mkdir -p "$DATA_MOUNT"
mount "$DATA_DEVICE" "$DATA_MOUNT"
if ! grep -q "$DATA_MOUNT" /etc/fstab; then
  echo "LABEL=dalston-data $DATA_MOUNT ext4 defaults,nofail 0 2" >> /etc/fstab
fi

# Create data directories
mkdir -p "$DATA_MOUNT/postgres" "$DATA_MOUNT/redis" "$DATA_MOUNT/models" "$DATA_MOUNT/dalston"
chown -R 1000:1000 "$DATA_MOUNT"

# Clone repo (shallow — only need compose files, code runs from ECR images)
if [ -n "$REPO_URL" ] && [ ! -f "$DATA_MOUNT/dalston/docker-compose.yml" ]; then
  echo "Cloning $REPO_URL ($REPO_BRANCH)..."
  git clone --depth 1 --branch "$REPO_BRANCH" "$REPO_URL" "$DATA_MOUNT/dalston"
fi

# Control plane services (only these start on the CPU instance)
CTRL_SERVICES="postgres redis gateway orchestrator stt-prepare"

# ECR-based deployment: login and build compose command with ECR overlay
if [ "$USE_ECR" = "true" ]; then
  COMPOSE_FILES="-f docker-compose.yml -f infra/docker/docker-compose.aws.yml -f infra/docker/docker-compose.ecr.yml"
  COMPOSE_UP_FLAGS="--no-build"

  # ECR login helper script (used by systemd and manual redeploy)
  cat > "$DATA_MOUNT/dalston/ecr-login.sh" << 'ECREOF'
#!/bin/bash
source /data/dalston/.env.aws
aws ecr get-login-password --region "$AWS_REGION" | docker login --username AWS --password-stdin "$ECR_REGISTRY"
ECREOF
  chmod +x "$DATA_MOUNT/dalston/ecr-login.sh"
else
  COMPOSE_FILES="-f docker-compose.yml -f infra/docker/docker-compose.aws.yml"
  COMPOSE_UP_FLAGS=""
fi

# Create .env.aws (includes compose vars for systemd)
cat > "$DATA_MOUNT/dalston/.env.aws" << ENVEOF
DALSTON_S3_BUCKET=${S3_BUCKET}
DALSTON_S3_REGION=${AWS_REGION}
AWS_REGION=${AWS_REGION}
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql+asyncpg://dalston:password@postgres:5432/dalston
HF_HOME=/data/models
ECR_REGISTRY=${ECR_REGISTRY}
IMAGE_TAG=latest
USE_ECR=${USE_ECR}
COMPOSE_FILES=${COMPOSE_FILES}
COMPOSE_UP_FLAGS=${COMPOSE_UP_FLAGS}
CTRL_SERVICES=${CTRL_SERVICES}
ENVEOF

# Create .env with secrets (only if it doesn't already exist — preserves manual edits)
if [ ! -f "$DATA_MOUNT/dalston/.env" ]; then
  cat > "$DATA_MOUNT/dalston/.env" << DOTENVEOF
HF_TOKEN=${HF_TOKEN}
POSTGRES_PASSWORD=password
DOTENVEOF
fi

# Create deploy script for easy redeploys
cat > "$DATA_MOUNT/dalston/deploy.sh" << DEPLOYEOF
#!/bin/bash
set -euo pipefail
cd /data/dalston
source .env.aws
export DALSTON_S3_BUCKET DALSTON_S3_REGION AWS_REGION REDIS_URL DATABASE_URL HF_HOME ECR_REGISTRY IMAGE_TAG

git pull --ff-only

if [ "$USE_ECR" = "true" ]; then
  ./ecr-login.sh
  docker compose ${COMPOSE_FILES} --env-file .env.aws pull ${CTRL_SERVICES}
fi

docker compose ${COMPOSE_FILES} --env-file .env.aws up -d ${COMPOSE_UP_FLAGS} ${CTRL_SERVICES}
echo "Deploy complete at \$(date)"
DEPLOYEOF
chmod +x "$DATA_MOUNT/dalston/deploy.sh"

# Create systemd service
cat > /etc/systemd/system/dalston.service << SVCEOF
[Unit]
Description=Dalston Transcription Server
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/data/dalston
EnvironmentFile=/data/dalston/.env.aws
ExecStartPre=/data/dalston/ecr-login.sh
ExecStart=/bin/bash -c 'cd /data/dalston && docker compose ${COMPOSE_FILES} --env-file .env.aws up -d ${COMPOSE_UP_FLAGS} ${CTRL_SERVICES}'
ExecStop=/bin/bash -c 'cd /data/dalston && docker compose ${COMPOSE_FILES} --env-file .env.aws down'
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
SVCEOF

systemctl daemon-reload
systemctl enable dalston.service

echo ""
echo "=========================================="
echo "Dalston bootstrap completed at $(date)"
echo "=========================================="
echo ""
echo "Next steps:"
echo "1. sudo tailscale up"
echo "2. tailscale ip -4"
echo "3. sudo systemctl start dalston"
echo ""
echo "To redeploy: sudo /data/dalston/deploy.sh"
"""

    return header + variables + body


def generate_gpu_worker_user_data(
    s3_bucket: str,
    region: str,
    ctrl_plane_ip: str,
) -> str:
    account_id = aws_account_id(region)
    ecr_registry = f"{account_id}.dkr.ecr.{region}.amazonaws.com"
    hf_token = os.environ.get("HF_TOKEN", "")

    # Part 1: static header
    header = """\
#!/bin/bash
set -euo pipefail
exec > >(tee /var/log/user-data.log) 2>&1
echo "Starting Dalston GPU worker bootstrap at $(date)"
"""

    # Part 2: variables (f-string interpolation)
    variables = f"""\
S3_BUCKET="{s3_bucket}"
AWS_REGION="{region}"
CTRL_PLANE_IP="{ctrl_plane_ip}"
ECR_REGISTRY="{ecr_registry}"
HF_TOKEN="{hf_token}"
"""

    # Part 3: body (raw string — no f-string to avoid bash {brace} conflicts)
    body = r"""
# Install Docker
dnf update -y
dnf install -y docker pciutils
systemctl start docker
systemctl enable docker
usermod -aG docker ec2-user

# Install and auto-join Tailscale
curl -fsSL https://tailscale.com/install.sh | sh
TS_AUTH_KEY=$(aws ssm get-parameter \
  --name "/dalston/tailscale-auth-key" \
  --with-decryption \
  --query "Parameter.Value" \
  --output text --region "$AWS_REGION") || true
if [ -n "$TS_AUTH_KEY" ]; then
  tailscale up --authkey="$TS_AUTH_KEY" --hostname="dalston-gpu-worker"
  echo "Tailscale joined as dalston-gpu-worker"
else
  echo "WARNING: No Tailscale auth key in SSM. Run 'sudo tailscale up' manually."
fi

# NVIDIA runtime
if lspci | grep -qi nvidia; then
  curl -fsSL https://nvidia.github.io/libnvidia-container/stable/rpm/nvidia-container-toolkit.repo \
    -o /etc/yum.repos.d/nvidia-container-toolkit.repo
  dnf install -y nvidia-container-toolkit || true
  if command -v nvidia-ctk >/dev/null 2>&1; then
    nvidia-ctk runtime configure --runtime=docker
    systemctl restart docker
  fi
fi

# Mount instance store NVMe for model cache (free 125 GB on g4dn)
NVME_DEV="/dev/nvme1n1"
if [ -b "$NVME_DEV" ]; then
  echo "Mounting instance store NVMe at /data/models..."
  mkfs.xfs "$NVME_DEV"
  mkdir -p /data/models
  mount "$NVME_DEV" /data/models
else
  echo "No instance store NVMe found, using root volume for models"
  mkdir -p /data/models
fi
chown -R 1000:1000 /data/models

# ECR login
aws ecr get-login-password --region "$AWS_REGION" | docker login --username AWS --password-stdin "$ECR_REGISTRY"

# Pull images
docker pull "$ECR_REGISTRY/dalston/stt-onnx:latest"
docker pull "$ECR_REGISTRY/dalston/stt-diarize-pyannote:latest"

mkdir -p /opt/dalston

# GPU worker start script
cat > /opt/dalston/gpu-start.sh << 'STARTEOF'
#!/bin/bash
set -euo pipefail
source /opt/dalston/gpu-env.sh

aws ecr get-login-password --region "$AWS_REGION" | docker login --username AWS --password-stdin "$ECR_REGISTRY"

docker pull "$ECR_REGISTRY/dalston/stt-onnx:latest"
docker pull "$ECR_REGISTRY/dalston/stt-diarize-pyannote:latest"

# Stop existing containers if running
docker rm -f stt-transcribe-onnx stt-diarize-pyannote-4-0 2>/dev/null || true

docker run -d --name stt-transcribe-onnx --gpus all --restart unless-stopped \
  -v /data/models:/data/models \
  -e DALSTON_DEVICE=cuda \
  -e DALSTON_ENGINE_ID=onnx \
  -e REDIS_URL="redis://${CTRL_PLANE_IP}:6379" \
  -e DALSTON_S3_BUCKET="$S3_BUCKET" \
  -e DALSTON_S3_REGION="$AWS_REGION" \
  -e AWS_REGION="$AWS_REGION" \
  -e HF_HOME=/data/models \
  "$ECR_REGISTRY/dalston/stt-onnx:latest"

docker run -d --name stt-diarize-pyannote-4-0 --gpus all --restart unless-stopped \
  -v /data/models:/data/models \
  -e DALSTON_DEVICE=cuda \
  -e DALSTON_ENGINE_ID=pyannote-4.0 \
  -e DALSTON_WORKER_ID=pyannote-gpu-1 \
  -e HF_TOKEN="$HF_TOKEN" \
  -e REDIS_URL="redis://${CTRL_PLANE_IP}:6379" \
  -e DALSTON_S3_BUCKET="$S3_BUCKET" \
  -e DALSTON_S3_REGION="$AWS_REGION" \
  -e AWS_REGION="$AWS_REGION" \
  -e HF_HOME=/data/models \
  "$ECR_REGISTRY/dalston/stt-diarize-pyannote:latest"

echo "GPU engines started at $(date)"
STARTEOF
chmod +x /opt/dalston/gpu-start.sh

# Save env for the start script
cat > /opt/dalston/gpu-env.sh << ENVEOF
S3_BUCKET="${S3_BUCKET}"
AWS_REGION="${AWS_REGION}"
CTRL_PLANE_IP="${CTRL_PLANE_IP}"
ECR_REGISTRY="${ECR_REGISTRY}"
HF_TOKEN="${HF_TOKEN}"
ENVEOF

# GPU worker systemd service
cat > /etc/systemd/system/dalston-gpu.service << SVCEOF
[Unit]
Description=Dalston GPU Worker
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/opt/dalston/gpu-start.sh
ExecStop=/usr/bin/docker rm -f stt-transcribe-onnx stt-diarize-pyannote-4-0
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
SVCEOF

systemctl daemon-reload
systemctl enable dalston-gpu.service

echo ""
echo "=========================================="
echo "GPU worker bootstrap completed at $(date)"
echo "=========================================="
echo ""
echo "Next steps:"
echo "1. sudo tailscale up"
echo "2. sudo systemctl start dalston-gpu"
"""

    return header + variables + body


# ---------------------------------------------------------------------------
# AMI lookup
# ---------------------------------------------------------------------------


def get_latest_ami(region: str) -> str:
    resp = ec2_client(region).describe_images(
        Owners=["amazon"],
        Filters=[
            {"Name": "name", "Values": ["al2023-ami-*-x86_64"]},
            {"Name": "virtualization-type", "Values": ["hvm"]},
        ],
    )
    images = sorted(resp["Images"], key=lambda i: i["CreationDate"])
    if not images:
        die("No AL2023 AMI found")
    return images[-1]["ImageId"]


# ---------------------------------------------------------------------------
# Instance launch
# ---------------------------------------------------------------------------


def launch_instance(
    region: str,
    instance_type: str,
    sg_id: str,
    user_data: str,
    name_tag: str,
    use_spot: bool,
    key_name: str,
    instance_profile: str,
) -> str:
    """Launch an EC2 instance, trying each AZ in the default VPC.

    Returns the instance ID on success or raises on failure.
    """
    ec2 = ec2_client(region)
    ami_id = get_latest_ami(region)
    vpc_id = get_default_vpc(region)

    resp = ec2.describe_subnets(Filters=[{"Name": "vpc-id", "Values": [vpc_id]}])
    subnets = [s["SubnetId"] for s in resp.get("Subnets", [])]
    if not subnets:
        die(f"No subnets found in VPC {vpc_id}")

    encoded_user_data = base64.b64encode(user_data.encode()).decode()

    for subnet_id in subnets:
        sub_resp = ec2.describe_subnets(SubnetIds=[subnet_id])
        az = sub_resp["Subnets"][0]["AvailabilityZone"]

        run_kwargs: dict = {
            "ImageId": ami_id,
            "InstanceType": instance_type,
            "KeyName": key_name,
            "SecurityGroupIds": [sg_id],
            "SubnetId": subnet_id,
            "IamInstanceProfile": {"Name": instance_profile},
            "UserData": encoded_user_data,
            "MinCount": 1,
            "MaxCount": 1,
            "BlockDeviceMappings": [
                {
                    "DeviceName": "/dev/xvda",
                    "Ebs": {
                        "VolumeSize": ROOT_VOLUME_SIZE,
                        "VolumeType": "gp3",
                        "Encrypted": True,
                        "DeleteOnTermination": True,
                    },
                }
            ],
            "TagSpecifications": [
                {
                    "ResourceType": "instance",
                    "Tags": [
                        {"Key": "Name", "Value": name_tag},
                        {"Key": "Project", "Value": "dalston"},
                    ],
                }
            ],
        }

        if use_spot:
            run_kwargs["InstanceMarketOptions"] = {
                "MarketType": "spot",
                "SpotOptions": {
                    "SpotInstanceType": "one-time",
                    "InstanceInterruptionBehavior": "terminate",
                },
            }

        log(f"Trying AZ {az} (subnet {subnet_id})...")
        try:
            result = ec2.run_instances(**run_kwargs)
            iid = result["Instances"][0]["InstanceId"]
            log(f"Launched in {az}: {iid}")
            return iid
        except ClientError as e:
            code = e.response["Error"]["Code"]
            if code in (
                "InsufficientInstanceCapacity",
                "SpotMaxPriceTooLow",
                "Unsupported",
            ):
                warn(f"No capacity in {az}, trying next AZ...")
                continue
            raise

    raise RuntimeError(f"Failed to launch {instance_type} in any AZ.")


# ---------------------------------------------------------------------------
# List GPU spot instances
# ---------------------------------------------------------------------------


def list_gpu_spot_instances(region: str) -> None:
    log(f"Available GPU spot instances in {region}:")
    print()
    header_fmt = "  {:<20s} {:<8s} {:<10s} {:<18s} {:s}"
    print(header_fmt.format("INSTANCE TYPE", "vCPUs", "RAM (GiB)", "GPUs", "SPOT $/hr"))
    print(header_fmt.format("-------------", "-----", "---------", "----", "---------"))

    ec2 = ec2_client(region)

    # Paginate through all instance types with GPU
    paginator = ec2.get_paginator("describe_instance_types")
    gpu_types: list[dict] = []
    for page in paginator.paginate(
        Filters=[
            {"Name": "processor-info.supported-architectures", "Values": ["x86_64"]}
        ]
    ):
        for it in page["InstanceTypes"]:
            if it.get("GpuInfo"):
                gpu_types.append(it)

    gpu_types.sort(key=lambda t: t["InstanceType"])

    for it in gpu_types:
        itype = it["InstanceType"]
        vcpus = it["VCpuInfo"]["DefaultVCpus"]
        mem_gib = it["MemoryInfo"]["SizeInMiB"] // 1024
        gpu_info = it["GpuInfo"]["Gpus"][0]
        gpu_count = gpu_info["Count"]
        gpu_name = gpu_info["Name"]

        try:
            sp_resp = ec2.describe_spot_price_history(
                InstanceTypes=[itype],
                ProductDescriptions=["Linux/UNIX"],
                MaxResults=1,
            )
            prices = sp_resp.get("SpotPriceHistory", [])
            if not prices:
                continue
            spot_price = prices[0]["SpotPrice"]
        except ClientError:
            continue

        print(
            header_fmt.format(
                itype,
                str(vcpus),
                str(mem_gib),
                f"{gpu_count}x {gpu_name}",
                f"${spot_price}",
            )
        )
    print()


# ---------------------------------------------------------------------------
# Interactive GPU launch with retry
# ---------------------------------------------------------------------------


def launch_gpu_interactive(
    region: str,
    sg_id: str,
    user_data: str,
    name_tag: str,
    use_spot: bool,
    key_name: str,
    instance_profile: str,
    gpu_type: str,
) -> str:
    """Launch GPU worker with interactive retry on capacity failure."""
    while True:
        try:
            return launch_instance(
                region,
                gpu_type,
                sg_id,
                user_data,
                name_tag,
                use_spot,
                key_name,
                instance_profile,
            )
        except RuntimeError:
            print()
            list_gpu_spot_instances(region)
            try:
                choice = input(
                    "Enter instance type to retry (or 'q' to quit): "
                ).strip()
            except (EOFError, KeyboardInterrupt):
                die("GPU worker launch aborted.")
            if not choice or choice == "q":
                die("GPU worker launch aborted.")
            gpu_type = choice


# ---------------------------------------------------------------------------
# EBS data volume
# ---------------------------------------------------------------------------


def create_and_attach_data_volume(region: str, instance_id: str) -> str:
    ec2 = ec2_client(region)

    resp = ec2.describe_instances(InstanceIds=[instance_id])
    az = resp["Reservations"][0]["Instances"][0]["Placement"]["AvailabilityZone"]

    vol_resp = ec2.create_volume(
        AvailabilityZone=az,
        Size=DATA_VOLUME_SIZE,
        VolumeType="gp3",
        Encrypted=True,
        TagSpecifications=[
            {
                "ResourceType": "volume",
                "Tags": [
                    {"Key": "Name", "Value": f"{NAME_PREFIX}-data"},
                    {"Key": "Project", "Value": "dalston"},
                ],
            }
        ],
    )
    vol_id = vol_resp["VolumeId"]

    log(f"Waiting for volume {vol_id} to be available...")
    waiter = ec2.get_waiter("volume_available")
    waiter.wait(VolumeIds=[vol_id])

    ec2.attach_volume(
        VolumeId=vol_id,
        InstanceId=instance_id,
        Device="/dev/xvdf",
    )

    return vol_id


# ---------------------------------------------------------------------------
# Cancel spot requests before termination
# ---------------------------------------------------------------------------


def cancel_spot_requests_for_instances(region: str, instance_ids: list[str]) -> None:
    """Cancel any active spot instance requests for the given instances."""
    ec2 = ec2_client(region)
    try:
        resp = ec2.describe_spot_instance_requests(
            Filters=[{"Name": "instance-id", "Values": instance_ids}]
        )
        sir_ids = [
            r["SpotInstanceRequestId"]
            for r in resp.get("SpotInstanceRequests", [])
            if r.get("State") in ("open", "active")
        ]
        if sir_ids:
            log(f"Cancelling spot requests: {', '.join(sir_ids)}")
            ec2.cancel_spot_instance_requests(SpotInstanceRequestIds=sir_ids)
    except ClientError:
        pass


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------


def cmd_setup(args: argparse.Namespace) -> None:
    region = args.region
    scenario = args.scenario
    use_spot = args.spot
    gpu_type = args.gpu_type
    key_name = args.key or f"{NAME_PREFIX}-key"

    # Check AWS credentials
    try:
        aws_account_id(region)
    except Exception:
        die("AWS credentials not configured. Run 'aws configure' first.")

    # Idempotency check
    existing = load_state()
    if existing and existing.instance_id:
        state = get_instance_state(existing.region, existing.instance_id)
        if state in ("running", "stopped"):
            log(f"Existing deployment found: {existing.instance_id} (state={state})")
            log("Infrastructure resources (S3, IAM, SG) will be verified.")
            log(
                "Instance will NOT be re-created. Use 'dalston-aws teardown' first to start fresh."
            )
            print()

            vpc_id = get_instance_vpc(existing.region, existing.instance_id)
            existing.s3_bucket = create_s3_bucket(existing.region)
            existing.iam_role, existing.instance_profile = create_iam_role(
                existing.region, existing.s3_bucket
            )
            existing.key_name = ensure_key_pair(
                existing.region, existing.key_name or key_name
            )
            existing.sg_id = create_security_group(existing.region, vpc_id)
            save_state(existing)
            cmd_status_impl(existing)
            return
        log(
            f"Previous instance {existing.instance_id} is {state}. Will create a new one."
        )

    account_id = aws_account_id(region)
    vpc_id = get_default_vpc(region)

    print()
    log("Setting up Dalston on AWS")
    log(f"  Region:   {region}")
    log(f"  Scenario: {scenario}")
    log(f"  Spot:     {use_spot}")
    log(f"  Account:  {account_id}")
    print()

    st = DeploymentState(region=region, scenario=scenario, key_name=key_name)

    # 1. S3 bucket
    st.s3_bucket = create_s3_bucket(region)

    # 2. IAM role
    st.iam_role, st.instance_profile = create_iam_role(region, st.s3_bucket)

    # 3. Key pair
    st.key_name = ensure_key_pair(region, key_name)

    # 4. Security group
    st.sg_id = create_security_group(region, vpc_id)

    # 5. Launch instances
    if scenario == "cpu":
        log(f"Launching CPU instance ({CPU_INSTANCE_TYPE})...")
        ud = generate_user_data(st.s3_bucket, region, "--profile local-infra")
        st.instance_id = launch_instance(
            region,
            CPU_INSTANCE_TYPE,
            st.sg_id,
            ud,
            f"{NAME_PREFIX}-server",
            use_spot,
            st.key_name,
            st.instance_profile,
        )
        wait_instance_running(region, st.instance_id)
        st.data_volume_id = create_and_attach_data_volume(region, st.instance_id)

    elif scenario == "gpu":
        log(f"Launching GPU instance ({gpu_type})...")
        ud = generate_user_data(
            st.s3_bucket, region, "--profile local-infra --profile gpu"
        )
        st.instance_id = launch_instance(
            region,
            gpu_type,
            st.sg_id,
            ud,
            f"{NAME_PREFIX}-server",
            use_spot,
            st.key_name,
            st.instance_profile,
        )
        wait_instance_running(region, st.instance_id)
        st.data_volume_id = create_and_attach_data_volume(region, st.instance_id)

    elif scenario == "split":
        # Control plane — always on-demand, uses ECR images
        log(f"Launching control plane ({CTRL_INSTANCE_TYPE})...")
        ctrl_ud = generate_user_data(
            st.s3_bucket, region, "--profile local-infra", use_ecr=True
        )
        st.instance_id = launch_instance(
            region,
            CTRL_INSTANCE_TYPE,
            st.sg_id,
            ctrl_ud,
            f"{NAME_PREFIX}-control-plane",
            False,  # always on-demand
            st.key_name,
            st.instance_profile,
        )
        wait_instance_running(region, st.instance_id)
        st.data_volume_id = create_and_attach_data_volume(region, st.instance_id)

        ctrl_private_ip = get_instance_private_ip(region, st.instance_id)

        # GPU worker security group
        st.gpu_sg_id = create_gpu_worker_security_group(region, vpc_id)
        open_control_plane_ports(region, st.sg_id, st.gpu_sg_id)

        # GPU worker
        gpu_ud = generate_gpu_worker_user_data(st.s3_bucket, region, ctrl_private_ip)
        st.gpu_instance_id = launch_gpu_interactive(
            region,
            st.gpu_sg_id,
            gpu_ud,
            f"{NAME_PREFIX}-gpu-worker",
            use_spot,
            st.key_name,
            st.instance_profile,
            gpu_type,
        )
        wait_instance_running(region, st.gpu_instance_id)
        st.gpu_data_volume_id = ""  # GPU uses NVMe instance store

    save_state(st)

    # Summary
    print()
    print("==========================================")
    log("Setup complete!")
    print("==========================================")
    print()
    log(f"Instance: {st.instance_id} ({get_instance_ip(region, st.instance_id)})")
    if scenario == "split":
        log(
            f"GPU worker: {st.gpu_instance_id} ({get_instance_ip(region, st.gpu_instance_id)})"
        )
    print()
    log("Next steps:")
    ip = get_instance_ip(region, st.instance_id)
    print("  1. SSH to the instance:")
    print(f"     ssh -i {STATE_DIR / st.key_name}.pem ec2-user@{ip}")
    print("  2. Set up Tailscale:")
    print("     sudo tailscale up")
    print("  3. Clone your repo to /data/dalston and start:")
    print("     sudo systemctl start dalston")
    print()
    log("Management commands:")
    print("  dalston-aws status   # Check instance state")
    print("  dalston-aws up       # Start instance(s)")
    print("  dalston-aws down     # Stop instance(s)")
    print("  dalston-aws ssh      # SSH via Tailscale")
    print("  dalston-aws teardown # Remove everything")


def cmd_status_impl(st: DeploymentState) -> None:
    print()
    log("Dalston AWS Deployment")
    log(f"  Scenario: {st.scenario}")
    log(f"  Region:   {st.region}")
    log(f"  S3:       {st.s3_bucket}")
    print()

    state = get_instance_state(st.region, st.instance_id)
    ip = get_instance_ip(st.region, st.instance_id)
    label = "Control plane" if st.scenario == "split" else "Instance"
    log(f"  {label}: {st.instance_id}  state={state}  ip={ip or 'none'}")

    if st.scenario == "split" and st.gpu_instance_id:
        gpu_state = get_instance_state(st.region, st.gpu_instance_id)
        gpu_ip = get_instance_ip(st.region, st.gpu_instance_id)
        log(
            f"  GPU worker:     {st.gpu_instance_id}  state={gpu_state}  ip={gpu_ip or 'none'}"
        )
    print()


def cmd_status(args: argparse.Namespace) -> None:
    st = require_state()
    cmd_status_impl(st)


def cmd_up(args: argparse.Namespace) -> None:
    st = require_state()
    log("Starting instance(s)...")
    ec2 = ec2_client(st.region)
    retry_aws(ec2.start_instances, InstanceIds=[st.instance_id])
    if st.scenario == "split" and st.gpu_instance_id:
        retry_aws(ec2.start_instances, InstanceIds=[st.gpu_instance_id])
    log("Start command sent. Instances booting...")


def cmd_down(args: argparse.Namespace) -> None:
    st = require_state()
    log("Stopping instance(s)...")
    ec2 = ec2_client(st.region)
    ec2.stop_instances(InstanceIds=[st.instance_id])
    if st.scenario == "split" and st.gpu_instance_id:
        ec2.stop_instances(InstanceIds=[st.gpu_instance_id])
    log("Stop command sent.")


def cmd_ssh(args: argparse.Namespace) -> None:
    st = require_state()

    if args.target == "gpu":
        if st.scenario != "split" or not st.gpu_instance_id:
            die("No GPU worker found. Use 'dalston-aws ssh' for the main instance.")
        hostname = "dalston-gpu-worker"
    else:
        hostname = "dalston-control-plane"

    key_file = STATE_DIR / f"{st.key_name}.pem"
    ssh_args = ["ssh"]
    if key_file.exists():
        ssh_args += ["-i", str(key_file)]
    ssh_args.append(f"ec2-user@{hostname}")

    log(f"Connecting to {hostname} via Tailscale SSH...")
    os.execvp("ssh", ssh_args)


def cmd_add_gpu(args: argparse.Namespace) -> None:
    st = require_state()
    use_spot = args.spot
    gpu_type = args.gpu_type

    if st.gpu_instance_id:
        gpu_state = get_instance_state(st.region, st.gpu_instance_id)
        if gpu_state != "terminated":
            die(
                f"GPU worker already exists ({st.gpu_instance_id}, state={gpu_state}). "
                "Use 'dalston-aws remove-gpu' first."
            )

    main_state = get_instance_state(st.region, st.instance_id)
    if main_state != "running":
        die(
            f"Main instance {st.instance_id} is {main_state}. Run 'dalston-aws up' first."
        )

    ctrl_private_ip = get_instance_private_ip(st.region, st.instance_id)
    vpc_id = get_instance_vpc(st.region, st.instance_id)

    log("Adding GPU worker to existing deployment")
    log(f"  Main instance: {st.instance_id} ({ctrl_private_ip})")
    log(f"  GPU type:      {gpu_type}")
    log(f"  Spot:          {use_spot}")
    print()

    # GPU worker security group
    st.gpu_sg_id = create_gpu_worker_security_group(st.region, vpc_id)
    open_control_plane_ports(st.region, st.sg_id, st.gpu_sg_id)

    # Launch GPU worker
    gpu_ud = generate_gpu_worker_user_data(st.s3_bucket, st.region, ctrl_private_ip)
    st.gpu_instance_id = launch_gpu_interactive(
        st.region,
        st.gpu_sg_id,
        gpu_ud,
        f"{NAME_PREFIX}-gpu-worker",
        use_spot,
        st.key_name,
        st.instance_profile,
        gpu_type,
    )
    wait_instance_running(st.region, st.gpu_instance_id)
    st.gpu_data_volume_id = ""  # GPU uses NVMe instance store

    st.scenario = "split"
    save_state(st)

    print()
    print("==========================================")
    log("GPU worker added!")
    print("==========================================")
    print()
    log(
        f"GPU worker: {st.gpu_instance_id} ({get_instance_ip(st.region, st.gpu_instance_id)})"
    )
    print()
    log("Next steps on the GPU worker:")
    print("  1. SSH: dalston-aws ssh gpu")
    print("  2. sudo tailscale up")
    print("  3. Update .env.gpu REDIS_URL/DATABASE_URL with control plane Tailscale IP")
    print("  4. sudo systemctl start dalston-gpu")


def cmd_remove_gpu(args: argparse.Namespace) -> None:
    st = require_state()

    if not st.gpu_instance_id:
        die("No GPU worker found. Nothing to remove.")

    gpu_state = get_instance_state(st.region, st.gpu_instance_id)
    if gpu_state == "terminated":
        log("GPU worker already terminated. Cleaning up state...")
        st.gpu_instance_id = ""
        st.gpu_data_volume_id = ""
        st.gpu_sg_id = ""
        main_type = get_instance_type(st.region, st.instance_id)
        st.scenario = "gpu" if main_type.startswith(("g", "p")) else "cpu"
        save_state(st)
        log("State cleaned up.")
        return

    warn(
        f"This will terminate GPU worker {st.gpu_instance_id} and delete its data volume."
    )
    confirm = input("Type 'yes' to confirm: ").strip()
    if confirm != "yes":
        die("Aborted.")

    ec2 = ec2_client(st.region)

    # Cancel spot requests before terminating
    cancel_spot_requests_for_instances(st.region, [st.gpu_instance_id])

    log(f"Terminating GPU worker {st.gpu_instance_id}...")
    try:
        ec2.terminate_instances(InstanceIds=[st.gpu_instance_id])
    except ClientError:
        pass
    wait_instance_terminated(st.region, st.gpu_instance_id)

    if st.gpu_data_volume_id:
        log(f"Deleting GPU data volume {st.gpu_data_volume_id}...")
        try:
            ec2.delete_volume(VolumeId=st.gpu_data_volume_id)
        except ClientError:
            pass

    if st.gpu_sg_id:
        log(f"Deleting GPU security group {st.gpu_sg_id}...")
        time.sleep(3)
        try:
            ec2.delete_security_group(GroupId=st.gpu_sg_id)
        except ClientError:
            pass

    main_type = get_instance_type(st.region, st.instance_id)
    st.scenario = "gpu" if main_type.startswith(("g", "p")) else "cpu"
    st.gpu_instance_id = ""
    st.gpu_data_volume_id = ""
    st.gpu_sg_id = ""
    save_state(st)

    log(f"GPU worker removed. Deployment is now single-instance ({st.scenario}).")


def cmd_teardown(args: argparse.Namespace) -> None:
    st = require_state()

    print()
    warn("This will PERMANENTLY DELETE all Dalston AWS resources:")
    instance_list = st.instance_id
    if st.gpu_instance_id:
        instance_list += f" {st.gpu_instance_id}"
    warn(f"  - EC2 instance(s): {instance_list}")
    volume_list = st.data_volume_id
    if st.gpu_data_volume_id:
        volume_list += f" {st.gpu_data_volume_id}"
    warn(f"  - EBS volumes: {volume_list}")
    warn(f"  - S3 bucket: {st.s3_bucket} (contents preserved -- delete manually)")
    warn(f"  - IAM role: {st.iam_role}")
    sg_list = st.sg_id
    if st.gpu_sg_id:
        sg_list += f" {st.gpu_sg_id}"
    warn(f"  - Security group(s): {sg_list}")
    print()
    confirm = input("Type 'yes' to confirm: ").strip()
    if confirm != "yes":
        die("Aborted.")

    ec2 = ec2_client(st.region)
    iam = iam_client()

    # Cancel spot requests before terminating
    ids_to_cancel = [st.instance_id]
    if st.gpu_instance_id:
        ids_to_cancel.append(st.gpu_instance_id)
    cancel_spot_requests_for_instances(st.region, ids_to_cancel)

    # Terminate instances
    log("Terminating instances...")
    try:
        ec2.terminate_instances(InstanceIds=[st.instance_id])
    except ClientError:
        pass
    if st.gpu_instance_id:
        try:
            ec2.terminate_instances(InstanceIds=[st.gpu_instance_id])
        except ClientError:
            pass

    log("Waiting for termination...")
    wait_instance_terminated(st.region, st.instance_id)
    if st.gpu_instance_id:
        wait_instance_terminated(st.region, st.gpu_instance_id)

    # Delete data volumes
    log("Deleting data volumes...")
    if st.data_volume_id:
        try:
            ec2.delete_volume(VolumeId=st.data_volume_id)
        except ClientError:
            pass
    if st.gpu_data_volume_id:
        try:
            ec2.delete_volume(VolumeId=st.gpu_data_volume_id)
        except ClientError:
            pass

    # Delete security groups
    log("Deleting security groups...")
    time.sleep(5)
    if st.sg_id:
        try:
            ec2.delete_security_group(GroupId=st.sg_id)
        except ClientError:
            pass
    if st.gpu_sg_id:
        try:
            ec2.delete_security_group(GroupId=st.gpu_sg_id)
        except ClientError:
            pass

    # Delete IAM resources
    log("Deleting IAM role...")
    profile_name = st.instance_profile or f"{NAME_PREFIX}-instance-profile"
    role_name = st.iam_role or f"{NAME_PREFIX}-ec2-role"
    try:
        iam.remove_role_from_instance_profile(
            InstanceProfileName=profile_name,
            RoleName=role_name,
        )
    except ClientError:
        pass
    try:
        iam.delete_instance_profile(InstanceProfileName=profile_name)
    except ClientError:
        pass
    for policy_name in (
        f"{NAME_PREFIX}-s3-access",
        f"{NAME_PREFIX}-ecr-access",
        f"{NAME_PREFIX}-ssm-access",
    ):
        try:
            iam.delete_role_policy(RoleName=role_name, PolicyName=policy_name)
        except ClientError:
            pass
    try:
        iam.delete_role(RoleName=role_name)
    except ClientError:
        pass

    warn(f"S3 bucket {st.s3_bucket} was NOT deleted (may contain transcription data).")
    warn(f"To delete: aws s3 rb s3://{st.s3_bucket} --force")

    # Clean up state
    STATE_FILE.unlink(missing_ok=True)
    log("Teardown complete.")


# ---------------------------------------------------------------------------
# Argument parser
# ---------------------------------------------------------------------------


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="dalston-aws",
        description="Provision and manage Dalston on AWS without Terraform.",
    )
    sub = parser.add_subparsers(dest="command")

    # setup
    p_setup = sub.add_parser(
        "setup", help="Provision AWS resources and launch instance(s)"
    )
    scenario_group = p_setup.add_mutually_exclusive_group()
    scenario_group.add_argument(
        "--cpu", dest="scenario", action="store_const", const="cpu"
    )
    scenario_group.add_argument(
        "--gpu", dest="scenario", action="store_const", const="gpu"
    )
    scenario_group.add_argument(
        "--split", dest="scenario", action="store_const", const="split"
    )
    p_setup.set_defaults(scenario="gpu")
    p_setup.add_argument("--spot", action="store_true", help="Use spot pricing")
    p_setup.add_argument(
        "--region", default=os.environ.get("AWS_REGION", DEFAULT_REGION)
    )
    p_setup.add_argument("--key", default=None, help="Existing SSH key pair name")
    p_setup.add_argument(
        "--gpu-type", default=GPU_INSTANCE_TYPE, help="GPU instance type"
    )
    p_setup.set_defaults(func=cmd_setup)

    # teardown
    p_teardown = sub.add_parser("teardown", help="Remove all AWS resources")
    p_teardown.set_defaults(func=cmd_teardown)

    # status
    p_status = sub.add_parser("status", help="Show instance state")
    p_status.set_defaults(func=cmd_status)

    # up
    p_up = sub.add_parser("up", help="Start instance(s)")
    p_up.set_defaults(func=cmd_up)

    # down
    p_down = sub.add_parser("down", help="Stop instance(s)")
    p_down.set_defaults(func=cmd_down)

    # ssh
    p_ssh = sub.add_parser("ssh", help="SSH to instance via Tailscale")
    p_ssh.add_argument(
        "target",
        nargs="?",
        default="main",
        choices=["main", "gpu"],
        help="Which instance to connect to (default: main)",
    )
    p_ssh.set_defaults(func=cmd_ssh)

    # add-gpu
    p_add = sub.add_parser("add-gpu", help="Add a GPU worker to existing deployment")
    p_add.add_argument("--spot", action="store_true", help="Use spot pricing")
    p_add.add_argument(
        "--gpu-type", default=GPU_INSTANCE_TYPE, help="GPU instance type"
    )
    p_add.set_defaults(func=cmd_add_gpu)

    # remove-gpu
    p_remove = sub.add_parser("remove-gpu", help="Remove the GPU worker")
    p_remove.set_defaults(func=cmd_remove_gpu)

    return parser


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(0)

    args.func(args)


if __name__ == "__main__":
    main()
