#!/usr/bin/env bash
set -euo pipefail

# dalston-aws — provision and manage Dalston on AWS without Terraform
#
# Usage:
#   dalston-aws setup                  # Single GPU instance (Scenario 2, default)
#   dalston-aws setup --cpu            # CPU-only instance (Scenario 1)
#   dalston-aws setup --split          # Two-tier: CPU control plane + GPU worker (Scenario 5)
#   dalston-aws setup --spot           # Use spot pricing (combine with any scenario)
#   dalston-aws add-gpu [--spot]        # Add a GPU worker to existing deployment
#   dalston-aws remove-gpu              # Remove the GPU worker
#   dalston-aws teardown               # Remove all AWS resources
#   dalston-aws status                 # Show instance state
#   dalston-aws up                     # Start instance(s)
#   dalston-aws down                   # Stop instance(s)
#   dalston-aws ssh [gpu]              # SSH via Tailscale (default: main instance, "gpu" for GPU worker)
#
# Prerequisites:
#   - AWS CLI configured (aws sts get-caller-identity should work)
#   - An SSH key pair in AWS (or the script creates one)
#
# The script creates: S3 bucket, IAM role + instance profile, security group,
# EC2 instance(s) with EBS data volume. All resources tagged with Project=dalston.

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
readonly STATE_DIR="${HOME}/.dalston"
readonly STATE_FILE="${STATE_DIR}/aws-state.env"

# Defaults
REGION="${AWS_REGION:-eu-west-2}"
NAME_PREFIX="dalston"
DATA_VOLUME_SIZE=50
ROOT_VOLUME_SIZE=30
REPO_URL=""
REPO_BRANCH="main"

# Scenario defaults
SCENARIO="gpu"  # gpu, cpu, split
USE_SPOT=false
USE_RIVA=false
GPU_INSTANCE_TYPE="g5.xlarge"
CPU_INSTANCE_TYPE="t3.xlarge"
CTRL_INSTANCE_TYPE="t3.medium"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log()  { echo -e "${GREEN}[dalston-aws]${NC} $*"; }
warn() { echo -e "${YELLOW}[dalston-aws]${NC} $*"; }
err()  { echo -e "${RED}[dalston-aws]${NC} $*" >&2; }
die()  { err "$@"; exit 1; }

# ============================================================
# STATE MANAGEMENT
# ============================================================

save_state() {
    mkdir -p "$STATE_DIR"
    cat > "$STATE_FILE" << EOF
# dalston-aws state — auto-generated, do not edit
DALSTON_REGION=${REGION}
DALSTON_SCENARIO=${SCENARIO}
DALSTON_S3_BUCKET=${S3_BUCKET:-}
DALSTON_IAM_ROLE=${IAM_ROLE:-}
DALSTON_INSTANCE_PROFILE=${INSTANCE_PROFILE:-}
DALSTON_SG_ID=${SG_ID:-}
DALSTON_INSTANCE_ID=${INSTANCE_ID:-}
DALSTON_DATA_VOLUME_ID=${DATA_VOLUME_ID:-}
DALSTON_GPU_INSTANCE_ID=${GPU_INSTANCE_ID:-}
DALSTON_GPU_DATA_VOLUME_ID=${GPU_DATA_VOLUME_ID:-}
DALSTON_GPU_SG_ID=${GPU_SG_ID:-}
DALSTON_KEY_NAME=${KEY_NAME:-}
EOF
    log "State saved to $STATE_FILE"
}

load_state() {
    if [[ ! -f "$STATE_FILE" ]]; then
        return 1
    fi
    # shellcheck source=/dev/null
    source "$STATE_FILE"
    REGION="${DALSTON_REGION}"
    SCENARIO="${DALSTON_SCENARIO}"
    S3_BUCKET="${DALSTON_S3_BUCKET}"
    IAM_ROLE="${DALSTON_IAM_ROLE}"
    INSTANCE_PROFILE="${DALSTON_INSTANCE_PROFILE}"
    SG_ID="${DALSTON_SG_ID}"
    INSTANCE_ID="${DALSTON_INSTANCE_ID}"
    DATA_VOLUME_ID="${DALSTON_DATA_VOLUME_ID}"
    GPU_INSTANCE_ID="${DALSTON_GPU_INSTANCE_ID:-}"
    GPU_DATA_VOLUME_ID="${DALSTON_GPU_DATA_VOLUME_ID:-}"
    GPU_SG_ID="${DALSTON_GPU_SG_ID:-}"
    KEY_NAME="${DALSTON_KEY_NAME}"
    return 0
}

require_state() {
    load_state || die "No deployment found. Run 'dalston-aws setup' first."
}

# ============================================================
# AWS HELPERS
# ============================================================

aws_account_id() {
    aws sts get-caller-identity --query Account --output text --region "$REGION"
}

wait_instance_running() {
    local instance_id="$1"
    log "Waiting for $instance_id to be running..."
    aws ec2 wait instance-running --instance-ids "$instance_id" --region "$REGION"
}

get_instance_state() {
    local instance_id="$1"
    aws ec2 describe-instances \
        --instance-ids "$instance_id" \
        --query 'Reservations[0].Instances[0].State.Name' \
        --output text \
        --region "$REGION" 2>/dev/null || echo "terminated"
}

get_instance_ip() {
    local instance_id="$1"
    aws ec2 describe-instances \
        --instance-ids "$instance_id" \
        --query 'Reservations[0].Instances[0].PublicIpAddress' \
        --output text \
        --region "$REGION" 2>/dev/null || echo ""
}

retry_aws() {
    local max_retries=4
    local delay=2
    local attempt=1
    while true; do
        if "$@"; then
            return 0
        fi
        if (( attempt >= max_retries )); then
            err "Command failed after $max_retries attempts: $*"
            return 1
        fi
        warn "Attempt $attempt failed, retrying in ${delay}s..."
        sleep "$delay"
        delay=$(( delay * 2 ))
        attempt=$(( attempt + 1 ))
    done
}

# ============================================================
# SETUP: CREATE AWS RESOURCES
# ============================================================

create_s3_bucket() {
    local account_id
    account_id=$(aws_account_id)
    S3_BUCKET="${NAME_PREFIX}-artifacts-${account_id}"

    if aws s3api head-bucket --bucket "$S3_BUCKET" --region "$REGION" 2>/dev/null; then
        log "S3 bucket $S3_BUCKET already exists"
        return 0
    fi

    log "Creating S3 bucket: $S3_BUCKET"

    local create_args=(
        s3api create-bucket
        --bucket "$S3_BUCKET"
        --region "$REGION"
    )
    # LocationConstraint required for non-us-east-1
    if [[ "$REGION" != "us-east-1" ]]; then
        create_args+=(--create-bucket-configuration "LocationConstraint=${REGION}")
    fi
    aws "${create_args[@]}"

    # Block public access
    aws s3api put-public-access-block \
        --bucket "$S3_BUCKET" \
        --public-access-block-configuration \
        "BlockPublicAcls=true,IgnorePublicAcls=true,BlockPublicPolicy=true,RestrictPublicBuckets=true" \
        --region "$REGION"

    # Enable encryption
    aws s3api put-bucket-encryption \
        --bucket "$S3_BUCKET" \
        --server-side-encryption-configuration \
        '{"Rules":[{"ApplyServerSideEncryptionByDefault":{"SSEAlgorithm":"AES256"}}]}' \
        --region "$REGION"

    # Lifecycle: temp/ expires in 7 days, jobs/ in 30 days
    aws s3api put-bucket-lifecycle-configuration \
        --bucket "$S3_BUCKET" \
        --lifecycle-configuration '{
            "Rules": [
                {"ID":"cleanup-temp","Status":"Enabled","Filter":{"Prefix":"temp/"},"Expiration":{"Days":7}},
                {"ID":"cleanup-jobs","Status":"Enabled","Filter":{"Prefix":"jobs/"},"Expiration":{"Days":30}}
            ]
        }' \
        --region "$REGION"

    log "S3 bucket created with encryption + lifecycle rules"
}

create_iam_role() {
    IAM_ROLE="${NAME_PREFIX}-ec2-role"
    INSTANCE_PROFILE="${NAME_PREFIX}-instance-profile"

    local role_exists=false
    if aws iam get-role --role-name "$IAM_ROLE" --no-cli-pager 2>/dev/null; then
        log "IAM role $IAM_ROLE already exists"
        role_exists=true
    fi

    if [[ "$role_exists" == "false" ]]; then
        log "Creating IAM role: $IAM_ROLE"
        aws iam create-role \
            --role-name "$IAM_ROLE" \
            --assume-role-policy-document '{
                "Version":"2012-10-17",
                "Statement":[{
                    "Effect":"Allow",
                    "Principal":{"Service":"ec2.amazonaws.com"},
                    "Action":"sts:AssumeRole"
                }]
            }' \
            --tags "Key=Project,Value=dalston" \
            --no-cli-pager
    fi

    # S3 access policy — put-role-policy is idempotent (upsert)
    local bucket_arn="arn:aws:s3:::${S3_BUCKET}"
    aws iam put-role-policy \
        --role-name "$IAM_ROLE" \
        --policy-name "${NAME_PREFIX}-s3-access" \
        --policy-document "{
            \"Version\":\"2012-10-17\",
            \"Statement\":[
                {\"Effect\":\"Allow\",\"Action\":[\"s3:ListBucket\"],\"Resource\":\"${bucket_arn}\"},
                {\"Effect\":\"Allow\",\"Action\":[\"s3:GetObject\",\"s3:PutObject\",\"s3:DeleteObject\"],\"Resource\":\"${bucket_arn}/*\"}
            ]
        }"

    # Instance profile — check independently (role may exist but profile may not)
    if aws iam get-instance-profile --instance-profile-name "$INSTANCE_PROFILE" --no-cli-pager 2>/dev/null; then
        log "Instance profile $INSTANCE_PROFILE already exists"
    else
        log "Creating instance profile: $INSTANCE_PROFILE"
        aws iam create-instance-profile \
            --instance-profile-name "$INSTANCE_PROFILE" \
            --tags "Key=Project,Value=dalston" \
            --no-cli-pager

        aws iam add-role-to-instance-profile \
            --instance-profile-name "$INSTANCE_PROFILE" \
            --role-name "$IAM_ROLE"

        # IAM is eventually consistent — wait for the instance profile to propagate
        log "Waiting for IAM instance profile to propagate..."
        sleep 10
    fi

    log "IAM role + instance profile ready"
}

create_security_group() {
    local name="${NAME_PREFIX}-sg"
    local vpc_id="$1"

    # Check if it already exists
    local existing
    existing=$(aws ec2 describe-security-groups \
        --filters "Name=group-name,Values=$name" "Name=vpc-id,Values=$vpc_id" \
        --query 'SecurityGroups[0].GroupId' \
        --output text \
        --region "$REGION" 2>/dev/null || echo "None")

    if [[ "$existing" != "None" && -n "$existing" ]]; then
        SG_ID="$existing"
        log "Security group $SG_ID already exists"
        return 0
    fi

    log "Creating security group: $name"
    SG_ID=$(aws ec2 create-security-group \
        --group-name "$name" \
        --description "Dalston EC2 - SSH from Tailscale" \
        --vpc-id "$vpc_id" \
        --query 'GroupId' \
        --output text \
        --region "$REGION")

    # SSH from Tailscale CIDR
    aws ec2 authorize-security-group-ingress \
        --group-id "$SG_ID" \
        --protocol tcp \
        --port 22 \
        --cidr 100.64.0.0/10 \
        --region "$REGION" \
        --no-cli-pager

    aws ec2 create-tags \
        --resources "$SG_ID" \
        --tags "Key=Name,Value=$name" "Key=Project,Value=dalston" \
        --region "$REGION"

    log "Security group $SG_ID created (SSH from Tailscale)"
}

create_gpu_worker_security_group() {
    local name="${NAME_PREFIX}-gpu-sg"
    local vpc_id="$1"

    local existing
    existing=$(aws ec2 describe-security-groups \
        --filters "Name=group-name,Values=$name" "Name=vpc-id,Values=$vpc_id" \
        --query 'SecurityGroups[0].GroupId' \
        --output text \
        --region "$REGION" 2>/dev/null || echo "None")

    if [[ "$existing" != "None" && -n "$existing" ]]; then
        GPU_SG_ID="$existing"
        log "GPU security group $GPU_SG_ID already exists"
        return 0
    fi

    log "Creating GPU worker security group: $name"
    GPU_SG_ID=$(aws ec2 create-security-group \
        --group-name "$name" \
        --description "Dalston GPU worker - SSH from Tailscale" \
        --vpc-id "$vpc_id" \
        --query 'GroupId' \
        --output text \
        --region "$REGION")

    # SSH from Tailscale
    aws ec2 authorize-security-group-ingress \
        --group-id "$GPU_SG_ID" \
        --protocol tcp \
        --port 22 \
        --cidr 100.64.0.0/10 \
        --region "$REGION" \
        --no-cli-pager

    aws ec2 create-tags \
        --resources "$GPU_SG_ID" \
        --tags "Key=Name,Value=$name" "Key=Project,Value=dalston" \
        --region "$REGION"

    # Allow control plane SG to reach GPU worker (for Redis if needed)
    # In split mode, GPU connects out to control plane Redis — no inbound rule needed on GPU.
    # But allow Tailscale range for SSH access.

    log "GPU security group $GPU_SG_ID created"
}

ensure_key_pair() {
    KEY_NAME="${KEY_NAME:-${NAME_PREFIX}-key}"

    if aws ec2 describe-key-pairs --key-names "$KEY_NAME" --region "$REGION" --no-cli-pager 2>/dev/null; then
        log "Key pair $KEY_NAME already exists in AWS"
        return 0
    fi

    log "Creating key pair: $KEY_NAME"
    mkdir -p "$STATE_DIR"
    local key_file="${STATE_DIR}/${KEY_NAME}.pem"
    aws ec2 create-key-pair \
        --key-name "$KEY_NAME" \
        --query 'KeyMaterial' \
        --output text \
        --region "$REGION" > "$key_file"
    chmod 600 "$key_file"
    log "Private key saved to $key_file"
}

generate_user_data() {
    local s3_bucket="$1"
    local compose_profiles="$2"
    local extra_compose_files="${3:-}"  # e.g., "-f docker-compose.riva.yml"

    cat << 'USERDATA_HEADER'
#!/bin/bash
set -euo pipefail
exec > >(tee /var/log/user-data.log) 2>&1
echo "Starting Dalston bootstrap at $(date)"
USERDATA_HEADER

    cat << USERDATA_VARS
DATA_DEVICE="/dev/xvdf"
DATA_MOUNT="/data"
S3_BUCKET="${s3_bucket}"
AWS_REGION="${REGION}"
COMPOSE_PROFILE_FLAGS="${compose_profiles}"
EXTRA_COMPOSE_FILES="${extra_compose_files}"
NGC_API_KEY="${NGC_API_KEY:-}"
USERDATA_VARS

    # Use heredoc for the rest so variables above are expanded but
    # the script body uses its own variables at runtime
    cat << 'USERDATA_BODY'

# Install Docker
echo "Installing Docker..."
dnf update -y
dnf install -y docker git pciutils

# Install Tailscale
echo "Installing Tailscale..."
curl -fsSL https://tailscale.com/install.sh | sh

# Start Docker
systemctl start docker
systemctl enable docker
usermod -aG docker ec2-user

# Install Docker Compose
echo "Installing Docker Compose..."
DOCKER_COMPOSE_VERSION="v2.24.0"
curl -L "https://github.com/docker/compose/releases/download/${DOCKER_COMPOSE_VERSION}/docker-compose-linux-x86_64" \
  -o /usr/local/bin/docker-compose
chmod +x /usr/local/bin/docker-compose
ln -sf /usr/local/bin/docker-compose /usr/bin/docker-compose

# GPU detection and NVIDIA runtime setup
if lspci | grep -qi nvidia; then
  echo "NVIDIA GPU detected. Installing NVIDIA Container Toolkit..."
  curl -fsSL https://nvidia.github.io/libnvidia-container/stable/rpm/nvidia-container-toolkit.repo \
    -o /etc/yum.repos.d/nvidia-container-toolkit.repo
  dnf install -y nvidia-container-toolkit || true
  if command -v nvidia-ctk >/dev/null 2>&1; then
    nvidia-ctk runtime configure --runtime=docker
    systemctl restart docker
    echo "NVIDIA runtime configured."
  else
    echo "WARNING: NVIDIA toolkit installation incomplete."
  fi
fi

# Wait for data volume
echo "Waiting for data volume..."
while [ ! -e "$DATA_DEVICE" ]; do
  sleep 5
done

# Format if needed
if ! blkid "$DATA_DEVICE" | grep -q ext4; then
  echo "Formatting data volume..."
  mkfs.ext4 -L dalston-data "$DATA_DEVICE"
fi

# Mount
mkdir -p "$DATA_MOUNT"
mount "$DATA_DEVICE" "$DATA_MOUNT"
if ! grep -q "$DATA_MOUNT" /etc/fstab; then
  echo "LABEL=dalston-data $DATA_MOUNT ext4 defaults,nofail 0 2" >> /etc/fstab
fi

# Create data directories
mkdir -p "$DATA_MOUNT/postgres" "$DATA_MOUNT/redis" "$DATA_MOUNT/models" "$DATA_MOUNT/dalston" "$DATA_MOUNT/nim-cache"
chown -R 1000:1000 "$DATA_MOUNT"

# Create .env.aws
cat > "$DATA_MOUNT/dalston/.env.aws" << ENVEOF
DALSTON_S3_BUCKET=${S3_BUCKET}
DALSTON_S3_REGION=${AWS_REGION}
AWS_REGION=${AWS_REGION}
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql+asyncpg://dalston:password@postgres:5432/dalston
HF_HOME=/data/models
ENVEOF

# Add NGC_API_KEY if set (for Riva NIM)
if [[ -n "${NGC_API_KEY:-}" ]]; then
  echo "NGC_API_KEY=${NGC_API_KEY}" >> "$DATA_MOUNT/dalston/.env.aws"
fi

# Create systemd service
cat > /etc/systemd/system/dalston.service << SVCEOF
[Unit]
Description=Dalston Transcription Server
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/data/dalston
ExecStart=/usr/bin/docker-compose -f docker-compose.yml ${EXTRA_COMPOSE_FILES} -f infra/docker/docker-compose.aws.yml --env-file .env.aws ${COMPOSE_PROFILE_FLAGS} up -d
ExecStop=/usr/bin/docker-compose -f docker-compose.yml ${EXTRA_COMPOSE_FILES} -f infra/docker/docker-compose.aws.yml --env-file .env.aws ${COMPOSE_PROFILE_FLAGS} down
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
SVCEOF

systemctl daemon-reload
systemctl enable dalston.service

echo ""
echo "=========================================="
echo "Dalston bootstrap completed at $(date)"
echo "=========================================="
echo ""
echo "Next steps:"
echo "1. sudo tailscale up"
echo "2. tailscale ip -4"
echo "3. sudo systemctl start dalston"
USERDATA_BODY
}

generate_gpu_worker_user_data() {
    local s3_bucket="$1"
    local ctrl_plane_ip="$2"

    cat << 'USERDATA_HEADER'
#!/bin/bash
set -euo pipefail
exec > >(tee /var/log/user-data.log) 2>&1
echo "Starting Dalston GPU worker bootstrap at $(date)"
USERDATA_HEADER

    cat << USERDATA_VARS
DATA_DEVICE="/dev/xvdf"
DATA_MOUNT="/data"
S3_BUCKET="${s3_bucket}"
AWS_REGION="${REGION}"
CTRL_PLANE_IP="${ctrl_plane_ip}"
USERDATA_VARS

    cat << 'USERDATA_BODY'

# Install Docker
dnf update -y
dnf install -y docker git pciutils
systemctl start docker
systemctl enable docker
usermod -aG docker ec2-user

# Docker Compose
DOCKER_COMPOSE_VERSION="v2.24.0"
curl -L "https://github.com/docker/compose/releases/download/${DOCKER_COMPOSE_VERSION}/docker-compose-linux-x86_64" \
  -o /usr/local/bin/docker-compose
chmod +x /usr/local/bin/docker-compose
ln -sf /usr/local/bin/docker-compose /usr/bin/docker-compose

# Tailscale
curl -fsSL https://tailscale.com/install.sh | sh

# NVIDIA runtime
if lspci | grep -qi nvidia; then
  curl -fsSL https://nvidia.github.io/libnvidia-container/stable/rpm/nvidia-container-toolkit.repo \
    -o /etc/yum.repos.d/nvidia-container-toolkit.repo
  dnf install -y nvidia-container-toolkit || true
  if command -v nvidia-ctk >/dev/null 2>&1; then
    nvidia-ctk runtime configure --runtime=docker
    systemctl restart docker
  fi
fi

# Data volume
while [ ! -e "$DATA_DEVICE" ]; do sleep 5; done
if ! blkid "$DATA_DEVICE" | grep -q ext4; then
  mkfs.ext4 -L dalston-data "$DATA_DEVICE"
fi
mkdir -p "$DATA_MOUNT"
mount "$DATA_DEVICE" "$DATA_MOUNT"
if ! grep -q "$DATA_MOUNT" /etc/fstab; then
  echo "LABEL=dalston-data $DATA_MOUNT ext4 defaults,nofail 0 2" >> /etc/fstab
fi
mkdir -p "$DATA_MOUNT/models" "$DATA_MOUNT/dalston"
chown -R 1000:1000 "$DATA_MOUNT"

# .env.gpu — points Redis and Postgres to the control plane
cat > "$DATA_MOUNT/dalston/.env.gpu" << ENVEOF
DALSTON_S3_BUCKET=${S3_BUCKET}
DALSTON_S3_REGION=${AWS_REGION}
AWS_REGION=${AWS_REGION}
REDIS_URL=redis://${CTRL_PLANE_IP}:6379
DATABASE_URL=postgresql+asyncpg://dalston:password@${CTRL_PLANE_IP}:5432/dalston
HF_HOME=/data/models
ENVEOF

# GPU worker systemd service — only GPU engines, no infra
cat > /etc/systemd/system/dalston-gpu.service << SVCEOF
[Unit]
Description=Dalston GPU Worker
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/data/dalston
ExecStart=/usr/bin/docker-compose -f docker-compose.yml -f infra/docker/docker-compose.aws.yml --env-file .env.gpu --profile gpu up -d \
  stt-batch-transcribe-nemo \
  stt-batch-transcribe-faster-whisper \
  stt-batch-align-phoneme \
  stt-batch-diarize-nemo-msdd \
  stt-rt-nemo \
  stt-rt-faster-whisper
ExecStop=/usr/bin/docker-compose -f docker-compose.yml -f infra/docker/docker-compose.aws.yml --env-file .env.gpu --profile gpu down
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
SVCEOF

systemctl daemon-reload
systemctl enable dalston-gpu.service

echo ""
echo "=========================================="
echo "GPU worker bootstrap completed at $(date)"
echo "=========================================="
echo ""
echo "Next steps:"
echo "1. sudo tailscale up"
echo "2. Update .env.gpu REDIS_URL with control plane Tailscale IP"
echo "3. sudo systemctl start dalston-gpu"
USERDATA_BODY
}

get_latest_ami() {
    aws ec2 describe-images \
        --owners amazon \
        --filters "Name=name,Values=al2023-ami-*-x86_64" "Name=virtualization-type,Values=hvm" \
        --query 'Images | sort_by(@, &CreationDate) | [-1].ImageId' \
        --output text \
        --region "$REGION"
}

launch_instance() {
    local instance_type="$1"
    local sg_id="$2"
    local user_data_file="$3"
    local name_tag="$4"
    local use_spot="$5"

    local ami_id
    ami_id=$(get_latest_ami)

    # Get default VPC + subnet
    local vpc_id subnet_id
    vpc_id=$(aws ec2 describe-vpcs --filters "Name=is-default,Values=true" \
        --query 'Vpcs[0].VpcId' --output text --region "$REGION")
    subnet_id=$(aws ec2 describe-subnets --filters "Name=vpc-id,Values=$vpc_id" \
        --query 'Subnets[0].SubnetId' --output text --region "$REGION")

    local run_args=(
        ec2 run-instances
        --image-id "$ami_id"
        --instance-type "$instance_type"
        --key-name "$KEY_NAME"
        --security-group-ids "$sg_id"
        --subnet-id "$subnet_id"
        --iam-instance-profile "Name=${INSTANCE_PROFILE}"
        --user-data "file://${user_data_file}"
        --block-device-mappings "[{\"DeviceName\":\"/dev/xvda\",\"Ebs\":{\"VolumeSize\":${ROOT_VOLUME_SIZE},\"VolumeType\":\"gp3\",\"Encrypted\":true,\"DeleteOnTermination\":true}}]"
        --tag-specifications "ResourceType=instance,Tags=[{Key=Name,Value=${name_tag}},{Key=Project,Value=dalston}]"
        --query 'Instances[0].InstanceId'
        --output text
        --region "$REGION"
    )

    if [[ "$use_spot" == "true" ]]; then
        run_args+=(
            --instance-market-options '{"MarketType":"spot","SpotOptions":{"SpotInstanceType":"persistent","InstanceInterruptionBehavior":"stop"}}'
        )
    fi

    local iid
    iid=$(aws "${run_args[@]}")
    echo "$iid"
}

create_and_attach_data_volume() {
    local instance_id="$1"

    # Get the AZ of the instance
    local az
    az=$(aws ec2 describe-instances \
        --instance-ids "$instance_id" \
        --query 'Reservations[0].Instances[0].Placement.AvailabilityZone' \
        --output text \
        --region "$REGION")

    local vol_id
    vol_id=$(aws ec2 create-volume \
        --availability-zone "$az" \
        --size "$DATA_VOLUME_SIZE" \
        --volume-type gp3 \
        --encrypted \
        --tag-specifications "ResourceType=volume,Tags=[{Key=Name,Value=${NAME_PREFIX}-data},{Key=Project,Value=dalston}]" \
        --query 'VolumeId' \
        --output text \
        --region "$REGION")

    log "Waiting for volume $vol_id to be available..."
    aws ec2 wait volume-available --volume-ids "$vol_id" --region "$REGION"

    aws ec2 attach-volume \
        --volume-id "$vol_id" \
        --instance-id "$instance_id" \
        --device /dev/xvdf \
        --region "$REGION" \
        --no-cli-pager

    echo "$vol_id"
}

# Allow control plane Redis + Postgres access from GPU worker
open_control_plane_ports() {
    local ctrl_sg_id="$1"
    local gpu_sg_id="$2"

    # Redis (6379) from GPU SG
    aws ec2 authorize-security-group-ingress \
        --group-id "$ctrl_sg_id" \
        --protocol tcp \
        --port 6379 \
        --source-group "$gpu_sg_id" \
        --region "$REGION" \
        --no-cli-pager 2>/dev/null || true

    # Postgres (5432) from GPU SG
    aws ec2 authorize-security-group-ingress \
        --group-id "$ctrl_sg_id" \
        --protocol tcp \
        --port 5432 \
        --source-group "$gpu_sg_id" \
        --region "$REGION" \
        --no-cli-pager 2>/dev/null || true

    log "Control plane ports 6379,5432 open to GPU worker"
}

# ============================================================
# SETUP COMMAND
# ============================================================

cmd_setup() {
    # Check AWS credentials
    aws sts get-caller-identity --region "$REGION" > /dev/null 2>&1 \
        || die "AWS credentials not configured. Run 'aws configure' first."

    # Idempotency: if state exists and instance is alive, don't create a duplicate
    if load_state 2>/dev/null && [[ -n "${INSTANCE_ID:-}" ]]; then
        local existing_state
        existing_state=$(get_instance_state "$INSTANCE_ID")
        if [[ "$existing_state" == "running" || "$existing_state" == "stopped" ]]; then
            log "Existing deployment found: $INSTANCE_ID (state=$existing_state)"
            log "Infrastructure resources (S3, IAM, SG) will be verified."
            log "Instance will NOT be re-created. Use 'dalston-aws teardown' first to start fresh."
            echo ""

            # Still re-run infra setup to ensure idempotent convergence
            local account_id vpc_id
            account_id=$(aws_account_id)
            vpc_id=$(aws ec2 describe-instances \
                --instance-ids "$INSTANCE_ID" \
                --query 'Reservations[0].Instances[0].VpcId' \
                --output text \
                --region "$REGION")

            create_s3_bucket
            create_iam_role
            ensure_key_pair
            create_security_group "$vpc_id"
            save_state
            cmd_status
            return 0
        fi
        # Instance terminated/gone — fall through to re-create
        log "Previous instance $INSTANCE_ID is $existing_state. Will create a new one."
    fi

    local account_id
    account_id=$(aws_account_id)
    local vpc_id
    vpc_id=$(aws ec2 describe-vpcs --filters "Name=is-default,Values=true" \
        --query 'Vpcs[0].VpcId' --output text --region "$REGION")

    echo ""
    log "Setting up Dalston on AWS"
    log "  Region:   $REGION"
    log "  Scenario: $SCENARIO"
    log "  Spot:     $USE_SPOT"
    log "  Account:  $account_id"
    echo ""

    # 1. S3 bucket
    create_s3_bucket

    # 2. IAM role
    create_iam_role

    # 3. Key pair
    ensure_key_pair

    # 4. Security group(s)
    create_security_group "$vpc_id"

    # 5. Launch instance(s) based on scenario
    case "$SCENARIO" in
        cpu)
            log "Launching CPU instance ($CPU_INSTANCE_TYPE)..."
            local user_data_file
            user_data_file=$(mktemp)
            generate_user_data "$S3_BUCKET" "--profile local-infra" > "$user_data_file"
            INSTANCE_ID=$(launch_instance "$CPU_INSTANCE_TYPE" "$SG_ID" "$user_data_file" "${NAME_PREFIX}-server" "$USE_SPOT")
            rm -f "$user_data_file"
            wait_instance_running "$INSTANCE_ID"
            DATA_VOLUME_ID=$(create_and_attach_data_volume "$INSTANCE_ID")
            ;;

        gpu)
            log "Launching GPU instance ($GPU_INSTANCE_TYPE)..."
            local user_data_file extra_compose=""
            user_data_file=$(mktemp)
            if [[ "$USE_RIVA" == "true" ]]; then
                extra_compose="-f docker-compose.riva.yml"
                # Prompt for NGC_API_KEY if not already set
                if [[ -z "${NGC_API_KEY:-}" ]]; then
                    read -r -p "NGC_API_KEY (required for Riva NIM): " NGC_API_KEY
                    [[ -n "$NGC_API_KEY" ]] || die "NGC_API_KEY is required for --riva"
                fi
                log "Riva NIM enabled (NGC_API_KEY set)"
            fi
            generate_user_data "$S3_BUCKET" "--profile local-infra --profile gpu" "$extra_compose" > "$user_data_file"
            INSTANCE_ID=$(launch_instance "$GPU_INSTANCE_TYPE" "$SG_ID" "$user_data_file" "${NAME_PREFIX}-server" "$USE_SPOT")
            rm -f "$user_data_file"
            wait_instance_running "$INSTANCE_ID"
            DATA_VOLUME_ID=$(create_and_attach_data_volume "$INSTANCE_ID")
            ;;

        split)
            # Control plane
            log "Launching control plane ($CTRL_INSTANCE_TYPE)..."
            local ctrl_user_data
            ctrl_user_data=$(mktemp)
            generate_user_data "$S3_BUCKET" "--profile local-infra" > "$ctrl_user_data"
            INSTANCE_ID=$(launch_instance "$CTRL_INSTANCE_TYPE" "$SG_ID" "$ctrl_user_data" "${NAME_PREFIX}-control-plane" "false")
            rm -f "$ctrl_user_data"
            wait_instance_running "$INSTANCE_ID"
            DATA_VOLUME_ID=$(create_and_attach_data_volume "$INSTANCE_ID")

            local ctrl_private_ip
            ctrl_private_ip=$(aws ec2 describe-instances \
                --instance-ids "$INSTANCE_ID" \
                --query 'Reservations[0].Instances[0].PrivateIpAddress' \
                --output text \
                --region "$REGION")

            # GPU worker security group
            create_gpu_worker_security_group "$vpc_id"
            open_control_plane_ports "$SG_ID" "$GPU_SG_ID"

            # GPU worker
            log "Launching GPU worker ($GPU_INSTANCE_TYPE)..."
            local gpu_user_data
            gpu_user_data=$(mktemp)
            generate_gpu_worker_user_data "$S3_BUCKET" "$ctrl_private_ip" > "$gpu_user_data"
            GPU_INSTANCE_ID=$(launch_instance "$GPU_INSTANCE_TYPE" "$GPU_SG_ID" "$gpu_user_data" "${NAME_PREFIX}-gpu-worker" "$USE_SPOT")
            rm -f "$gpu_user_data"
            wait_instance_running "$GPU_INSTANCE_ID"
            GPU_DATA_VOLUME_ID=$(create_and_attach_data_volume "$GPU_INSTANCE_ID")
            ;;
    esac

    save_state

    # Print summary
    echo ""
    echo "=========================================="
    log "Setup complete!"
    echo "=========================================="
    echo ""
    log "Instance: $INSTANCE_ID ($(get_instance_ip "$INSTANCE_ID"))"
    if [[ "$SCENARIO" == "split" ]]; then
        log "GPU worker: $GPU_INSTANCE_ID ($(get_instance_ip "$GPU_INSTANCE_ID"))"
    fi
    echo ""
    log "Next steps:"
    echo "  1. SSH to the instance:"
    echo "     ssh -i ${STATE_DIR}/${KEY_NAME}.pem ec2-user@$(get_instance_ip "$INSTANCE_ID")"
    echo "  2. Set up Tailscale:"
    echo "     sudo tailscale up"
    echo "  3. Clone your repo to /data/dalston and start:"
    echo "     sudo systemctl start dalston"
    echo ""
    log "Management commands:"
    echo "  dalston-aws status   # Check instance state"
    echo "  dalston-aws up       # Start instance(s)"
    echo "  dalston-aws down     # Stop instance(s)"
    echo "  dalston-aws ssh      # SSH via Tailscale"
    echo "  dalston-aws teardown # Remove everything"
}

# ============================================================
# MANAGEMENT COMMANDS
# ============================================================

cmd_status() {
    require_state
    echo ""
    log "Dalston AWS Deployment"
    log "  Scenario: $SCENARIO"
    log "  Region:   $REGION"
    log "  S3:       $S3_BUCKET"
    echo ""

    local state ip
    state=$(get_instance_state "$INSTANCE_ID")
    ip=$(get_instance_ip "$INSTANCE_ID")
    local label="Instance"
    [[ "$SCENARIO" == "split" ]] && label="Control plane"
    log "  $label: $INSTANCE_ID  state=${state}  ip=${ip:-none}"

    if [[ "$SCENARIO" == "split" && -n "$GPU_INSTANCE_ID" ]]; then
        state=$(get_instance_state "$GPU_INSTANCE_ID")
        ip=$(get_instance_ip "$GPU_INSTANCE_ID")
        log "  GPU worker:     $GPU_INSTANCE_ID  state=${state}  ip=${ip:-none}"
    fi
    echo ""
}

cmd_up() {
    require_state
    log "Starting instance(s)..."
    retry_aws aws ec2 start-instances --instance-ids "$INSTANCE_ID" --region "$REGION" --no-cli-pager
    if [[ "$SCENARIO" == "split" && -n "$GPU_INSTANCE_ID" ]]; then
        retry_aws aws ec2 start-instances --instance-ids "$GPU_INSTANCE_ID" --region "$REGION" --no-cli-pager
    fi
    log "Start command sent. Instances booting..."
}

cmd_down() {
    require_state
    log "Stopping instance(s)..."
    aws ec2 stop-instances --instance-ids "$INSTANCE_ID" --region "$REGION" --no-cli-pager
    if [[ "$SCENARIO" == "split" && -n "$GPU_INSTANCE_ID" ]]; then
        aws ec2 stop-instances --instance-ids "$GPU_INSTANCE_ID" --region "$REGION" --no-cli-pager
    fi
    log "Stop command sent."
}

cmd_ssh() {
    require_state
    local target_id="$INSTANCE_ID"
    local target_label="main instance"

    if [[ "${1:-}" == "gpu" && "$SCENARIO" == "split" && -n "$GPU_INSTANCE_ID" ]]; then
        target_id="$GPU_INSTANCE_ID"
        target_label="GPU worker"
    fi

    local ip
    ip=$(get_instance_ip "$target_id")
    if [[ -z "$ip" || "$ip" == "None" ]]; then
        die "$target_label is not running. Run 'dalston-aws up' first."
    fi

    local key_file="${STATE_DIR}/${KEY_NAME}.pem"
    if [[ ! -f "$key_file" ]]; then
        warn "Key file not found at $key_file — trying without key"
        ssh "ec2-user@${ip}"
    else
        ssh -i "$key_file" "ec2-user@${ip}"
    fi
}

# ============================================================
# ADD-GPU / REMOVE-GPU — incremental scaling
# ============================================================

cmd_add_gpu() {
    require_state

    if [[ -n "$GPU_INSTANCE_ID" ]]; then
        local gpu_state
        gpu_state=$(get_instance_state "$GPU_INSTANCE_ID")
        if [[ "$gpu_state" != "terminated" ]]; then
            die "GPU worker already exists ($GPU_INSTANCE_ID, state=$gpu_state). Use 'dalston-aws remove-gpu' first."
        fi
    fi

    # Verify main instance is running
    local main_state
    main_state=$(get_instance_state "$INSTANCE_ID")
    if [[ "$main_state" != "running" ]]; then
        die "Main instance $INSTANCE_ID is $main_state. Run 'dalston-aws up' first."
    fi

    local ctrl_private_ip
    ctrl_private_ip=$(aws ec2 describe-instances \
        --instance-ids "$INSTANCE_ID" \
        --query 'Reservations[0].Instances[0].PrivateIpAddress' \
        --output text \
        --region "$REGION")

    local vpc_id
    vpc_id=$(aws ec2 describe-instances \
        --instance-ids "$INSTANCE_ID" \
        --query 'Reservations[0].Instances[0].VpcId' \
        --output text \
        --region "$REGION")

    log "Adding GPU worker to existing deployment"
    log "  Main instance: $INSTANCE_ID ($ctrl_private_ip)"
    log "  GPU type:      $GPU_INSTANCE_TYPE"
    log "  Spot:          $USE_SPOT"
    echo ""

    # GPU worker security group
    create_gpu_worker_security_group "$vpc_id"
    open_control_plane_ports "$SG_ID" "$GPU_SG_ID"

    # Launch GPU worker
    log "Launching GPU worker ($GPU_INSTANCE_TYPE)..."
    local gpu_user_data
    gpu_user_data=$(mktemp)
    generate_gpu_worker_user_data "$S3_BUCKET" "$ctrl_private_ip" > "$gpu_user_data"
    GPU_INSTANCE_ID=$(launch_instance "$GPU_INSTANCE_TYPE" "$GPU_SG_ID" "$gpu_user_data" "${NAME_PREFIX}-gpu-worker" "$USE_SPOT")
    rm -f "$gpu_user_data"
    wait_instance_running "$GPU_INSTANCE_ID"
    GPU_DATA_VOLUME_ID=$(create_and_attach_data_volume "$GPU_INSTANCE_ID")

    # Update scenario to split
    SCENARIO="split"
    save_state

    echo ""
    echo "=========================================="
    log "GPU worker added!"
    echo "=========================================="
    echo ""
    log "GPU worker: $GPU_INSTANCE_ID ($(get_instance_ip "$GPU_INSTANCE_ID"))"
    echo ""
    log "Next steps on the GPU worker:"
    echo "  1. SSH: dalston-aws ssh gpu"
    echo "  2. sudo tailscale up"
    echo "  3. Update .env.gpu REDIS_URL/DATABASE_URL with control plane Tailscale IP"
    echo "  4. sudo systemctl start dalston-gpu"
}

cmd_remove_gpu() {
    require_state

    if [[ -z "$GPU_INSTANCE_ID" ]]; then
        die "No GPU worker found. Nothing to remove."
    fi

    local gpu_state
    gpu_state=$(get_instance_state "$GPU_INSTANCE_ID")
    if [[ "$gpu_state" == "terminated" ]]; then
        log "GPU worker already terminated. Cleaning up state..."
        GPU_INSTANCE_ID=""
        GPU_DATA_VOLUME_ID=""
        GPU_SG_ID=""
        SCENARIO="gpu"  # revert to single-instance
        # Check if main instance is GPU-capable
        local main_type
        main_type=$(aws ec2 describe-instances \
            --instance-ids "$INSTANCE_ID" \
            --query 'Reservations[0].Instances[0].InstanceType' \
            --output text \
            --region "$REGION" 2>/dev/null || echo "")
        if [[ "$main_type" == t* || "$main_type" == m* || "$main_type" == c* ]]; then
            SCENARIO="cpu"
        fi
        save_state
        log "State cleaned up."
        return 0
    fi

    warn "This will terminate GPU worker $GPU_INSTANCE_ID and delete its data volume."
    read -rp "Type 'yes' to confirm: " confirm
    [[ "$confirm" == "yes" ]] || die "Aborted."

    # Terminate GPU instance
    log "Terminating GPU worker $GPU_INSTANCE_ID..."
    aws ec2 terminate-instances --instance-ids "$GPU_INSTANCE_ID" --region "$REGION" --no-cli-pager || true
    aws ec2 wait instance-terminated --instance-ids "$GPU_INSTANCE_ID" --region "$REGION" || true

    # Delete GPU data volume
    if [[ -n "$GPU_DATA_VOLUME_ID" ]]; then
        log "Deleting GPU data volume $GPU_DATA_VOLUME_ID..."
        aws ec2 delete-volume --volume-id "$GPU_DATA_VOLUME_ID" --region "$REGION" --no-cli-pager 2>/dev/null || true
    fi

    # Delete GPU security group
    if [[ -n "$GPU_SG_ID" ]]; then
        log "Deleting GPU security group $GPU_SG_ID..."
        sleep 3
        aws ec2 delete-security-group --group-id "$GPU_SG_ID" --region "$REGION" --no-cli-pager 2>/dev/null || true
    fi

    # Update state — figure out scenario from main instance type
    local main_type
    main_type=$(aws ec2 describe-instances \
        --instance-ids "$INSTANCE_ID" \
        --query 'Reservations[0].Instances[0].InstanceType' \
        --output text \
        --region "$REGION" 2>/dev/null || echo "")
    if [[ "$main_type" == g* || "$main_type" == p* ]]; then
        SCENARIO="gpu"
    else
        SCENARIO="cpu"
    fi

    GPU_INSTANCE_ID=""
    GPU_DATA_VOLUME_ID=""
    GPU_SG_ID=""
    save_state

    log "GPU worker removed. Deployment is now single-instance ($SCENARIO)."
}

# ============================================================
# TEARDOWN
# ============================================================

cmd_teardown() {
    require_state

    echo ""
    warn "This will PERMANENTLY DELETE all Dalston AWS resources:"
    warn "  - EC2 instance(s): $INSTANCE_ID ${GPU_INSTANCE_ID:+$GPU_INSTANCE_ID}"
    warn "  - EBS volumes: $DATA_VOLUME_ID ${GPU_DATA_VOLUME_ID:+$GPU_DATA_VOLUME_ID}"
    warn "  - S3 bucket: $S3_BUCKET (contents preserved — delete manually)"
    warn "  - IAM role: $IAM_ROLE"
    warn "  - Security group(s): $SG_ID ${GPU_SG_ID:+$GPU_SG_ID}"
    echo ""
    read -rp "Type 'yes' to confirm: " confirm
    [[ "$confirm" == "yes" ]] || die "Aborted."

    # Terminate instances
    log "Terminating instances..."
    aws ec2 terminate-instances --instance-ids "$INSTANCE_ID" --region "$REGION" --no-cli-pager || true
    if [[ -n "$GPU_INSTANCE_ID" ]]; then
        aws ec2 terminate-instances --instance-ids "$GPU_INSTANCE_ID" --region "$REGION" --no-cli-pager || true
    fi

    log "Waiting for termination..."
    aws ec2 wait instance-terminated --instance-ids "$INSTANCE_ID" --region "$REGION" || true
    if [[ -n "$GPU_INSTANCE_ID" ]]; then
        aws ec2 wait instance-terminated --instance-ids "$GPU_INSTANCE_ID" --region "$REGION" || true
    fi

    # Delete data volumes
    log "Deleting data volumes..."
    aws ec2 delete-volume --volume-id "$DATA_VOLUME_ID" --region "$REGION" --no-cli-pager 2>/dev/null || true
    if [[ -n "$GPU_DATA_VOLUME_ID" ]]; then
        aws ec2 delete-volume --volume-id "$GPU_DATA_VOLUME_ID" --region "$REGION" --no-cli-pager 2>/dev/null || true
    fi

    # Delete security group(s) — may need retry as ENIs detach
    log "Deleting security groups..."
    sleep 5
    aws ec2 delete-security-group --group-id "$SG_ID" --region "$REGION" --no-cli-pager 2>/dev/null || true
    if [[ -n "$GPU_SG_ID" ]]; then
        aws ec2 delete-security-group --group-id "$GPU_SG_ID" --region "$REGION" --no-cli-pager 2>/dev/null || true
    fi

    # Delete IAM resources
    log "Deleting IAM role..."
    aws iam remove-role-from-instance-profile \
        --instance-profile-name "$INSTANCE_PROFILE" \
        --role-name "$IAM_ROLE" 2>/dev/null || true
    aws iam delete-instance-profile \
        --instance-profile-name "$INSTANCE_PROFILE" 2>/dev/null || true
    aws iam delete-role-policy \
        --role-name "$IAM_ROLE" \
        --policy-name "${NAME_PREFIX}-s3-access" 2>/dev/null || true
    aws iam delete-role --role-name "$IAM_ROLE" 2>/dev/null || true

    # Note: S3 bucket is NOT deleted (may contain data)
    warn "S3 bucket $S3_BUCKET was NOT deleted (may contain transcription data)."
    warn "To delete: aws s3 rb s3://${S3_BUCKET} --force"

    # Clean up state
    rm -f "$STATE_FILE"
    log "Teardown complete."
}

# ============================================================
# MAIN
# ============================================================

usage() {
    cat << EOF
Usage: dalston-aws <command> [options]

Commands:
  setup      Provision AWS resources and launch instance(s)
  add-gpu    Add a GPU worker to an existing deployment
  remove-gpu Remove the GPU worker and revert to single instance
  teardown   Remove all AWS resources
  status     Show instance state
  up         Start instance(s)
  down       Stop instance(s)
  ssh [gpu]  SSH to instance (default: main, "gpu" for GPU worker)

Setup options:
  --cpu          CPU-only instance (Scenario 1: t3.xlarge)
  --gpu          Single GPU instance (Scenario 2: g5.xlarge) [default]
  --split        Two-tier: CPU control plane + GPU worker (Scenario 5)
  --spot         Use spot pricing (~65% savings)
  --region R     AWS region (default: eu-west-2)
  --key NAME     Existing SSH key pair name
  --gpu-type T   GPU instance type (default: g5.xlarge)
  --riva         Enable Riva NIM runtime (prompts for NGC_API_KEY if not set)

Examples:
  dalston-aws setup                    # Single g5.xlarge
  dalston-aws setup --spot             # Same, with spot pricing
  dalston-aws setup --cpu              # CPU-only t3.xlarge
  dalston-aws setup --split --spot     # Control plane + GPU spot worker
  dalston-aws add-gpu --spot           # Add GPU worker to existing setup
  dalston-aws remove-gpu               # Remove GPU worker
  dalston-aws down                     # Stop (saves ~\$4/day)
  dalston-aws up                       # Restart
  dalston-aws setup --gpu --riva       # GPU with Riva NIM (TensorRT-optimized)
  dalston-aws teardown                 # Delete everything
EOF
}

main() {
    local command="${1:-}"
    shift || true

    # Parse flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --cpu)     SCENARIO="cpu" ;;
            --gpu)     SCENARIO="gpu" ;;
            --split)   SCENARIO="split" ;;
            --spot)    USE_SPOT=true ;;
            --riva)    USE_RIVA=true ;;
            --region)  REGION="${2:?--region requires a value}"; shift ;;
            --key)     KEY_NAME="${2:?--key requires a value}"; shift ;;
            --gpu-type) GPU_INSTANCE_TYPE="${2:?--gpu-type requires a value}"; shift ;;
            gpu)       ;; # handled by ssh command
            *)         die "Unknown option: $1" ;;
        esac
        shift
    done

    case "$command" in
        setup)      cmd_setup ;;
        add-gpu)    cmd_add_gpu ;;
        remove-gpu) cmd_remove_gpu ;;
        teardown)   cmd_teardown ;;
        status)     cmd_status ;;
        up)         cmd_up ;;
        down)       cmd_down ;;
        ssh)        cmd_ssh "${@:-}" ;;
        ""|help|-h|--help) usage ;;
        *)          die "Unknown command: $command. Run 'dalston-aws help'" ;;
    esac
}

main "$@"
