# ---------------------------------------------------------------------------
# Logging / audit
# ---------------------------------------------------------------------------

_RED = "\033[0;31m"
_GREEN = "\033[0;32m"
_YELLOW = "\033[1;33m"
_BLUE = "\033[0;34m"
_NC = "\033[0m"


def log(msg: str) -> None:
    print(f"{_BLUE}[dalston-gcp]{_NC} {msg}")


def audit(action: str, **details: Any) -> None:
    try:
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        entry = {
            "ts": datetime.now(UTC).isoformat(),
            "tool": "dalston-gcp",
            "action": action,
            **details,
        }
        with AUDIT_LOG.open("a") as f:
            f.write(json.dumps(entry) + "\n")
    except Exception:
        pass  # never let audit failures break commands


def warn(msg: str) -> None:
    print(f"{_YELLOW}[dalston-gcp] WARN:{_NC} {msg}", file=sys.stderr)


def err(msg: str) -> None:
    print(f"{_RED}[dalston-gcp] ERROR:{_NC} {msg}", file=sys.stderr)


def die(msg: str) -> NoReturn:
    err(msg)
    sys.exit(1)


# ---------------------------------------------------------------------------
# Dataclasses (templates + state) — mirrors dalston-aws structure
# ---------------------------------------------------------------------------


@dataclass
class ControlPlaneConfig:
    instance_type: str = DEFAULT_CTRL_MACHINE
    spot: bool = False
    compose_profiles: list[str] | None = None
    data_volume_gb: int = DATA_DISK_SIZE_GB


@dataclass
class GpuWorkerConfig:
    instance_type: str = DEFAULT_GPU_MACHINE
    spot: bool = True
    gpu_type: str = DEFAULT_GPU_TYPE
    gpu_count: int = DEFAULT_GPU_COUNT


@dataclass
class DeploymentTemplate:
    scenario: str = "split"
    region: str = DEFAULT_REGION
    registry: str = DEFAULT_GHCR_REGISTRY
    control_plane: ControlPlaneConfig | None = None
    gpu_worker: GpuWorkerConfig | None = None


def load_template(path: str | Path) -> DeploymentTemplate:
    """Load a deployment template. Accepts a full path or a preset name.

    Preset resolution: `gcp-<name>.yaml` wins over `<name>.yaml` so that AWS
    templates (split, cpu, gpu) don't accidentally get consumed here.
    """
    p = Path(path)
    if not p.exists():
        gcp_preset = TEMPLATES_DIR / f"gcp-{path}.yaml"
        plain_preset = TEMPLATES_DIR / f"{path}.yaml"
        if gcp_preset.exists():
            p = gcp_preset
        elif plain_preset.exists():
            warn(
                f"No gcp-{path}.yaml template found — falling back to "
                f"{plain_preset.name}. Instance types may be AWS-native."
            )
            p = plain_preset
        else:
            die(f"Template not found: {path} (looked for gcp-{path}.yaml)")
    data = yaml.safe_load(p.read_text())
    cp = data.pop("control_plane", None) or {}
    gw = data.pop("gpu_worker", None)
    tmpl = DeploymentTemplate(**data)
    tmpl.control_plane = ControlPlaneConfig(**cp)
    tmpl.gpu_worker = GpuWorkerConfig(**gw) if gw else None
    return tmpl


@dataclass
class GpuWorker:
    """State for a single GPU worker instance.

    `name` is the engine-derived label and may repeat across replicas.
    `hostname` is the unique Tailscale node name (suffixed `-1`, `-2` for
    replicas). Empty hostname means unresolved — run `dalston-gcp reconcile`.
    """

    name: str = ""
    hostname: str = ""
    instance_name: str = ""  # GCE instance name (per-worker, unique)
    instance_type: str = ""
    gpu_type: str = ""
    gpu_count: int = 1
    spot: bool = True
    zone: str = ""
    engines: list[str] | None = None


@dataclass
class DeploymentState:
    project: str = ""
    region: str = DEFAULT_REGION
    zone: str = ""  # default zone within region, picked at setup
    scenario: str = "split"
    template: str = ""
    gcs_bucket: str = ""
    service_account: str = (
        ""  # full email, e.g. dalston-sa@PROJECT.iam.gserviceaccount.com
    )
    network: str = "default"
    instance_name: str = ""  # control plane instance name
    data_disk_name: str = ""
    observability: bool = False
    gpu_workers: list[dict] | None = None


def save_state(state: DeploymentState) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    STATE_FILE.write_text(
        yaml.dump(asdict(state), default_flow_style=False, sort_keys=False)
    )
    log(f"State saved to {STATE_FILE}")


def load_state() -> DeploymentState | None:
    if not STATE_FILE.exists():
        return None
    data = yaml.safe_load(STATE_FILE.read_text())
    known = set(DeploymentState.__dataclass_fields__)
    state = DeploymentState(**{k: v for k, v in data.items() if k in known})
    for w in state.gpu_workers or []:
        if "hostname" not in w:
            w["hostname"] = f"{NAME_PREFIX}-gpu-{w['name']}"
    return state


def require_state() -> DeploymentState:
    st = load_state()
    if st is None:
        die("No deployment found. Run 'dalston-gcp setup -t TEMPLATE' first.")
    return st


# ---------------------------------------------------------------------------
# gcloud / gsutil subprocess wrappers
# ---------------------------------------------------------------------------


def _run_gcloud(
    args: list[str],
    *,
    check: bool = True,
    capture: bool = True,
    json_out: bool = False,
    input_data: str | None = None,
) -> subprocess.CompletedProcess | Any:
    """Run a gcloud command. Returns parsed JSON when json_out=True."""
    cmd = ["gcloud", *args]
    if json_out and "--format" not in args:
        cmd += ["--format=json"]
    try:
        res = subprocess.run(
            cmd,
            check=check,
            capture_output=capture,
            text=True,
            input=input_data,
        )
    except FileNotFoundError:
        die(
            "gcloud CLI not found. Install with: https://cloud.google.com/sdk/docs/install"
        )
    except subprocess.CalledProcessError as e:
        stderr = e.stderr.strip() if e.stderr else ""
        raise RuntimeError(f"gcloud {' '.join(args)} failed: {stderr}") from e
    if json_out and res.stdout:
        try:
            return json.loads(res.stdout)
        except json.JSONDecodeError:
            return None
    return res


def _run_gsutil(
    args: list[str], *, check: bool = True, capture: bool = True
) -> subprocess.CompletedProcess:
    """Run a gsutil command. (Storage operations.)"""
    cmd = ["gsutil", *args]
    try:
        return subprocess.run(cmd, check=check, capture_output=capture, text=True)
    except FileNotFoundError:
        die("gsutil not found. It ships with the gcloud SDK.")
    except subprocess.CalledProcessError as e:
        stderr = e.stderr.strip() if e.stderr else ""
        raise RuntimeError(f"gsutil {' '.join(args)} failed: {stderr}") from e


def _get_active_project() -> str:
    """Return the configured GCP project, or die if unset."""
    try:
        res = _run_gcloud(["config", "get-value", "project"])
        project = res.stdout.strip()
        if not project or project == "(unset)":
            die(
                "No active GCP project. Set one with:\n"
                "  gcloud config set project PROJECT_ID"
            )
        return project
    except Exception:
        die("Could not read active GCP project. Run `gcloud auth login` first.")


def _default_zone(region: str) -> str:
    """Pick the 'a' zone in a region as the default, matching gcloud's own default."""
    return f"{region}-a"


def _project_number(project_id: str) -> str:
    """Resolve numeric project number — needed for default compute service account."""
    res = _run_gcloud(["projects", "describe", project_id], json_out=True)
    if not res:
        die(f"Could not describe project {project_id}")
    return str(res["projectNumber"])


# ---------------------------------------------------------------------------
# Preflight — check gcloud, auth, project, enabled APIs. Every command that
# touches GCP should call preflight() so the user gets actionable errors
# instead of cryptic gcloud failures mid-launch.
# ---------------------------------------------------------------------------

REQUIRED_APIS = [
    "compute.googleapis.com",
    "storage.googleapis.com",
    "secretmanager.googleapis.com",
    "iam.googleapis.com",
]


def _check_gcloud_installed() -> list[str]:
    """Return list of fix steps if gcloud isn't installed, else []."""
    try:
        subprocess.run(
            ["gcloud", "--version"], capture_output=True, text=True, check=True
        )
        return []
    except (FileNotFoundError, subprocess.CalledProcessError):
        return [
            "Install gcloud SDK: https://cloud.google.com/sdk/docs/install",
            "  macOS:   brew install --cask google-cloud-sdk",
            "  Linux:   curl https://sdk.cloud.google.com | bash",
        ]


def _check_gcloud_auth() -> list[str]:
    """Return fix steps if there's no authenticated account."""
    try:
        res = _run_gcloud(
            ["auth", "list", "--filter=status:ACTIVE", "--format=value(account)"],
            check=False,
        )
        if res.stdout.strip():
            return []
        return [
            "No authenticated gcloud account. Run:",
            "  gcloud auth login",
            "  gcloud auth application-default login   # for API calls",
        ]
    except Exception:
        return ["gcloud auth check failed. Run `gcloud auth login`."]


def _check_project_set() -> tuple[str | None, list[str]]:
    """Return (project_id, fixes). project_id is None if unset."""
    try:
        res = _run_gcloud(["config", "get-value", "project"], check=False)
        project = res.stdout.strip()
        if project and project != "(unset)":
            return project, []
    except Exception:
        pass
    return None, [
        "No active GCP project. Set one with:",
        "  gcloud config set project YOUR_PROJECT_ID",
        "List available projects: gcloud projects list",
    ]


def _check_apis_enabled(project: str) -> list[str]:
    """Return fix step per disabled required API."""
    try:
        res = _run_gcloud(
            [
                "services",
                "list",
                "--enabled",
                "--project",
                project,
                "--format=value(config.name)",
            ],
            check=False,
        )
        enabled = set(res.stdout.split())
    except Exception:
        return [
            "Could not list enabled APIs. Run:",
            f"  gcloud services enable {' '.join(REQUIRED_APIS)} --project {project}",
        ]
    missing = [api for api in REQUIRED_APIS if api not in enabled]
    if not missing:
        return []
    return [
        "Some required APIs are disabled:",
        *[f"  - {api}" for api in missing],
        "Enable them with:",
        f"  gcloud services enable {' '.join(missing)} --project {project}",
    ]


def preflight(*, auto_fix: bool = False) -> str:
    """Verify prerequisites and return the active project ID. Dies with a
    copy-pasteable fix list if anything is missing.

    If auto_fix=True, attempts to enable missing APIs automatically (user still
    has to handle auth and project-set — those are interactive)."""
    probs = _check_gcloud_installed()
    if probs:
        _die_with_fixes("gcloud is not installed", probs)

    probs = _check_gcloud_auth()
    if probs:
        _die_with_fixes("gcloud is not authenticated", probs)

    project, probs = _check_project_set()
    if probs or not project:
        _die_with_fixes("No GCP project set", probs)

    probs = _check_apis_enabled(project)
    if probs:
        if auto_fix:
            # Try to enable missing APIs for the user
            missing = [
                line.strip().lstrip("- ")
                for line in probs
                if line.strip().startswith("- ")
            ]
            if missing:
                log(f"Enabling required APIs: {', '.join(missing)}...")
                try:
                    _run_gcloud(["services", "enable", *missing, "--project", project])
                    log("APIs enabled.")
                    return project
                except RuntimeError as e:
                    warn(f"Auto-enable failed: {e}")
        _die_with_fixes("Required GCP APIs are not enabled", probs)

    return project


def _die_with_fixes(headline: str, fixes: list[str]) -> NoReturn:
    """Print a clearly formatted error with fix instructions then exit."""
    err(headline)
    print("", file=sys.stderr)
    for line in fixes:
        print(line, file=sys.stderr)
    print("", file=sys.stderr)
    print(
        "Run `dalston-gcp doctor` any time to re-check prerequisites.",
        file=sys.stderr,
    )
    sys.exit(1)


@contextmanager
def _startup_script_file(content: str):
    """Write a startup script to a temp file and yield its path.

    gcloud's `--metadata-from-file startup-script=PATH` reads from a real file.
    Piping to `/dev/stdin` is unreliable because gcloud may re-read the file.
    """
    with tempfile.NamedTemporaryFile(
        mode="w", suffix=".sh", prefix="dalston-startup-", delete=False
    ) as f:
        f.write(content)
        path = f.name
    try:
        yield path
    finally:
        try:
            os.unlink(path)
        except OSError:
            pass


# ---------------------------------------------------------------------------
# State file lock (prevents concurrent launches from corrupting gpu_workers)
# ---------------------------------------------------------------------------

_LAUNCH_LOCK = STATE_DIR / "launch.lock"


@contextmanager
def _launch_lock():
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with _LAUNCH_LOCK.open("w") as f:
        try:
            fcntl.flock(f.fileno(), fcntl.LOCK_EX)
            yield
        finally:
            fcntl.flock(f.fileno(), fcntl.LOCK_UN)


# ---------------------------------------------------------------------------
# Infrastructure provisioning
# ---------------------------------------------------------------------------


def create_gcs_bucket(project: str, region: str) -> str:
    """Create or reuse a GCS bucket named dalston-artifacts-<project>."""
    bucket = f"{NAME_PREFIX}-artifacts-{project}"
    # Check if it exists
    try:
        res = _run_gsutil(["ls", "-b", f"gs://{bucket}"], check=False)
        if res.returncode == 0:
            log(f"Using existing GCS bucket: gs://{bucket}")
            return bucket
    except Exception:
        pass
    log(f"Creating GCS bucket gs://{bucket} in {region}...")
    _run_gsutil(
        [
            "mb",
            "-p",
            project,
            "-l",
            region,
            "-b",
            "on",  # uniform bucket-level access
            f"gs://{bucket}",
        ]
    )
    return bucket


def create_service_account(project: str, bucket: str) -> str:
    """Create a dedicated SA for dalston instances, grant minimum perms, return email."""
    sa_name = "dalston-sa"
    sa_email = f"{sa_name}@{project}.iam.gserviceaccount.com"

    # Create SA (idempotent — 409 means it exists)
    try:
        _run_gcloud(
            [
                "iam",
                "service-accounts",
                "create",
                sa_name,
                "--project",
                project,
                "--display-name",
                "Dalston compute identity",
            ],
            capture=True,
        )
        log(f"Created service account {sa_email}")
    except RuntimeError as e:
        if "already exists" not in str(e):
            raise
        log(f"Using existing service account {sa_email}")

    # Grant roles needed:
    #   - storage.objectAdmin on the bucket (not project-wide)
    #   - secretmanager.secretAccessor (for Tailscale key lookup)
    #   - logging.logWriter, monitoring.metricWriter (for boot logs)
    # Bucket-scoped grant:
    _run_gsutil(
        [
            "iam",
            "ch",
            f"serviceAccount:{sa_email}:objectAdmin",
            f"gs://{bucket}",
        ],
        check=False,
    )
    for role in (
        "roles/secretmanager.secretAccessor",
        "roles/logging.logWriter",
        "roles/monitoring.metricWriter",
    ):
        _run_gcloud(
            [
                "projects",
                "add-iam-policy-binding",
                project,
                "--member",
                f"serviceAccount:{sa_email}",
                "--role",
                role,
                "--condition=None",
            ],
            capture=True,
            check=False,
        )
    return sa_email


def create_firewall_rules(project: str, network: str) -> None:
    """Open minimum ports for Dalston + Tailscale.

    - `dalston-ssh`:     tcp:22 from anywhere (for manual fallback; Tailscale is primary)
    - `dalston-ts-udp`:  udp:41641 from anywhere (Tailscale direct UDP)
    - `dalston-internal`: all traffic between dalston-tagged instances

    Tailscale handles auth; we don't open Dalston service ports to the public
    internet. Engines and control-plane talk via Tailscale.
    """
    rules = [
        {
            "name": f"{NAME_PREFIX}-ssh",
            "network": network,
            "target-tags": f"{CTRL_TAG},{GPU_TAG}",
            "allow": "tcp:22",
            "source-ranges": "0.0.0.0/0",
            "description": "Dalston SSH fallback (primary via Tailscale)",
        },
        {
            "name": f"{NAME_PREFIX}-tailscale-udp",
            "network": network,
            "target-tags": f"{CTRL_TAG},{GPU_TAG}",
            "allow": "udp:41641",
            "source-ranges": "0.0.0.0/0",
            "description": "Tailscale direct UDP",
        },
        {
            "name": f"{NAME_PREFIX}-internal",
            "network": network,
            "target-tags": f"{CTRL_TAG},{GPU_TAG}",
            "source-tags": f"{CTRL_TAG},{GPU_TAG}",
            "allow": "tcp,udp,icmp",
            "description": "Dalston intra-cluster traffic",
        },
    ]
    for rule in rules:
        args = [
            "compute",
            "firewall-rules",
            "create",
            rule["name"],
            "--project",
            project,
            "--network",
            rule["network"],
            "--direction",
            "INGRESS",
            "--target-tags",
            rule["target-tags"],
            "--allow",
            rule["allow"],
            "--description",
            rule["description"],
        ]
        if "source-ranges" in rule:
            args += ["--source-ranges", rule["source-ranges"]]
        if "source-tags" in rule:
            args += ["--source-tags", rule["source-tags"]]
        try:
            _run_gcloud(args, capture=True)
            log(f"Created firewall rule: {rule['name']}")
        except RuntimeError as e:
            if "already exists" in str(e):
                log(f"Firewall rule exists: {rule['name']}")
            else:
                warn(f"Firewall rule {rule['name']}: {e}")


def ensure_secret(project: str, secret_name: str, value: str | None = None) -> None:
    """Create a Secret Manager secret if absent. If `value` is provided and the
    secret is newly created, add it as the first version. Existing secrets are
    left alone — the user managed the auth key outside our lifecycle."""
    try:
        _run_gcloud(
            ["secrets", "describe", secret_name, "--project", project],
            capture=True,
        )
        return  # already exists
    except RuntimeError:
        pass
    _run_gcloud(
        [
            "secrets",
            "create",
            secret_name,
            "--project",
            project,
            "--replication-policy",
            "automatic",
        ],
        capture=True,
    )
    if value:
        _run_gcloud(
            [
                "secrets",
                "versions",
                "add",
                secret_name,
                "--project",
                project,
                "--data-file",
                "-",
            ],
            input_data=value,
            capture=True,
        )
    log(f"Created secret: {secret_name}")


# ---------------------------------------------------------------------------
# Cloud-init / startup script generation
# ---------------------------------------------------------------------------


def _tailscale_startup_block(hostname: str) -> str:
    """Shell snippet to install Tailscale and auto-join using auth key from
    Secret Manager. Runs on every boot (idempotent, skips if already up)."""
    return f"""\
# --- Tailscale install + auto-join ---
if command -v apt-get >/dev/null 2>&1; then
  mkdir -p /etc/apt/apt.conf.d
  echo 'DPkg::Lock::Timeout "600";' > /etc/apt/apt.conf.d/99-dalston-lock-timeout
fi

if ! command -v tailscale >/dev/null 2>&1; then
  curl -fsSL https://tailscale.com/install.sh | sh
fi

cat > /usr/local/bin/dalston-tailscale-join.sh << 'TSEOF'
#!/bin/bash
set -euo pipefail

# Skip if already up
if tailscale status --json 2>/dev/null | python3 -c "import sys,json; sys.exit(0 if json.load(sys.stdin).get('BackendState')=='Running' else 1)" 2>/dev/null; then
  echo "Tailscale already connected"; exit 0
fi

PROJECT=$(curl -s "http://metadata.google.internal/computeMetadata/v1/project/project-id" -H "Metadata-Flavor: Google")
TS_HOSTNAME="{hostname}"

# Delete stale offline tailnet node with same hostname so we don't get a -1 suffix.
TS_API_KEY=$(gcloud secrets versions access latest --secret="{SECRET_TS_API_KEY}" --project="$PROJECT" 2>/dev/null || true)
if [ -n "$TS_API_KEY" ]; then
  curl -s -H "Authorization: Bearer $TS_API_KEY" \
    "https://api.tailscale.com/api/v2/tailnet/-/devices" | \
    python3 -c "
import sys, json
for d in json.load(sys.stdin).get('devices', []):
    if d.get('hostname') == '$TS_HOSTNAME' and not d.get('online', False):
        print(d['nodeId'])
" | while read -r node_id; do
    curl -s -X DELETE -H "Authorization: Bearer $TS_API_KEY" \
      "https://api.tailscale.com/api/v2/device/$node_id"
    echo "Removed stale Tailscale node: $node_id ($TS_HOSTNAME)"
  done
fi

TS_AUTH_KEY=$(gcloud secrets versions access latest --secret="{SECRET_TS_AUTH_KEY}" --project="$PROJECT" 2>/dev/null || true)
if [ -n "$TS_AUTH_KEY" ]; then
  tailscale up --authkey="$TS_AUTH_KEY" --hostname="$TS_HOSTNAME"
  echo "Tailscale joined as $TS_HOSTNAME"
else
  echo "WARNING: no Tailscale auth key in Secret Manager. Run 'sudo tailscale up' manually."
fi
TSEOF
chmod +x /usr/local/bin/dalston-tailscale-join.sh

cat > /etc/systemd/system/dalston-tailscale.service << 'SVCEOF'
[Unit]
Description=Dalston Tailscale auto-join
After=network-online.target tailscaled.service
Wants=network-online.target tailscaled.service

[Service]
Type=oneshot
ExecStart=/usr/local/bin/dalston-tailscale-join.sh
RemainAfterExit=true

[Install]
WantedBy=multi-user.target
SVCEOF
systemctl daemon-reload
systemctl enable dalston-tailscale.service
/usr/local/bin/dalston-tailscale-join.sh || true
"""


def _generate_docker_run_block(engine_name: str, port: int) -> str:
    """Docker run invocation for one GPU engine, identical semantics to the AWS
    version — same images, env vars, ports, and GHCR pulls."""
    preset = GPU_ENGINE_PRESETS[engine_name]
    image = f"$GHCR_REGISTRY/{preset['image']}:latest"
    container = preset["container"]
    extra_env_lines = [f'-e {k}="{v}"' for k, v in preset.get("extra_env", {}).items()]
    needs_hf = preset.get("needs_hf_token", False)
    hf_line = '-e HF_TOKEN="$HF_TOKEN"' if needs_hf else ""
    env_block = " \\\n    ".join(filter(None, extra_env_lines + [hf_line]))
    return f"""\
docker run -d --name {container} \\
  --gpus all \\
  --restart unless-stopped \\
  --network host \\
  $LOG_FLAGS \\
  -e DALSTON_WORKER_ID="$DALSTON_WORKER_ID" \\
  -e REDIS_URL="redis://$CTRL_PLANE_HOST:6379" \\
  -e POSTGRES_URL="postgresql://dalston:dalston@$CTRL_PLANE_HOST:5432/dalston" \\
  -e DALSTON_S3_BUCKET="$GCS_BUCKET" \\
  -e DALSTON_S3_REGION="$REGION" \\
  -e GOOGLE_APPLICATION_CREDENTIALS_FROM_METADATA="1" \\
  {env_block} \\
  $OTEL_FLAGS \\
  {image}
"""


def generate_gpu_worker_startup_script(
    gcs_bucket: str,
    region: str,
    worker_name: str,
    engines: list[str],
    registry: str | None = None,
    observability: bool = False,
) -> str:
    """Build the full startup script that runs on first boot of a GPU worker."""
    ghcr_registry = registry or os.environ.get("GHCR_REGISTRY", DEFAULT_GHCR_REGISTRY)
    hf_token = os.environ.get("HF_TOKEN", "")
    ts_hostname = f"{NAME_PREFIX}-gpu-{worker_name}"

    for eng in engines:
        if eng not in GPU_ENGINE_PRESETS:
            raise ValueError(
                f"Unknown engine '{eng}'. Available: {list(GPU_ENGINE_PRESETS)}"
            )
        if GPU_ENGINE_PRESETS[eng].get("needs_hf_token") and not hf_token:
            die(
                f"Engine '{eng}' requires HF_TOKEN for gated model access. "
                f"export HF_TOKEN=hf_... before launch."
            )

    presets = [GPU_ENGINE_PRESETS[e] for e in engines]
    pull_lines = "\n".join(
        f'docker pull "$GHCR_REGISTRY/{p["image"]}:latest"' for p in presets
    )
    containers = [p["container"] for p in presets]
    rm_line = "docker rm -f " + " ".join(containers) + " 2>/dev/null || true"
    run_blocks = [
        _generate_docker_run_block(eng, 9100 + i) for i, eng in enumerate(engines)
    ]
    run_section = "\n".join(run_blocks)

    header = """\
#!/bin/bash
set -euo pipefail
exec > >(tee /var/log/dalston-startup.log) 2>&1
echo "Starting Dalston GPU worker bootstrap at $(date)"
"""

    variables = f"""\
GCS_BUCKET="{gcs_bucket}"
REGION="{region}"
CTRL_PLANE_HOST="{NAME_PREFIX}-control-plane"
GHCR_REGISTRY="{ghcr_registry}"
HF_TOKEN="{hf_token}"
OBSERVABILITY="{"true" if observability else "false"}"
"""

    # Deep Learning VM image from GCP ships Docker + NVIDIA drivers + nvidia-container-toolkit
    # pre-installed. We just start the daemon and run engines. For non-DLVM images, the startup
    # script would need to install drivers first (see GPU_IMAGE comment in launch_gpu).
    body = (
        r"""
systemctl start docker
systemctl enable docker
usermod -aG docker ubuntu 2>/dev/null || true

# Verify NVIDIA toolkit is wired into Docker (DLVM image default)
if ! docker info 2>/dev/null | grep -qi nvidia; then
  echo "NVIDIA runtime not found, configuring..."
  if command -v nvidia-ctk >/dev/null 2>&1; then
    nvidia-ctk runtime configure --runtime=docker
    systemctl restart docker
  else
    echo "WARN: nvidia-ctk missing, GPU engines will fail. Check image."
  fi
fi

# Local SSD scratch mount for model cache, if present.
# Local SSDs on GCP appear as /dev/nvme0n*, but only when --local-ssd is passed at launch.
LOCAL_SSD=""
for dev in /dev/nvme*n1; do
  [ -b "$dev" ] || continue
  MODEL=$(lsblk -n -o MODEL "$dev" 2>/dev/null | head -1)
  if echo "$MODEL" | grep -qi "Google EphemeralDisk"; then
    LOCAL_SSD="$dev"; break
  fi
done

if [ -n "$LOCAL_SSD" ]; then
  EXISTING=$(lsblk -n -o MOUNTPOINT "$LOCAL_SSD" 2>/dev/null | grep -v '^$' | head -1 || true)
  if [ -z "$EXISTING" ]; then
    mkfs.ext4 -F "$LOCAL_SSD"
    mkdir -p /data/models
    mount "$LOCAL_SSD" /data/models
  else
    mkdir -p /data/models; rm -rf /data/models; ln -s "$EXISTING" /data/models
  fi
else
  mkdir -p /data/models
fi
chown -R 1000:1000 /data/models

"""
        + _tailscale_startup_block(ts_hostname)
        + f"""
# Pull engine images
{pull_lines}

mkdir -p /opt/dalston
cat > /opt/dalston/gpu-env.sh << ENVEOF
GCS_BUCKET="${{GCS_BUCKET}}"
REGION="${{REGION}}"
CTRL_PLANE_HOST="${{CTRL_PLANE_HOST}}"
GHCR_REGISTRY="${{GHCR_REGISTRY}}"
HF_TOKEN="${{HF_TOKEN}}"
OBSERVABILITY="${{OBSERVABILITY}}"
ENVEOF

cat > /opt/dalston/gpu-start.sh << 'STARTEOF'
#!/bin/bash
set -euo pipefail
source /opt/dalston/gpu-env.sh

{pull_lines}
{rm_line}

# Fetch instance ID from GCP metadata server (no token dance like IMDSv2).
DALSTON_WORKER_ID=$(curl -sf -H "Metadata-Flavor: Google" \\
  "http://metadata.google.internal/computeMetadata/v1/instance/id" 2>/dev/null || hostname)
echo "DALSTON_WORKER_ID=$DALSTON_WORKER_ID"

OTEL_FLAGS=""
LOG_FLAGS=""
if [ "$OBSERVABILITY" = "true" ]; then
  OTEL_FLAGS="-e OTEL_ENABLED=true -e OTEL_EXPORTER_OTLP_ENDPOINT=http://${{CTRL_PLANE_HOST}}:4317 -e DALSTON_METRICS_ENABLED=true -e DALSTON_METRICS_PORT=9100"
fi

{run_section}
echo "GPU engines started at $(date)"
STARTEOF
chmod +x /opt/dalston/gpu-start.sh

cat > /etc/systemd/system/dalston-gpu.service << SVCEOF
[Unit]
Description=Dalston GPU Worker ({worker_name})
Requires=docker.service dalston-tailscale.service
After=docker.service dalston-tailscale.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/opt/dalston/gpu-start.sh
ExecStop=/usr/bin/docker rm -f {" ".join(containers)}
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
SVCEOF

systemctl daemon-reload
systemctl enable --now dalston-gpu.service

echo "=========================================="
echo "GPU worker bootstrap completed at $(date)"
echo "=========================================="
"""
    )

    return header + variables + body


def generate_control_plane_startup_script(
    gcs_bucket: str,
    region: str,
    compose_profiles: str,
    registry: str,
    observability: bool = False,
) -> str:
    """Startup script for control-plane VM. Installs Docker, clones repo, starts
    compose. Mirrors dalston-aws `generate_user_data` at a high level but uses
    Ubuntu 22.04 (GCP default) instead of AL2023."""
    ts_hostname = f"{NAME_PREFIX}-control-plane"
    obs_profile = " --profile observability" if observability else ""
    header = """\
#!/bin/bash
set -euo pipefail
exec > >(tee /var/log/dalston-startup.log) 2>&1
echo "Starting Dalston control-plane bootstrap at $(date)"
"""
    variables = f"""\
GCS_BUCKET="{gcs_bucket}"
REGION="{region}"
GHCR_REGISTRY="{registry}"
COMPOSE_PROFILES="{compose_profiles}{obs_profile}"
REPO_URL="{REPO_URL}"
REPO_BRANCH="{REPO_BRANCH}"
"""
    body = (
        r"""
apt-get update -q
apt-get install -y docker.io docker-compose-plugin git curl jq python3

systemctl start docker
systemctl enable docker
usermod -aG docker ubuntu || true

"""
        + _tailscale_startup_block(ts_hostname)
        + r"""
# Persistent data mount if a secondary disk is attached as /dev/sdb
if [ -b /dev/sdb ] && [ -z "$(lsblk -n -o FSTYPE /dev/sdb)" ]; then
  mkfs.ext4 -F /dev/sdb
fi
mkdir -p /data
if [ -b /dev/sdb ]; then
  mount /dev/sdb /data || true
  echo "/dev/sdb /data ext4 defaults,nofail 0 2" >> /etc/fstab
fi

# Clone repo
mkdir -p /opt/dalston && cd /opt/dalston
if [ ! -d .git ]; then
  git clone -b "$REPO_BRANCH" "$REPO_URL" .
else
  git fetch origin "$REPO_BRANCH" && git reset --hard "origin/$REPO_BRANCH"
fi

# Start compose stack
cd /opt/dalston
DALSTON_S3_BUCKET="$GCS_BUCKET" \
  DALSTON_S3_REGION="$REGION" \
  GHCR_REGISTRY="$GHCR_REGISTRY" \
  docker compose $COMPOSE_PROFILES up -d || true

echo "Control plane bootstrap completed at $(date)"
"""
    )
    return header + variables + body


# ---------------------------------------------------------------------------
# Compute image lookups
# ---------------------------------------------------------------------------


def _control_plane_image_family() -> tuple[str, str]:
    """Ubuntu 22.04 LTS on GCP's public images project."""
    return ("ubuntu-os-cloud", "ubuntu-2204-lts")


def _gpu_image_family() -> tuple[str, str]:
    """GCP Deep Learning VM — PyTorch + CUDA + Docker + nvidia-container-toolkit preinstalled."""
    return (
        "deeplearning-platform-release",
        "pytorch-latest-gpu-ubuntu-2204-py310",
    )


# ---------------------------------------------------------------------------
# Launch primitives
# ---------------------------------------------------------------------------


def _instance_exists(project: str, zone: str, name: str) -> bool:
    try:
        _run_gcloud(
            [
                "compute",
                "instances",
                "describe",
                name,
                "--project",
                project,
                "--zone",
                zone,
            ],
            capture=True,
        )
        return True
    except RuntimeError:
        return False


def _describe_instance(project: str, zone: str, name: str) -> dict | None:
    try:
        return _run_gcloud(
            [
                "compute",
                "instances",
                "describe",
                name,
                "--project",
                project,
                "--zone",
                zone,
            ],
            json_out=True,
        )
    except RuntimeError:
        return None


def _instance_status(inst: dict | None) -> str:
    if not inst:
        return "terminated"
    # GCE statuses: PROVISIONING, STAGING, RUNNING, STOPPING, STOPPED, SUSPENDED, TERMINATED
    return str(inst.get("status", "unknown")).lower()


def _instance_external_ip(inst: dict | None) -> str:
    if not inst:
        return ""
    for ni in inst.get("networkInterfaces", []):
        for ac in ni.get("accessConfigs", []) or []:
            if ac.get("natIP"):
                return ac["natIP"]
    return ""


def launch_control_plane_instance(
    st: DeploymentState, tmpl: DeploymentTemplate, *, observability: bool = False
) -> None:
    cp = tmpl.control_plane
    name = f"{NAME_PREFIX}-control-plane"
    if _instance_exists(st.project, st.zone, name):
        status = _instance_status(_describe_instance(st.project, st.zone, name))
        if status in ("running", "stopped", "terminated", "suspended"):
            die(f"Control plane already exists ({name}, status={status}).")

    compose_profiles = " ".join(f"--profile {p}" for p in (cp.compose_profiles or []))
    startup = generate_control_plane_startup_script(
        st.gcs_bucket,
        st.region,
        compose_profiles,
        tmpl.registry,
        observability,
    )
    st.observability = observability

    image_project, image_family = _control_plane_image_family()
    log(f"Launching control plane {name} ({cp.instance_type}, spot={cp.spot})...")
    args = [
        "compute",
        "instances",
        "create",
        name,
        "--project",
        st.project,
        "--zone",
        st.zone,
        "--machine-type",
        cp.instance_type,
        "--network",
        st.network,
        "--subnet",
        "default",
        "--tags",
        CTRL_TAG,
        "--image-project",
        image_project,
        "--image-family",
        image_family,
        "--boot-disk-size",
        "100GB",
        "--boot-disk-type",
        "pd-balanced",
        "--service-account",
        st.service_account,
        "--scopes",
        "cloud-platform",
        "--labels",
        f"dalston=control-plane,scenario={st.scenario}",
    ]
    if cp.spot:
        args += [
            "--provisioning-model",
            "SPOT",
            "--instance-termination-action",
            "STOP",
        ]
    # Attach persistent data disk (create if missing)
    data_disk_name = f"{NAME_PREFIX}-data"
    _ensure_data_disk(st.project, st.zone, data_disk_name, cp.data_volume_gb)
    args += ["--disk", f"name={data_disk_name},device-name=sdb,mode=rw,boot=no"]

    with _startup_script_file(startup) as script_path:
        _run_gcloud(
            args + ["--metadata-from-file", f"startup-script={script_path}"],
            capture=True,
        )
    st.instance_name = name
    st.data_disk_name = data_disk_name
    save_state(st)
    inst = _describe_instance(st.project, st.zone, name)
    ip = _instance_external_ip(inst)
    audit("launch.control-plane", instance=name, ip=ip, project=st.project)
    log(f"Control plane running: {name} ({ip})")


def _ensure_data_disk(project: str, zone: str, disk_name: str, size_gb: int) -> None:
    try:
        _run_gcloud(
            [
                "compute",
                "disks",
                "describe",
                disk_name,
                "--project",
                project,
                "--zone",
                zone,
            ],
            capture=True,
        )
        return  # exists
    except RuntimeError:
        pass
    _run_gcloud(
        [
            "compute",
            "disks",
            "create",
            disk_name,
            "--project",
            project,
            "--zone",
            zone,
            "--size",
            f"{size_gb}GB",
            "--type",
            "pd-balanced",
        ],
        capture=True,
    )
    log(f"Created data disk {disk_name} ({size_gb} GB)")


def _check_gpu_compat(engines: list[str], gpu_type: str) -> None:
    cap = GPU_COMPUTE_CAPS.get(gpu_type)
    if cap is None:
        warn(f"Unknown GPU type '{gpu_type}' — compatibility unchecked.")
        return
    for eng in engines:
        need = ENGINE_MIN_COMPUTE.get(eng)
        if need and cap < need:
            die(
                f"Engine '{eng}' needs compute capability >= {need}, "
                f"{gpu_type} is {cap}. Pick a newer GPU (L4/A100/H100)."
            )


def _next_worker_hostname_suffix(existing: list[dict], base: str) -> str:
    """Match dalston-aws semantics: first replica has no suffix, replicas
    get `-1`, `-2`, …"""
    taken = {w.get("hostname") for w in existing}
    if base not in taken:
        return base
    i = 1
    while f"{base}-{i}" in taken:
        i += 1
    return f"{base}-{i}"


def launch_gpu_worker(
    st: DeploymentState,
    tmpl: DeploymentTemplate,
    *,
    spot: bool | None = None,
    gpu_type: str | None = None,
    engines: list[str] | None = None,
) -> None:
    gw = tmpl.gpu_worker
    if not gw:
        die("Template has no gpu_worker config.")
    if not st.instance_name:
        die("Control plane not launched. Run 'dalston-gcp launch control-plane' first.")
    cp_inst = _describe_instance(st.project, st.zone, st.instance_name)
    if _instance_status(cp_inst) != "running":
        die(
            f"Control plane is {_instance_status(cp_inst)}. Run 'dalston-gcp up' first."
        )

    use_spot = spot if spot is not None else gw.spot
    gpu_accelerator = gpu_type or gw.gpu_type
    machine_type = gw.instance_type
    engines = engines or list(GPU_ENGINE_PRESETS.keys())
    worker_name = "-".join(engines) if len(engines) < 3 else "combo"

    _check_gpu_compat(engines, gpu_accelerator)

    # Reap state entries for terminated workers with same label
    if st.gpu_workers:
        kept = []
        for w in st.gpu_workers:
            if w["name"] == worker_name:
                w_zone = w.get("zone", st.zone)
                status = _instance_status(
                    _describe_instance(st.project, w_zone, w["instance_name"])
                )
                if status in ("terminated",):
                    log(
                        f"Reaping terminated worker '{worker_name}' ({w['instance_name']})"
                    )
                    continue
            kept.append(w)
        if len(kept) != len(st.gpu_workers):
            st.gpu_workers = kept
            save_state(st)

    # Pick hostname + instance name
    existing_workers = list(st.gpu_workers or [])
    base_hostname = f"{NAME_PREFIX}-gpu-{worker_name}"
    hostname = _next_worker_hostname_suffix(existing_workers, base_hostname)
    # Instance name must be a valid GCP name: lowercase, no underscores, <=63 chars
    instance_name = hostname.replace("_", "-")

    log(
        f"Launching GPU worker '{hostname}' ({machine_type} + {gw.gpu_count}× {gpu_accelerator}, "
        f"spot={use_spot}, engines={engines})"
    )

    startup = generate_gpu_worker_startup_script(
        st.gcs_bucket,
        st.region,
        worker_name,
        engines,
        registry=tmpl.registry,
        observability=st.observability,
    )

    image_project, image_family = _gpu_image_family()
    args = [
        "compute",
        "instances",
        "create",
        instance_name,
        "--project",
        st.project,
        "--zone",
        st.zone,
        "--machine-type",
        machine_type,
        "--network",
        st.network,
        "--subnet",
        "default",
        "--tags",
        GPU_TAG,
        "--image-project",
        image_project,
        "--image-family",
        image_family,
        "--boot-disk-size",
        "100GB",
        "--boot-disk-type",
        "pd-balanced",
        "--service-account",
        st.service_account,
        "--scopes",
        "cloud-platform",
        "--maintenance-policy",
        "TERMINATE",  # required for GPU VMs
        "--accelerator",
        f"type={gpu_accelerator},count={gw.gpu_count}",
        "--metadata",
        f"dalston-hostname={hostname},dalston-engines={','.join(engines)}",
        "--labels",
        f"dalston=gpu,worker={worker_name}",
    ]
    if use_spot:
        args += [
            "--provisioning-model",
            "SPOT",
            "--instance-termination-action",
            "STOP",
        ]
    # Local SSD for model cache (free tier on most GPU machines — 375 GB per device)
    # Can fail on tiny machine types; don't block if rejected.
    with _startup_script_file(startup) as script_path:
        script_args = ["--metadata-from-file", f"startup-script={script_path}"]
        try:
            _run_gcloud(
                args + script_args + ["--local-ssd", "interface=NVME"], capture=True
            )
        except RuntimeError as e:
            if "does not support" in str(e) or "invalid" in str(e).lower():
                log(
                    "Local SSD not supported on this machine type, falling back to boot disk for models"
                )
                _run_gcloud(args + script_args, capture=True)
            else:
                raise

    worker = asdict(
        GpuWorker(
            name=worker_name,
            hostname=hostname,
            instance_name=instance_name,
            instance_type=machine_type,
            gpu_type=gpu_accelerator,
            gpu_count=gw.gpu_count,
            spot=use_spot,
            zone=st.zone,
            engines=engines,
        )
    )
    if st.gpu_workers is None:
        st.gpu_workers = []
    st.gpu_workers.append(worker)
    save_state(st)

    inst = _describe_instance(st.project, st.zone, instance_name)
    ip = _instance_external_ip(inst)
    audit(
        "launch.gpu",
        instance=instance_name,
        ip=ip,
        worker=worker_name,
        hostname=hostname,
        gpu_type=gpu_accelerator,
    )
    log(f"GPU worker '{hostname}' running: {instance_name} ({ip})")


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------


def cmd_setup(args: argparse.Namespace) -> None:
    # Preflight: verify gcloud is installed, authenticated, project is set,
    # and required APIs are enabled. Prints copy-pasteable fixes on failure.
    preflight_project = preflight(auto_fix=args.auto_enable_apis)
    tmpl = load_template(args.template)
    region = args.region or tmpl.region
    tmpl.region = region
    project = args.project or preflight_project
    zone = args.zone or _default_zone(region)

    audit("setup", project=project, region=region, template=args.template)

    # Idempotency check
    existing = load_state()
    if existing:
        log("Existing deployment found. Verifying infrastructure...")
        existing.region = region
        existing.project = project
        existing.zone = zone or existing.zone
        existing.gcs_bucket = create_gcs_bucket(project, region)
        existing.service_account = create_service_account(project, existing.gcs_bucket)
        create_firewall_rules(project, existing.network)
        ensure_secret(project, SECRET_TS_AUTH_KEY)
        ensure_secret(project, SECRET_TS_API_KEY)
        save_state(existing)
        cmd_status_impl(existing)
        return

    log(f"Setting up Dalston on GCP (project={project}, region={region})")
    st = DeploymentState(
        project=project,
        region=region,
        zone=zone,
        scenario=tmpl.scenario,
        template=args.template,
    )
    st.gcs_bucket = create_gcs_bucket(project, region)
    st.service_account = create_service_account(project, st.gcs_bucket)
    create_firewall_rules(project, st.network)
    ensure_secret(project, SECRET_TS_AUTH_KEY)
    ensure_secret(project, SECRET_TS_API_KEY)
    save_state(st)
    audit("setup.done", project=project)
    log("Infrastructure ready.")
    log("Next:")
    log(
        f"  1. Upload Tailscale auth key: echo -n 'tskey-...' | gcloud secrets versions add {SECRET_TS_AUTH_KEY} --data-file=- --project={project}"
    )
    log("  2. dalston-gcp launch control-plane")
    cmd_status_impl(st)


def cmd_status_impl(st: DeploymentState) -> None:
    print()
    log("Dalston GCP Deployment")
    log(f"  Project:  {st.project}")
    log(f"  Scenario: {st.scenario}")
    if st.template:
        log(f"  Template: {st.template}")
    log(f"  Region:   {st.region} (zone {st.zone})")
    log(f"  GCS:      gs://{st.gcs_bucket}")
    log(f"  SA:       {st.service_account}")
    print()

    if st.instance_name:
        inst = _describe_instance(st.project, st.zone, st.instance_name)
        status = _instance_status(inst)
        ip = _instance_external_ip(inst)
        log(f"  Control plane: {st.instance_name}  status={status}  ip={ip or 'none'}")

    if st.gpu_workers:
        for w in st.gpu_workers:
            zone = w.get("zone", st.zone)
            inst = _describe_instance(st.project, zone, w["instance_name"])
            status = _instance_status(inst)
            ip = _instance_external_ip(inst)
            engines = ",".join(w.get("engines") or [])
            pricing = "spot" if w.get("spot", True) else "on-demand"
            itype = w.get("instance_type", "")
            gpu = f"{w.get('gpu_count', 1)}× {w.get('gpu_type', '')}"
            host = w.get("hostname") or "(unresolved — run reconcile)"
            log(
                f"  GPU '{w['name']}' [{host}]:  {w['instance_name']}  "
                f"status={status}  ip={ip or 'none'}  {itype}+{gpu} ({pricing})  "
                f"engines={engines}"
            )
    print()


def cmd_status(args: argparse.Namespace) -> None:
    st = require_state()
    cmd_status_impl(st)


def cmd_launch(args: argparse.Namespace) -> None:
    st = require_state()
    if not st.template:
        die("No template recorded in state. Re-run 'dalston-gcp setup -t TEMPLATE'.")
    tmpl = load_template(st.template)
    target = args.target

    spot_override = True if args.spot else (False if args.on_demand else None)

    if target in ("control-plane", None):
        launch_control_plane_instance(st, tmpl, observability=args.observability)
    if target in ("gpu", None):
        if tmpl.gpu_worker:
            engines = args.engines.split(",") if args.engines else None
            with _launch_lock():
                launch_gpu_worker(
                    st,
                    tmpl,
                    spot=spot_override,
                    gpu_type=args.gpu_type,
                    engines=engines,
                )
        elif target == "gpu":
            die("Template has no gpu_worker config.")

    cmd_status_impl(st)


def _terminate_gpu(st: DeploymentState, name: str | None = None) -> None:
    if not st.gpu_workers:
        log("No GPU workers to terminate.")
        return
    if name is None:
        targets = list(st.gpu_workers)
    else:
        # Match either hostname or label
        targets = [
            w
            for w in st.gpu_workers
            if w.get("hostname") == name
            or w["name"] == name
            or w["instance_name"] == name
        ]
        if not targets:
            die(
                f"No GPU worker matches '{name}'. Options: "
                f"{[w.get('hostname') or w['name'] for w in st.gpu_workers]}"
            )

    for w in targets:
        zone = w.get("zone", st.zone)
        log(f"Terminating GPU worker {w['instance_name']} (zone {zone})...")
        try:
            _run_gcloud(
                [
                    "compute",
                    "instances",
                    "delete",
                    w["instance_name"],
                    "--project",
                    st.project,
                    "--zone",
                    zone,
                    "--quiet",
                ],
                capture=True,
            )
        except RuntimeError as e:
            warn(f"Failed to delete {w['instance_name']}: {e}")
        audit("terminate.gpu", instance=w["instance_name"], hostname=w.get("hostname"))

    # Prune from state
    terminated_ids = {w["instance_name"] for w in targets}
    st.gpu_workers = [
        w for w in st.gpu_workers if w["instance_name"] not in terminated_ids
    ]
    save_state(st)


def _terminate_control_plane(st: DeploymentState) -> None:
    if not st.instance_name:
        log("No control plane to terminate.")
        return
    log(f"Terminating control plane {st.instance_name}...")
    try:
        _run_gcloud(
            [
                "compute",
                "instances",
                "delete",
                st.instance_name,
                "--project",
                st.project,
                "--zone",
                st.zone,
                "--quiet",
                # Don't delete the attached data disk — preserve state
                "--keep-disks",
                "data",
            ],
            capture=True,
        )
    except RuntimeError as e:
        warn(f"Failed to delete control plane: {e}")
    audit("terminate.control-plane", instance=st.instance_name)
    st.instance_name = ""
    save_state(st)


def cmd_terminate(args: argparse.Namespace) -> None:
    st = require_state()
    target = args.target
    if target == "all":
        _terminate_gpu(st)
        _terminate_control_plane(st)
    elif target == "gpu":
        _terminate_gpu(st, args.name)
    elif target == "control-plane":
        _terminate_control_plane(st)
    cmd_status_impl(st)


def cmd_up(args: argparse.Namespace) -> None:
    st = require_state()
    instances = []
    if st.instance_name:
        instances.append((st.zone, st.instance_name))
    for w in st.gpu_workers or []:
        instances.append((w.get("zone", st.zone), w["instance_name"]))
    for zone, name in instances:
        log(f"Starting {name} in {zone}...")
        try:
            _run_gcloud(
                [
                    "compute",
                    "instances",
                    "start",
                    name,
                    "--project",
                    st.project,
                    "--zone",
                    zone,
                ],
                capture=True,
            )
        except RuntimeError as e:
            warn(f"Failed to start {name}: {e}")
    audit("up")


def cmd_down(args: argparse.Namespace) -> None:
    st = require_state()
    instances = []
    if st.instance_name:
        instances.append((st.zone, st.instance_name))
    for w in st.gpu_workers or []:
        instances.append((w.get("zone", st.zone), w["instance_name"]))
    for zone, name in instances:
        log(f"Stopping {name} in {zone}...")
        try:
            _run_gcloud(
                [
                    "compute",
                    "instances",
                    "stop",
                    name,
                    "--project",
                    st.project,
                    "--zone",
                    zone,
                ],
                capture=True,
            )
        except RuntimeError as e:
            warn(f"Failed to stop {name}: {e}")
    audit("down")


def cmd_ssh(args: argparse.Namespace) -> None:
    st = require_state()
    if args.target == "gpu":
        if not st.gpu_workers:
            die("No GPU workers. Use 'dalston-gcp ssh main' for the control plane.")
        if args.name:
            candidates = [
                w
                for w in st.gpu_workers
                if w.get("hostname") == args.name
                or w["name"] == args.name
                or w["instance_name"] == args.name
            ]
            if not candidates:
                die(f"GPU worker '{args.name}' not found.")
            worker = candidates[0]
        else:
            worker = st.gpu_workers[0]
            if len(st.gpu_workers) > 1:
                labels = [w.get("hostname") or w["name"] for w in st.gpu_workers]
                warn(
                    f"Multiple GPU workers: {labels}. Connecting to "
                    f"'{worker.get('hostname') or worker['name']}'. Use --name."
                )
        name = worker["instance_name"]
        zone = worker.get("zone", st.zone)
    else:
        if not st.instance_name:
            die("No control plane. Run 'dalston-gcp launch control-plane'.")
        name = st.instance_name
        zone = st.zone

    log(f"Connecting to {name} via gcloud ssh (tunnelled through IAP)...")
    # Use gcloud's built-in SSH — handles keys, IAP, metadata SSH.
    os.execvp(
        "gcloud",
        [
            "gcloud",
            "compute",
            "ssh",
            name,
            f"--project={st.project}",
            f"--zone={zone}",
            "--tunnel-through-iap",
        ],
    )


def cmd_teardown(args: argparse.Namespace) -> None:
    st = load_state()
    if not st:
        log("No deployment to tear down.")
        return
    if not args.yes:
        print()
        warn("This will DELETE all GCP resources created by dalston-gcp:")
        warn("  - Compute instances (control plane + GPU workers)")
        warn(f"  - Data disk: {st.data_disk_name}")
        warn(f"  - GCS bucket: gs://{st.gcs_bucket} (with ALL contents)")
        warn(
            f"  - Firewall rules: {NAME_PREFIX}-ssh, {NAME_PREFIX}-tailscale-udp, {NAME_PREFIX}-internal"
        )
        warn(f"  - Service account: {st.service_account}")
        warn(f"  - Secrets: {SECRET_TS_AUTH_KEY}, {SECRET_TS_API_KEY}")
        print()
        ans = input("Type 'yes' to confirm: ")
        if ans.strip().lower() != "yes":
            log("Aborted.")
            return

    # 1. Terminate instances
    _terminate_gpu(st)
    _terminate_control_plane(st)

    # 2. Delete data disk
    if st.data_disk_name:
        try:
            _run_gcloud(
                [
                    "compute",
                    "disks",
                    "delete",
                    st.data_disk_name,
                    "--project",
                    st.project,
                    "--zone",
                    st.zone,
                    "--quiet",
                ],
                capture=True,
            )
            log(f"Deleted data disk {st.data_disk_name}")
        except RuntimeError as e:
            warn(f"Delete data disk: {e}")

    # 3. Firewall rules
    for rule in (
        f"{NAME_PREFIX}-ssh",
        f"{NAME_PREFIX}-tailscale-udp",
        f"{NAME_PREFIX}-internal",
    ):
        try:
            _run_gcloud(
                [
                    "compute",
                    "firewall-rules",
                    "delete",
                    rule,
                    "--project",
                    st.project,
                    "--quiet",
                ],
                capture=True,
            )
            log(f"Deleted firewall rule {rule}")
        except RuntimeError:
            pass

    # 4. Secrets
    for secret in (SECRET_TS_AUTH_KEY, SECRET_TS_API_KEY):
        try:
            _run_gcloud(
                ["secrets", "delete", secret, "--project", st.project, "--quiet"],
                capture=True,
            )
            log(f"Deleted secret {secret}")
        except RuntimeError:
            pass

    # 5. Service account
    if st.service_account:
        try:
            _run_gcloud(
                [
                    "iam",
                    "service-accounts",
                    "delete",
                    st.service_account,
                    "--project",
                    st.project,
                    "--quiet",
                ],
                capture=True,
            )
            log(f"Deleted service account {st.service_account}")
        except RuntimeError:
            pass

    # 6. GCS bucket (with contents) — ONLY if user really wants it
    if st.gcs_bucket and args.delete_bucket:
        try:
            _run_gsutil(["-m", "rm", "-r", f"gs://{st.gcs_bucket}"], check=False)
            _run_gsutil(["rb", f"gs://{st.gcs_bucket}"], check=False)
            log(f"Deleted GCS bucket gs://{st.gcs_bucket}")
        except RuntimeError as e:
            warn(f"Delete bucket: {e}")
    elif st.gcs_bucket:
        log(f"Kept GCS bucket gs://{st.gcs_bucket} (pass --delete-bucket to remove).")

    # 7. Local state file
    STATE_FILE.unlink(missing_ok=True)
    audit("teardown")
    log("Teardown complete.")


def cmd_reconcile(args: argparse.Namespace) -> None:
    """Re-resolve Tailscale hostnames for GPU workers with unresolved entries.

    Stub — needs parity with dalston-aws cmd_reconcile. The Tailscale matching
    logic is cloud-agnostic; port it from dalston-aws when this becomes blocking.
    """
    warn("reconcile: not yet implemented for GCP. Falls through to no-op.")
    warn("If you need this, it's a straight port of cmd_reconcile from dalston-aws.")


def cmd_patch(args: argparse.Namespace) -> None:
    """Trigger OS patching. AWS uses SSM RunCommand; GCP equivalent is VM Manager
    OS Config Patch. Stub for now — instances patch themselves on the daily
    systemd timer baked into the startup script (matches AWS behaviour)."""
    warn("patch: instances already run a daily systemd timer (04:00 UTC).")
    warn(
        "For on-demand patching, SSH in and run `apt-get update && apt-get upgrade -y`."
    )
    warn("A proper GCP port would use `gcloud compute os-config patch-jobs execute`.")


def cmd_engine(args: argparse.Namespace) -> None:
    warn("engine subcommand: not yet ported to GCP. Use launch gpu for now.")


def cmd_doctor(args: argparse.Namespace) -> None:
    """Diagnose and optionally fix GCP prerequisites. Safe to run any time.

    Checks, in order:
      1. gcloud CLI installed
      2. authenticated account
      3. active project set
      4. required APIs enabled (compute, storage, secretmanager, iam)
      5. Tailscale auth key uploaded (if deployment already exists)

    Prints pass/fail for each and exits 0 if healthy, 1 otherwise.
    """
    print()
    log("Dalston GCP prerequisites check")
    print()

    all_ok = True

    # 1. gcloud installed
    probs = _check_gcloud_installed()
    if probs:
        print(f"  {_RED}✗{_NC} gcloud CLI not installed")
        for line in probs:
            print(f"      {line}")
        print()
        sys.exit(1)  # can't check anything else without gcloud
    print(f"  {_GREEN}✓{_NC} gcloud CLI installed")

    # 2. auth
    probs = _check_gcloud_auth()
    if probs:
        print(f"  {_RED}✗{_NC} gcloud not authenticated")
        for line in probs:
            print(f"      {line}")
        all_ok = False
    else:
        try:
            account = _run_gcloud(
                ["config", "get-value", "account"],
                check=False,
            ).stdout.strip()
        except Exception:
            account = "?"
        print(f"  {_GREEN}✓{_NC} gcloud authenticated as {account}")

    # 3. project
    project, probs = _check_project_set()
    if probs or not project:
        print(f"  {_RED}✗{_NC} no active GCP project")
        for line in probs:
            print(f"      {line}")
        all_ok = False
    else:
        print(f"  {_GREEN}✓{_NC} active project: {project}")

        # 4. APIs (only checkable once we have a project)
        probs = _check_apis_enabled(project)
        if probs:
            print(f"  {_RED}✗{_NC} required APIs not all enabled")
            for line in probs:
                print(f"      {line}")
            if args.fix:
                # Pull missing API names out of the fix list
                missing = [
                    line.strip().lstrip("- ")
                    for line in probs
                    if line.strip().startswith("- ")
                ]
                if missing:
                    log(f"Enabling {len(missing)} API(s)...")
                    try:
                        _run_gcloud(
                            ["services", "enable", *missing, "--project", project]
                        )
                        print(
                            f"  {_GREEN}✓{_NC} APIs enabled (re-run doctor to confirm)"
                        )
                    except RuntimeError as e:
                        print(f"      auto-enable failed: {e}")
                        all_ok = False
            else:
                all_ok = False
        else:
            print(f"  {_GREEN}✓{_NC} all required APIs enabled")

    # 5. State + Tailscale key (only if setup has run)
    st = load_state()
    if st and st.project:
        # Tailscale auth key: check the secret exists and has at least one version
        try:
            _run_gcloud(
                [
                    "secrets",
                    "versions",
                    "access",
                    "latest",
                    "--secret",
                    SECRET_TS_AUTH_KEY,
                    "--project",
                    st.project,
                ],
                capture=True,
                check=True,
            )
            print(f"  {_GREEN}✓{_NC} Tailscale auth key present in Secret Manager")
        except Exception:
            print(f"  {_YELLOW}!{_NC} Tailscale auth key not yet uploaded")
            print(
                "      Get a reusable key at https://login.tailscale.com/admin/settings/keys"
            )
            print("      Then upload:")
            print(
                f"        echo -n 'tskey-auth-...' | gcloud secrets versions add "
                f"{SECRET_TS_AUTH_KEY} --data-file=- --project={st.project}"
            )
            all_ok = False

    print()
    if all_ok:
        log("All prerequisites satisfied.")
        sys.exit(0)
    else:
        log("Some prerequisites are missing. See fixes above.")
        if not args.fix:
            log("Tip: `dalston-gcp doctor --fix` will auto-enable missing APIs.")
        sys.exit(1)


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

QUICKSTART_EPILOG = """\
Quickstart (first-time setup):

  # 1. Install and authenticate gcloud SDK (one-time)
  brew install --cask google-cloud-sdk     # or see cloud.google.com/sdk/docs/install
  gcloud auth login
  gcloud auth application-default login
  gcloud config set project YOUR_PROJECT_ID

  # 2. Let dalston-gcp check & enable required APIs
  dalston-gcp doctor --fix

  # 3. Provision infra (bucket, service account, firewall, secrets)
  dalston-gcp setup -t split

  # 4. Upload Tailscale auth key (one-time; get one at
  #    https://login.tailscale.com/admin/settings/keys — reusable, 90-day OK)
  echo -n 'tskey-auth-...' | gcloud secrets versions add \\
    dalston-tailscale-auth-key --data-file=- --project=YOUR_PROJECT_ID

  # 5. Launch the control plane, then GPU workers
  dalston-gcp launch control-plane
  export HF_TOKEN=hf_...   # only if running pyannote
  dalston-gcp launch gpu --spot --engines nemo

  # Useful day-to-day:
  dalston-gcp status             # what's running where
  dalston-gcp ssh gpu --name nemo
  dalston-gcp down               # stop all, keep disks
  dalston-gcp up                 # restart
  dalston-gcp terminate gpu --name dalston-gpu-nemo
  dalston-gcp doctor             # re-check anything you forgot

State file: ~/.dalston/gcp-state.yaml
Audit log:  ~/.dalston/audit.log
"""


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="dalston-gcp",
        description="Provision and manage Dalston on GCP without Terraform.",
        epilog=QUICKSTART_EPILOG,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    p_setup = sub.add_parser(
        "setup",
        help="Provision GCP infra (bucket, SA, firewall)",
        description=(
            "Provisions: GCS bucket, service account, firewall rules, "
            "Secret Manager placeholders. Runs `doctor` checks first."
        ),
    )
    p_setup.add_argument(
        "-t", "--template", required=True, help="Template name (e.g. 'split') or path"
    )
    p_setup.add_argument("--region", help="GCP region (overrides template)")
    p_setup.add_argument("--zone", help="GCP zone within region (default: <region>-a)")
    p_setup.add_argument(
        "--project", help="GCP project (default: active gcloud config)"
    )
    p_setup.add_argument(
        "--auto-enable-apis",
        action="store_true",
        help="Auto-enable missing required APIs instead of erroring out",
    )
    p_setup.set_defaults(func=cmd_setup)

    p_status = sub.add_parser("status", help="Show deployment state")
    p_status.set_defaults(func=cmd_status)

    p_launch = sub.add_parser("launch", help="Launch instances")
    p_launch.add_argument(
        "target",
        nargs="?",
        choices=["control-plane", "gpu"],
        default=None,
        help="Component to launch (default: all from template)",
    )
    pricing = p_launch.add_mutually_exclusive_group()
    pricing.add_argument("--spot", action="store_true", help="Force spot pricing")
    pricing.add_argument(
        "--on-demand", action="store_true", help="Force on-demand pricing"
    )
    p_launch.add_argument(
        "--gpu-type", help="Override GPU accelerator (e.g. nvidia-l4)"
    )
    p_launch.add_argument(
        "--engines",
        help="Comma-separated engines to run (e.g. 'nemo' or 'pyannote,onnx')",
    )
    p_launch.add_argument(
        "--observability",
        action="store_true",
        help="Deploy observability stack (Jaeger, Prometheus, Grafana, Loki)",
    )
    p_launch.set_defaults(func=cmd_launch)

    p_term = sub.add_parser("terminate", help="Delete instances (keeps disks/bucket)")
    p_term.add_argument(
        "target",
        nargs="?",
        choices=["control-plane", "gpu", "all"],
        default="all",
    )
    p_term.add_argument(
        "--name", help="GPU worker label or hostname (for multiple replicas)"
    )
    p_term.set_defaults(func=cmd_terminate)

    p_up = sub.add_parser("up", help="Start stopped instances")
    p_up.set_defaults(func=cmd_up)

    p_down = sub.add_parser("down", help="Stop instances without deleting them")
    p_down.set_defaults(func=cmd_down)

    p_ssh = sub.add_parser("ssh", help="SSH into an instance")
    p_ssh.add_argument(
        "target",
        nargs="?",
        choices=["main", "gpu"],
        default="main",
    )
    p_ssh.add_argument("--name", help="GPU worker label or hostname")
    p_ssh.set_defaults(func=cmd_ssh)

    p_tear = sub.add_parser(
        "teardown", help="Delete everything (instances, disks, SA, rules)"
    )
    p_tear.add_argument("--yes", action="store_true", help="Skip confirmation")
    p_tear.add_argument(
        "--delete-bucket",
        action="store_true",
        help="Also delete GCS bucket and ALL its contents",
    )
    p_tear.set_defaults(func=cmd_teardown)

    p_rec = sub.add_parser("reconcile", help="Re-resolve Tailscale hostnames (stub)")
    p_rec.set_defaults(func=cmd_reconcile)

    p_patch = sub.add_parser("patch", help="On-demand OS patching (stub)")
    p_patch.set_defaults(func=cmd_patch)

    p_eng = sub.add_parser("engine", help="Single-engine direct mode (stub)")
    p_eng.set_defaults(func=cmd_engine)

    p_doc = sub.add_parser(
        "doctor",
        help="Check GCP prerequisites (gcloud, auth, project, APIs, secrets)",
        description=(
            "Diagnose whether your environment is ready to run dalston-gcp. "
            "Prints each check with a pass/fail indicator and copy-pasteable "
            "fix commands for any failures. Safe to run any time."
        ),
    )
    p_doc.add_argument(
        "--fix",
        action="store_true",
        help="Auto-enable missing required APIs (the only thing this tool can fix)",
    )
    p_doc.set_defaults(func=cmd_doctor)

    return p


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
