#!/usr/bin/env python3
"""dalston-gcp — provision and manage Dalston on Google Cloud without Terraform.

Parity target: dalston-aws. Same CLI surface, same state-file layout, same
engine preset dict so engines run unchanged.

Usage:
    dalston-gcp setup -t TEMPLATE [--region R] [--project P]
    dalston-gcp launch [control-plane|gpu] [--spot | --on-demand]
                       [--gpu-type GPU_TYPE] [--engines E1,E2]
    dalston-gcp terminate [control-plane|gpu] [--name NAME]
    dalston-gcp up / down                           # start/stop without deleting
    dalston-gcp status / ssh [main|gpu] / teardown
    dalston-gcp reconcile                           # re-resolve Tailscale hosts
    dalston-gcp patch                               # on-demand OS patching (stub)

Templates:
    YAML files in infra/templates/ prefixed with `gcp-` (e.g. gcp-split.yaml).
    Dalston-aws templates without the prefix are not read — GCP instance types
    differ.

Prerequisites:
    - gcloud CLI installed and authenticated (`gcloud auth login`)
    - A project set (`gcloud config set project PROJECT_ID`)
    - Compute Engine API enabled: `gcloud services enable compute.googleapis.com`
    - Storage API enabled: `gcloud services enable storage.googleapis.com`
    - Secret Manager API: `gcloud services enable secretmanager.googleapis.com`
    - Python >= 3.11, pip install pyyaml

State file: ~/.dalston/gcp-state.yaml
Audit log:  ~/.dalston/audit.log (shared with dalston-aws)
"""

from __future__ import annotations

import sys

if sys.version_info < (3, 11):  # noqa: UP036
    sys.stderr.write(
        "dalston-gcp requires Python >= 3.11 "
        f"(got {sys.version_info.major}.{sys.version_info.minor}).\n"
        "Invoke with a newer interpreter, e.g.\n"
        "  .venv/bin/python ./infra/scripts/dalston-gcp ...\n"
    )
    sys.exit(1)

import argparse
import fcntl
import json
import os
import subprocess
import tempfile
from contextlib import contextmanager
from dataclasses import asdict, dataclass
from datetime import UTC, datetime
from pathlib import Path
from typing import Any, NoReturn

import yaml

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

STATE_DIR = Path.home() / ".dalston"
STATE_FILE = STATE_DIR / "gcp-state.yaml"
AUDIT_LOG = STATE_DIR / "audit.log"
TEMPLATES_DIR = Path(__file__).resolve().parent.parent / "templates"
